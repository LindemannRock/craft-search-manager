{
  "name": "@lindemannrock/search-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Build tools for Search Manager plugin",
  "scripts": {
    "build": "npm run build:widget && npm run build:analytics && npm run build:widgetpreview",
    "build:analytics": "mkdir -p src/web/assets/analytics/dist && terser src/web/assets/analytics/src/analytics.js -o src/web/assets/analytics/dist/analytics.js -c -m",
    "build:widgetpreview": "mkdir -p src/web/assets/widgetpreview/dist && terser src/web/assets/widgetpreview/src/widget-preview.js -o src/web/assets/widgetpreview/dist/widget-preview.js -c -m",
    "build:widget": "cd src/web/assets/searchwidget && npm run build",
    "dev": "cd src/web/assets/searchwidget && npm run dev",
    "watch": "cd src/web/assets/searchwidget && npm run watch",
    "test": "cd src/web/assets/searchwidget && npm test",
    "test:a11y": "cd src/web/assets/searchwidget && npm run test:a11y",
    "test:a11y:ui": "cd src/web/assets/searchwidget && npm run test:a11y:ui",
    "test:a11y:live": "cd src/web/assets/searchwidget && npm run test:a11y:live",
    "test:a11y:live:ui": "cd src/web/assets/searchwidget && npm run test:a11y:live:ui",
    "minify": "npm run build:analytics && npm run build:widgetpreview",
    "minify:analytics": "npm run build:analytics",
    "minify:widgetpreview": "npm run build:widgetpreview"
  },
  "devDependencies": {
    "terser": "^5.46.1"
  },
  "author": {
    "name": "Bilal Harry Lindemann",
    "email": "hello@lindemannrock.com",
    "url": "https://lindemannrock.com"
  },
  "company": {
    "name": "LindemannRock",
    "url": "https://lindemannrock.com"
  },
  "license": "Proprietary"
}
