{% extends 'lindemannrock-base/_layouts/cp-table' %}

{% set setupIncompleteSummary = include('search-manager/_partials/setup-incomplete-summary', {
    selectedSubnavItem: 'widgets',
})|trim %}
{% set errorSummary = setupIncompleteSummary %}

{# Follows the canonical CP table index-page pattern (in-memory variant) —
   see plugins/base/docs/template-guides/cp-table-index-pattern.md.
   WidgetsController::actionIndex() owns query-param parsing, allowlist
   validation, filter, sort, and pagination. This template stays
   presentational and just renders what's handed in. #}

{% set tableConfig = {
	plugin: {
		handle: 'search-manager',
		name: searchHelper.fullName,
	},
	page: {
		title: 'Widgets'|t('search-manager'),
		subnav: 'widgets',
		crumbs: [
			{ label: searchHelper.fullName, url: url('search-manager') },
			{ label: 'Widgets'|t('search-manager'), url: url('search-manager/widgets') },
			{ label: 'Configurations'|t('search-manager') }
		],
	},
	sidebarMenu: {
		label: 'Widgets'|t('search-manager'),
		items: {
			configurations: { label: 'Configurations'|t('search-manager'), url: url('search-manager/widgets') },
			styles: { label: 'Styles'|t('search-manager'), url: url('search-manager/widgets/styles') },
		},
		selected: 'configurations',
	},
	filters: [
		{
			type: 'status',
			param: 'status',
			current: statusFilter,
			label: 'All'|t('search-manager'),
			groups: [
				{
					param: 'status',
					current: statusFilter,
					colorSet: 'status',
					options: [
						{value: 'all', label: 'All'|t('search-manager'), status: 'all'},
						{value: 'enabled', label: 'Enabled'|t('search-manager'), colorKey: 'enabled'},
						{value: 'disabled', label: 'Disabled'|t('search-manager'), colorKey: 'disabled'},
					],
				},
				{
					header: 'Config Source'|t('search-manager'),
					param: 'source',
					current: sourceFilter,
					colorSet: 'configSource',
					options: [
						{value: 'all', label: 'All Sources'|t('search-manager'), status: 'all'},
						{value: 'config', label: 'Config File'|t('search-manager'), colorKey: 'config'},
						{value: 'database', label: 'Database'|t('search-manager'), colorKey: 'database'},
					],
				},
				{
					header: 'Widget Type'|t('search-manager'),
					param: 'type',
					current: typeFilter,
					colorSet: 'widgetType',
					options: [
						{value: 'all', label: 'All Types'|t('search-manager'), status: 'all'},
						{value: 'modal', label: 'Modal'|t('search-manager'), colorKey: 'modal'},
						{value: 'page', label: 'Search Page'|t('search-manager'), colorKey: 'page'},
						{value: 'inline', label: 'Inline Search'|t('search-manager'), colorKey: 'inline'},
					],
				},
			],
		},
	],
	search: {
		placeholder: 'Search widget configs...'|t('search-manager'),
		value: search,
	},
	sort: {
		field: sort,
		direction: dir,
	},
	table: {
		columns: [
			{key: 'name', label: 'Name'|t('search-manager'), sortable: true},
			{key: 'handle', label: 'Handle'|t('search-manager'), sortable: true, hideable: true},
			{key: 'type', label: 'Type'|t('search-manager'), sortable: true, hideable: true},
			{key: 'source', label: 'Source'|t('search-manager'), sortable: true, hideable: true},
			{key: 'enabled', label: 'Status'|t('search-manager'), sortable: true, hideable: true},
			{key: 'isDefault', label: 'Default'|t('search-manager'), sortable: true, hideable: true},
		],
		items: widgetConfigs,
		emptyMessage: 'No widget configurations found.'|t('search-manager'),
		hasConfigItems: hasConfigItems,
	},
	pagination: {
		page: page,
		limit: limit,
		totalCount: totalCount,
		itemLabel: {singular: 'config'|t('search-manager'), plural: 'configs'|t('search-manager')},
	},
	checkboxes: canEdit or canDelete,
	newButton: canCreate ?? false ? {
		url: url('search-manager/widgets/new'),
		label: 'New Widget Config'|t('search-manager'),
	} : null,
} %}

{% block beforeTable %}
	{# Warning if default widget is missing or disabled. The controller
	   resolves `defaultWidget` against the unfiltered list. #}
	{% if defaultWidgetHandle %}
		{% if not defaultWidget %}
			{# Default widget doesn't exist #}
			{% set warningMessage %}
			<strong>{{ 'Warning'|t('search-manager') }}:</strong>
			{{ 'The default widget handle "{handle}" does not exist.'|t('search-manager', {handle: '<strong>' ~ defaultWidgetHandle|e ~ '</strong>'})|raw }}
			{% if isDefaultFromConfig %}
				{{ 'Update your config/search-manager.php to point to a valid widget handle.'|t('search-manager') }}
			{% else %}
				{{ 'Please set a different widget as default.'|t('search-manager') }}
			{% endif %}
			{% endset %}
			<div class="lr-info-box-table-wrapper">
				{% include 'lindemannrock-base/_components/info-box' with {
					message: warningMessage,
					type: 'warning',
					margin: 'none',
					stretch: true,
				} %}
			</div>
		{% elseif not defaultWidget.enabled %}
			{# Default widget exists but is disabled #}
			{% set warningMessage %}
			<strong>{{ 'Warning'|t('search-manager') }}:</strong>
			{{ 'The default widget "{name}" is disabled. Search widget may not work.'|t('search-manager', {name: '<strong>' ~ defaultWidget.name|e ~ '</strong>'})|raw }}
			{% if not isDefaultFromConfig %}
				{{ 'Please enable it or set a different widget as default.'|t('search-manager') }}
			{% else %}
				{{ 'Update your config/search-manager.php to fix this.'|t('search-manager') }}
			{% endif %}
			{% endset %}
			<div class="lr-info-box-table-wrapper">
				{% include 'lindemannrock-base/_components/info-box' with {
					message: warningMessage,
					type: 'warning',
					margin: 'none',
					stretch: true,
				} %}
			</div>
		{% endif %}
	{% elseif hasAnyWidgets %}
		{# No default handle set but widgets exist #}
		{% set warningMessage %}
		<strong>{{ 'Warning'|t('search-manager') }}:</strong>
		{{ 'No default widget is configured. Please set one of the widgets as default.'|t('search-manager') }}
		{% endset %}
		<div class="lr-info-box-table-wrapper">
			{% include 'lindemannrock-base/_components/info-box' with {
				message: warningMessage,
				type: 'warning',
				margin: 'none',
				stretch: true,
			} %}
		</div>
	{% endif %}

	{# Warning for handle collisions between config and database #}
	{% if collisionHandles is defined and collisionHandles|length %}
		{% set boldHandles = [] %}
		{% for handle in collisionHandles %}
			{% set boldHandles = boldHandles|merge(['<strong>' ~ handle|e ~ '</strong>']) %}
		{% endfor %}
		{% set warningMessage %}
		<strong>{{ 'Warning'|t('search-manager') }}:</strong>
		{{ 'These widget handles exist in both config/search-manager.php and the database:'|t('search-manager') }} {{ boldHandles|join(', ')|raw }}.
		{{ 'Config takes precedence; database entries with the same handle are ignored.'|t('search-manager') }}
		{{ 'Update your config/search-manager.php or remove the database entries to resolve this.'|t('search-manager') }}
		{% endset %}
		<div class="lr-info-box-table-wrapper">
			{% include 'lindemannrock-base/_components/info-box' with {
				message: warningMessage,
				type: 'warning',
				margin: 'none',
				stretch: true,
			} %}
		</div>
	{% endif %}
{% endblock %}

{% block tableRow %}
	{% set isConfig = item.isFromConfig() %}
	{% set isDefault = defaultWidgetHandle == item.handle %}

	{# Name #}
	<td data-column="name">
		{% if item.canEdit() %}
			<a class="label-link" href="{{ url('search-manager/widgets/edit/' ~ item.id) }}">
				<span>{{ item.name }}</span>
			</a>
		{% else %}
			<a class="label-link" href="{{ url('search-manager/widgets/view/' ~ item.handle) }}">
				<span>{{ item.name }}</span>
			</a>
			<span class="lr-config-info-icon" data-config="{{ item.rawConfigDisplay|e('html_attr') }}" data-config-source="config/search-manager.php"></span>
		{% endif %}
	</td>

	{# Handle #}
	<td data-column="handle">
		<code>{{ item.handle }}</code>
	</td>

	{# Type #}
	<td data-column="type">
		{% set typeLabels = {modal: 'Modal', page: 'Search Page', inline: 'Inline Search'} %}
		{% include 'lindemannrock-base/_components/badge' with {
			label: typeLabels[item.type] ?? item.type|capitalize,
			value: item.type,
			colorSet: 'widgetType',
		} only %}
	</td>

	{# Source #}
	<td data-column="source">
		{% include 'lindemannrock-base/_components/badge' with {
			label: item.source == 'config' ? 'Config'|t('search-manager') : 'Database'|t('search-manager'),
			value: item.source,
			colorSet: 'configSource',
		} only %}
	</td>

	{# Status #}
	<td data-column="enabled">
		{% include 'lindemannrock-base/_components/badge' with {
			label: item.enabled ? 'Enabled'|t('search-manager') : 'Disabled'|t('search-manager'),
			value: item.enabled ? 'enabled' : 'disabled',
			colorSet: 'status',
		} only %}
	</td>

	{# Default #}
	<td data-column="isDefault">
		{% if isDefault %}
			{% include 'lindemannrock-base/_components/badge' with {
				label: 'Yes'|t('search-manager'),
				value: 'yes',
				colorSet: 'yesNo',
			} only %}
		{% else %}
			<span class="light">-</span>
		{% endif %}
	</td>
{% endblock %}

{% block rowActions %}
	{% set isDefault = defaultWidgetHandle == item.handle %}
	{% set actionItems = [] %}

	{% if item.canEdit() %}
		{% if canEdit %}
			{% set actionItems = actionItems|merge([{
				label: 'Edit'|t('search-manager'),
				url: url('search-manager/widgets/edit/' ~ item.id),
			}]) %}
			{% if canCreate %}
				{% set actionItems = actionItems|merge([{
					label: 'Duplicate'|t('search-manager'),
					jsAction: 'duplicate',
				}]) %}
			{% endif %}
			{% if not isDefault and not isDefaultFromConfig %}
				{% set actionItems = actionItems|merge([{
					label: 'Set as Default'|t('search-manager'),
					jsAction: 'set-default',
					data: {name: item.name},
				}]) %}
			{% endif %}
		{% endif %}
		{% if canDelete and not isDefault %}
			{% set actionItems = actionItems|merge([
				{type: 'divider'},
				{
					label: 'Delete'|t('search-manager'),
					class: 'error',
					jsAction: 'delete',
					data: {name: item.name},
				},
			]) %}
		{% endif %}
	{% else %}
		{% set actionItems = actionItems|merge([{
			label: 'View'|t('search-manager'),
			url: url('search-manager/widgets/view/' ~ item.handle),
		}]) %}
		{% if canEdit and not isDefault and not isDefaultFromConfig %}
			{% set actionItems = actionItems|merge([{
				label: 'Set as Default'|t('search-manager'),
				jsAction: 'set-default',
				data: {name: item.name},
			}]) %}
		{% endif %}
	{% endif %}

	{% if actionItems|length > 0 %}
		{% include 'lindemannrock-base/_components/row-actions' with {
			item: {id: item.id},
			actions: {
				type: 'menu',
				icon: 'settings',
				title: 'Actions'|t('search-manager'),
				items: actionItems,
			},
		} only %}
	{% endif %}
{% endblock %}

{% block bulkActions %}
	{% if canEdit %}
		{% include 'lindemannrock-base/_components/bulk-status-menu' with {
			label: 'Set status'|t('search-manager'),
			countId: 'lr-bulk-status-count',
			items: [
				{id: 'lr-bulk-enable-action', label: 'Enable'|t('search-manager'), status: 'enabled'},
				{id: 'lr-bulk-disable-action', label: 'Disable'|t('search-manager'), status: 'disabled'},
			],
		} only %}
	{% endif %}

	{% if canDelete %}
		{% include 'lindemannrock-base/_components/bulk-actions-menu' with {
			label: 'Actions'|t('search-manager'),
			countId: 'lr-bulk-actions-count',
			items: [
				{id: 'lr-bulk-delete-btn', label: 'Delete'|t('search-manager'), class: 'error'},
			],
		} only %}
	{% endif %}
{% endblock %}

{% block scripts %}
<script>
(function() {
	if (typeof Craft === 'undefined') return;

	const T = {
		deleted: {{ 'Widget config deleted'|t('search-manager')|json_encode|raw }},
		deleteFailed: {{ 'Failed to delete config'|t('search-manager')|json_encode|raw }},
		deleteConfirm: {{ 'Delete widget config "{name}"? This cannot be undone.'|t('search-manager')|json_encode|raw }},
		duplicated: {{ 'Widget config duplicated'|t('search-manager')|json_encode|raw }},
		duplicateFailed: {{ 'Could not duplicate widget config'|t('search-manager')|json_encode|raw }},
		defaultUpdated: {{ 'Default config updated'|t('search-manager')|json_encode|raw }},
		defaultUpdateFailed: {{ 'Failed to update default config'|t('search-manager')|json_encode|raw }},
		bulkEnabledTemplate: {{ 'Enabled {count} configs'|t('search-manager')|json_encode|raw }},
		bulkEnableFailed: {{ 'Failed to enable configs'|t('search-manager')|json_encode|raw }},
		bulkDisabledTemplate: {{ 'Disabled {count} configs'|t('search-manager')|json_encode|raw }},
		bulkDisableFailed: {{ 'Failed to disable configs'|t('search-manager')|json_encode|raw }},
		bulkDeletedTemplate: {{ 'Deleted {count} config(s)'|t('search-manager')|json_encode|raw }},
		bulkDeleteFailed: {{ 'Failed to delete configs'|t('search-manager')|json_encode|raw }},
		bulkDeleteConfirmSingular: {{ 'Delete {count} config? This cannot be undone.'|t('search-manager')|json_encode|raw }},
		bulkDeleteConfirmPlural: {{ 'Delete {count} configs? This cannot be undone.'|t('search-manager')|json_encode|raw }},
	};

	function selectedIds() {
		return window.lrTableSelection ? window.lrTableSelection.getSelectedIds() : [];
	}

	// Row-action handler — delegated, anchor-scoped, action-name-allowlisted.
	document.addEventListener('click', function(e) {
		const trigger = e.target.closest('a[data-action]');
		if (!trigger) return;

		const action = trigger.dataset.action;
		if (action !== 'delete' && action !== 'set-default' && action !== 'duplicate') return;

		const id = parseInt(trigger.dataset.id || '0', 10);
		const name = trigger.dataset.name || '';
		if (!id) return;
		e.preventDefault();

		if (action === 'delete') {
			if (!confirm(T.deleteConfirm.replace('{name}', name))) return;
			Craft.sendActionRequest('POST', 'search-manager/widgets/delete', {
				data: { configId: id },
			}).then(function(response) {
				if (response.data.success) {
					Craft.cp.displayNotice(T.deleted);
					setTimeout(function() { window.location.reload(); }, 1000);
				} else {
					Craft.cp.displayError(response.data.error || T.deleteFailed);
				}
			}).catch(function() {
				Craft.cp.displayError(T.deleteFailed);
			});
		} else if (action === 'set-default') {
			Craft.sendActionRequest('POST', 'search-manager/widgets/set-default', {
				data: { configId: id },
			}).then(function(response) {
				if (response.data.success) {
					Craft.cp.displayNotice(T.defaultUpdated);
					setTimeout(function() { window.location.reload(); }, 1000);
				} else {
					Craft.cp.displayError(response.data.error || T.defaultUpdateFailed);
				}
			}).catch(function() {
				Craft.cp.displayError(T.defaultUpdateFailed);
			});
		} else if (action === 'duplicate') {
			Craft.sendActionRequest('POST', 'search-manager/widgets/duplicate', {
				data: { configId: id },
			}).then(function(response) {
				Craft.cp.displayNotice(response.data.message || T.duplicated);
				setTimeout(function() { window.location.reload(); }, 500);
			}).catch(function(response) {
				Craft.cp.displayError(response?.response?.data?.error || T.duplicateFailed);
			});
		}
	});

	function runBulk(endpoint, successTemplate, errorFallback) {
		const ids = selectedIds();
		if (!ids.length) return;
		Craft.sendActionRequest('POST', endpoint, {
			data: { configIds: ids },
		}).then(function(response) {
			if (response.data.success === false) {
				if (Array.isArray(response.data.errors)) {
					response.data.errors.forEach(function(err) { Craft.cp.displayError(err); });
				} else {
					Craft.cp.displayError(response.data.error || errorFallback);
				}
				return;
			}

			const count = response.data.count || 0;
			if (count > 0) {
				Craft.cp.displayNotice(successTemplate.replace('{count}', count));
				setTimeout(function() { window.location.reload(); }, 1000);
				return;
			}

			Craft.cp.displayError(response.data.error || errorFallback);
		}).catch(function() {
			Craft.cp.displayError(errorFallback);
		});
	}

	document.getElementById('lr-bulk-enable-action')?.addEventListener('click', function(e) {
		e.preventDefault();
		runBulk('search-manager/widgets/bulk-enable', T.bulkEnabledTemplate, T.bulkEnableFailed);
	});

	document.getElementById('lr-bulk-disable-action')?.addEventListener('click', function(e) {
		e.preventDefault();
		runBulk('search-manager/widgets/bulk-disable', T.bulkDisabledTemplate, T.bulkDisableFailed);
	});

	document.getElementById('lr-bulk-delete-btn')?.addEventListener('click', function() {
		const ids = selectedIds();
		if (!ids.length) return;
		const confirmTemplate = ids.length === 1 ? T.bulkDeleteConfirmSingular : T.bulkDeleteConfirmPlural;
		if (!confirm(confirmTemplate.replace('{count}', ids.length))) return;
		runBulk('search-manager/widgets/bulk-delete', T.bulkDeletedTemplate, T.bulkDeleteFailed);
	});

	const collisionHandles = {{ collisionHandles is defined ? collisionHandles|json_encode|raw : '[]' }};
	if (collisionHandles.length > 0) {
		document.querySelectorAll('#lr-data-table tbody tr.lr-data-row').forEach(function(row) {
			const handleCell = row.querySelector('td[data-column="handle"] code');
			if (handleCell && collisionHandles.includes(handleCell.textContent.trim())) {
				row.classList.add('lr-row--warning');
			}
		});
	}
})();
</script>
{% endblock %}
