{% import "_includes/forms" as forms %}

{{ forms.textField({
	label: 'Results Limit'|t('search-manager'),
	instructions: 'Maximum number of results to display'|t('search-manager'),
	tip: 'Min: 1, Max: 100. Default: 10'|t('search-manager'),
	id: 'behavior-resultsLimit',
	name: 'settings[behavior][resultsLimit]',
	value: widgetConfig.getResultsLimit(),
	type: 'number',
	min: 1,
	max: 100,
	errors: widgetConfig.getErrors('settings.behavior.resultsLimit')
}) }}

{{ forms.lightswitchField({
	label: 'Results Require URL'|t('search-manager'),
	instructions: 'Hide search results that do not have a URL (e.g., entries without landing pages)'|t('search-manager'),
	id: 'behavior-resultsRequireUrl',
	name: 'settings[behavior][resultsRequireUrl]',
	on: widgetConfig.isResultsRequireUrlEnabled(),
}) }}

<hr>

{{ forms.selectField({
	label: 'Results Layout'|t('search-manager'),
	instructions: 'How results are displayed. Hierarchical can group split section hits back under their page.'|t('search-manager'),
	id: 'behavior-resultsLayout',
	name: 'settings[behavior][resultsLayout]',
	value: widgetConfig.getResultsLayout(),
	options: [
		{value: 'default', label: 'Default'|t('search-manager')},
		{value: 'hierarchical', label: 'Hierarchical'|t('search-manager')},
	],
	toggle: true,
	targetPrefix: 'result-layout-',
	errors: widgetConfig.getErrors('settings.behavior.resultsLayout')
}) }}

<div id="result-layout-default"{% if widgetConfig.getResultsLayout() != 'default' %} class="hidden"{% endif %}>
	{{ forms.lightswitchField({
		label: 'Results Grouping Enabled'|t('search-manager'),
		instructions: 'Group flat results by source, Entry section, or type.'|t('search-manager'),
		id: 'behavior-resultsGroupingEnabled',
		name: 'settings[behavior][resultsGroupingEnabled]',
		on: widgetConfig.isResultsGroupingEnabled(),
	}) }}
</div>

<div id="result-layout-hierarchical"{% if widgetConfig.getResultsLayout() != 'hierarchical' %} class="hidden"{% endif %}>
	{% include "search-manager/widgets/_partials/hierarchy" with {
		widgetConfig: widgetConfig,
	} %}
</div>

<hr>

{# Line Clamping #}
<h2>{{ "Line Clamping"|t('search-manager') }}</h2>

{{ forms.textField({
	label: 'Results Title Lines'|t('search-manager'),
	instructions: 'Maximum lines for result titles before truncating'|t('search-manager'),
	tip: 'Min: 1, Max: 5. Default: 1. Use 2-3 for longer titles.'|t('search-manager'),
	id: 'behavior-resultsTitleLines',
	name: 'settings[behavior][resultsTitleLines]',
	value: widgetConfig.getResultsTitleLines(),
	type: 'number',
	min: 1,
	max: 5,
	errors: widgetConfig.getErrors('settings.behavior.resultsTitleLines')
}) }}

{{ forms.textField({
	label: 'Results Description Lines'|t('search-manager'),
	instructions: 'Maximum lines for result descriptions before truncating'|t('search-manager'),
	tip: 'Min: 1, Max: 5. Default: 1. Use 2-3 for richer previews.'|t('search-manager'),
	id: 'behavior-resultsDescriptionLines',
	name: 'settings[behavior][resultsDescriptionLines]',
	value: widgetConfig.getResultsDescriptionLines(),
	type: 'number',
	min: 1,
	max: 5,
	errors: widgetConfig.getErrors('settings.behavior.resultsDescriptionLines')
}) }}
