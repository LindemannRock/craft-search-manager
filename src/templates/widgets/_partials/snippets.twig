{% import "_includes/forms" as forms %}

{{ forms.lightswitchField({
	label: 'Show Code Snippets'|t('search-manager'),
	instructions: 'Allow snippets to use block-level code from page and section bodies.'|t('search-manager'),
	id: 'behavior-showCodeSnippets',
	name: 'settings[behavior][showCodeSnippets]',
	on: widgetConfig.isShowCodeSnippetsEnabled(),
}) }}

{{ forms.selectField({
	label: 'Snippet Mode'|t('search-manager'),
	instructions: 'How snippets choose a passage from eligible fields, page bodies, or split section bodies.'|t('search-manager'),
	tip: 'Default: balanced. Use "early" for leading previews, "deep" for long documentation.'|t('search-manager'),
	id: 'behavior-snippetMode',
	name: 'settings[behavior][snippetMode]',
	value: widgetConfig.getSnippetMode(),
	options: [
		{value: 'early', label: 'Early'|t('search-manager')},
		{value: 'balanced', label: 'Balanced'|t('search-manager')},
		{value: 'deep', label: 'Deep'|t('search-manager')},
	],
	errors: widgetConfig.getErrors('settings.behavior.snippetMode')
}) }}

{{ forms.textField({
	label: 'Snippet Length'|t('search-manager'),
	instructions: 'Maximum character length for page and section snippets'|t('search-manager'),
	tip: 'Min: 50, Max: 1000 characters. Default: 150. Longer snippets show more context but use more space.'|t('search-manager'),
	id: 'behavior-snippetLength',
	name: 'settings[behavior][snippetLength]',
	value: widgetConfig.getSnippetLength(),
	type: 'number',
	min: snippetOptions.minSnippetLength,
	max: snippetOptions.maxSnippetLength,
	errors: widgetConfig.getErrors('settings.behavior.snippetLength')
}) }}

{{ forms.lightswitchField({
	label: 'Parse Markdown Snippets'|t('search-manager'),
	instructions: 'Clean Markdown markers from page and section snippet display text.'|t('search-manager'),
	tip: 'Enable for Markdown-heavy content, such as documentation pages. This does not change indexed content.'|t('search-manager'),
	id: 'behavior-parseMarkdownSnippets',
	name: 'settings[behavior][parseMarkdownSnippets]',
	on: widgetConfig.isParseMarkdownSnippetsEnabled(),
}) }}
