{% import "_includes/forms" as forms %}

{{ forms.textField({
	first: true,
	label: "Name"|t('search-manager'),
	instructions: "Human-readable name for this configuration"|t('search-manager'),
	id: 'name',
	name: 'name',
	value: widgetConfig.name,
	required: true,
	autofocus: isNew,
	errors: widgetConfig.getErrors('name')
}) }}

{{ forms.textField({
	label: "Handle"|t('search-manager'),
	instructions: "Unique identifier used in templates (e.g., `configHandle: 'homepage'`)"|t('search-manager'),
	id: 'handle',
	name: 'handle',
	value: widgetConfig.handle,
	required: true,
	errors: widgetConfig.getErrors('handle')
}) }}

<hr>

{% set selectedIndexHandles = widgetConfig.getIndexHandles() %}
{% set availableIndices = (selectedApiKey and not selectedApiKey.allowsAllIndices())
	? indices|filter(index => selectedApiKey.allowsIndex(index.handle))
	: indices %}
{% set allIndexOptions = [] %}
{% set indexOptions = [] %}
{% for index in indices %}
	{% set option = {
		label: index.name ~ ' (' ~ index.handle ~ ')',
		value: index.handle
	} %}
	{% set allIndexOptions = allIndexOptions|merge([option]) %}
	{% if index in availableIndices %}
		{% set indexOptions = indexOptions|merge([option]) %}
	{% endif %}
{% endfor %}

{{ forms.selectField({
	label: 'API Key'|t('search-manager'),
	instructions: 'Select a public API key for this widget. Only the key name and prefix are shown; the full key is never displayed in the control panel. A render-time `apiKey` override still takes precedence.'|t('search-manager'),
	id: 'settings-apiKeyHandle',
	name: 'settings[apiKeyHandle]',
	value: widgetConfig.getApiKeyHandle(),
	options: widgetApiKeyOptions,
	errors: widgetConfig.getErrors('settings.apiKeyHandle'),
}) }}

{% if not hasWidgetUsableApiKeys %}
	{% include 'lindemannrock-base/_components/info-box' with {
		type: 'warning',
		message: 'No widget-usable public API keys are available. Create a new public key to use the selector.'|t('search-manager'),
		margin: 'bottom',
	} only %}
{% endif %}

{% if selectedApiKey and not selectedApiKey.allowsAllIndices() %}
	{% include 'lindemannrock-base/_components/info-box' with {
		type: 'info',
		message: 'The selected public key limits which indices this widget can search. Leave Search Indices empty to use the key’s allowed indices. Select indices only to narrow this widget further.'|t('search-manager'),
		margin: 'bottom',
	} only %}
{% endif %}

{{ forms.checkboxSelectField({
	label: 'Search Indices'|t('search-manager'),
	instructions: selectedApiKey and not selectedApiKey.allowsAllIndices()
		? 'Leave unchecked to use the selected API key’s allowed indices. Select indices only to narrow this widget further.'|t('search-manager')
		: 'Select which indices this widget searches. Leave all unchecked to search all indices.'|t('search-manager'),
	id: 'search-indexHandles',
	name: 'settings[search][indexHandles]',
	values: selectedIndexHandles,
	options: indexOptions,
	containerAttributes: {
		data: {
			inputName: 'settings[search][indexHandles]',
		},
	},
	errors: widgetConfig.getErrors('settings.search.indexHandles'),
}) }}

<script id="search-manager-widget-index-options" type="application/json">{{ allIndexOptions|json_encode|raw }}</script>
<script id="search-manager-widget-api-key-scopes" type="application/json">{{ widgetApiKeyScopes|json_encode|raw }}</script>
