{% import "_includes/forms" as forms %}

{% set styles = widgetConfig.getStylesForPreview() %}
{% set defaultStyles = widgetConfig.defaultStyleValues() %}

{% set styleMap = {} %}
{% set styleSources = {} %}
{% for style in widgetStyles %}
	{% set merged = defaultStyles|merge(style.getStyles()) %}
	{% set styleMap = styleMap|merge({ (style.handle): merged }) %}
	{% set styleSources = styleSources|merge({ (style.handle): style.source }) %}
{% endfor %}

<p class="light">{{ "Customize the visual appearance of the search widget. Colors support hex values."|t('search-manager') }}</p>

{# ========================================
   STYLE PRESET
   ======================================== #}
<h2>{{ "Style Preset"|t('search-manager') }}</h2>
<p class="light">{{ "Select a reusable style preset or create a new one from the current appearance."|t('search-manager') }}</p>

{% set selectedStyleHandle = widgetConfig.styleHandle ?? '' %}
{% set styleOptions = [
	{ value: '', label: 'Inline (this widget only)'|t('search-manager') },
	{ value: '__new__', label: 'Create new style…'|t('search-manager') }
] %}

{% for style in widgetStyles %}
	{% set styleOptions = styleOptions|merge([{
		value: style.handle,
		label: style.name ~ ' (' ~ style.handle ~ ')'
	}]) %}
{% endfor %}

{{ forms.selectField({
	label: 'Style Preset'|t('search-manager'),
	id: 'stylePreset',
	name: 'styleHandle',
	value: selectedStyleHandle,
	options: styleOptions,
}) }}

<input type="hidden" id="editStylePreset" name="editStylePreset" value="0">

<div id="new-style-fields" style="display: none; margin-top: 12px;">
	<div class="flex" style="gap: 24px; flex-wrap: wrap;">
		{{ forms.textField({
			label: 'New Style Name'|t('search-manager'),
			id: 'newStyleName',
			name: 'newStyleName',
			value: '',
			placeholder: 'Docs Dark',
		}) }}
		{{ forms.textField({
			label: 'New Style Handle'|t('search-manager'),
			id: 'newStyleHandle',
			name: 'newStyleHandle',
			value: '',
			placeholder: 'docs-dark',
		}) }}
	</div>
	<p class="light" style="margin-top: 6px;">{{ "A new style preset will be created from the current appearance values."|t('search-manager') }}</p>
</div>

<div class="flex" style="gap: 8px; align-items: center; margin-top: 10px;">
	<button type="button" class="btn" id="edit-style-preset">{{ "Edit Preset"|t('search-manager') }}</button>
	<button type="button" class="btn" id="cancel-style-edit" style="display: none;">{{ "Cancel Edit"|t('search-manager') }}</button>
	<span class="light" id="style-edit-note" style="display: none;">{{ "Editing preset styles will affect all widgets using this preset."|t('search-manager') }}</span>
</div>

<hr>

{# ========================================
   COLOR SCHEME MODE TOGGLE
   ======================================== #}
<div class="btngroup" id="color-scheme-toggle" style="margin-bottom: 24px;">
	<button type="button" class="btn secondary" data-color-scheme="light" aria-pressed="true">
		<span class="icon">{{ svg('@app/icons/sun.svg')|attr({ class: 'icon-sun' }) }}</span>
		{{ "Light Mode"|t('search-manager') }}
	</button>
	<button type="button" class="btn" data-color-scheme="dark" aria-pressed="false">
		<span class="icon">{{ svg('@app/icons/moon.svg')|attr({ class: 'icon-moon' }) }}</span>
		{{ "Dark Mode"|t('search-manager') }}
	</button>
</div>

<style>
	.appearance-fields { display: none; }
	.appearance-fields.is-visible { display: block; }
</style>

<div id="appearance-fields" class="appearance-fields"
	data-style-map="{{ styleMap|json_encode|e('html_attr') }}"
	data-style-sources="{{ styleSources|json_encode|e('html_attr') }}"
	data-default-styles="{{ defaultStyles|json_encode|e('html_attr') }}"
>

{# Shared style fields (Modal, Input, Results, Spinner, Trigger, Keyboard Badge) #}
{% include "search-manager/widgets/_shared/style-fields" with {
	namePrefix: 'settings[styles]',
	styles: styles,
} only %}

<hr>

{# ========================================
   SEARCH HIGHLIGHTING (widget-specific)
   ======================================== #}
<h2>{{ "Search Highlighting"|t('search-manager') }}</h2>
<p class="light">{{ "Colors for highlighted matching terms in search results."|t('search-manager') }}</p>

{# Light Mode Colors #}
<div class="color-scheme-section" data-color-scheme="light">
	<div class="flex" style="gap: 24px; flex-wrap: wrap;">
		{{ forms.colorField({
			label: 'Background'|t('search-manager'),
			id: 'highlighting-bgLight',
			name: 'settings[highlighting][bgLight]',
			value: widgetConfig.getHighlightBgLight(),
		}) }}
		{{ forms.colorField({
			label: 'Text'|t('search-manager'),
			id: 'highlighting-colorLight',
			name: 'settings[highlighting][colorLight]',
			value: widgetConfig.getHighlightColorLight(),
		}) }}
	</div>
</div>

{# Dark Mode Colors #}
<div class="color-scheme-section hidden" data-color-scheme="dark">
	<div class="flex" style="gap: 24px; flex-wrap: wrap;">
		{{ forms.colorField({
			label: 'Background'|t('search-manager'),
			id: 'highlighting-bgDark',
			name: 'settings[highlighting][bgDark]',
			value: widgetConfig.getHighlightBgDark(),
		}) }}
		{{ forms.colorField({
			label: 'Text'|t('search-manager'),
			id: 'highlighting-colorDark',
			name: 'settings[highlighting][colorDark]',
			value: widgetConfig.getHighlightColorDark(),
		}) }}
	</div>
</div>

</div>{# /appearance-fields #}
