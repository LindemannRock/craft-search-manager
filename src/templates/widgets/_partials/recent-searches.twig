{% import "_includes/forms" as forms %}

{{ forms.lightswitchField({
	label: 'Enable Recent Searches'|t('search-manager'),
	instructions: 'Show recently searched terms when the modal opens'|t('search-manager'),
	id: 'behavior-recentSearchesEnabled',
	name: 'settings[behavior][recentSearchesEnabled]',
	on: widgetConfig.isRecentSearchesEnabled(),
	toggle: 'recent-searches-limit-field',
}) }}

<div id="recent-searches-limit-field"{% if not widgetConfig.isRecentSearchesEnabled() and not widgetConfig.getErrors('settings.behavior.recentSearchesLimit') %} class="hidden"{% endif %}>
	{{ forms.textField({
		label: 'Recent Searches Limit'|t('search-manager'),
		instructions: 'Maximum number of recent searches to store and display'|t('search-manager'),
		tip: 'Min: 1, Max: 50. Default: 5'|t('search-manager'),
		id: 'behavior-recentSearchesLimit',
		name: 'settings[behavior][recentSearchesLimit]',
		value: widgetConfig.getRecentSearchesLimit(),
		type: 'number',
		min: 1,
		max: 50,
		errors: widgetConfig.getErrors('settings.behavior.recentSearchesLimit')
	}) }}
</div>
