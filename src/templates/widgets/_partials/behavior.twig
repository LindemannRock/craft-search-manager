{% import "_includes/forms" as forms %}

{# Behavior Settings #}
<h2>{{ "Behavior Settings"|t('search-manager') }}</h2>

{{ forms.lightswitchField({
	label: 'Prevent Body Scroll'|t('search-manager'),
	instructions: 'Prevent the page from scrolling when the search modal is open'|t('search-manager'),
	id: 'behavior-preventBodyScroll',
	name: 'settings[behavior][preventBodyScroll]',
	on: widgetConfig.isPreventBodyScrollEnabled(),
}) }}

{{ forms.textField({
	label: 'Debounce'|t('search-manager'),
	instructions: 'Delay in milliseconds before search triggers after typing'|t('search-manager'),
	tip: 'Min: 0 (instant), Max: 2000 (2 seconds). Default: 200ms'|t('search-manager'),
	id: 'behavior-debounce',
	name: 'settings[behavior][debounce]',
	value: widgetConfig.getDebounce(),
	type: 'number',
	min: 0,
	max: 2000,
	errors: widgetConfig.getErrors('settings.behavior.debounce')
}) }}

{{ forms.textField({
	label: 'Minimum Characters'|t('search-manager'),
	instructions: 'Minimum characters before search begins'|t('search-manager'),
	tip: 'Min: 1, Max: 10. Default: 2'|t('search-manager'),
	id: 'behavior-minChars',
	name: 'settings[behavior][minChars]',
	value: widgetConfig.getMinChars(),
	type: 'number',
	min: 1,
	max: 10,
	errors: widgetConfig.getErrors('settings.behavior.minChars')
}) }}

{{ forms.textField({
	label: 'Maximum Results'|t('search-manager'),
	instructions: 'Maximum number of results to display'|t('search-manager'),
	tip: 'Min: 1, Max: 100. Default: 10'|t('search-manager'),
	id: 'behavior-maxResults',
	name: 'settings[behavior][maxResults]',
	value: widgetConfig.getMaxResults(),
	type: 'number',
	min: 1,
	max: 100,
	errors: widgetConfig.getErrors('settings.behavior.maxResults')
}) }}

{{ forms.lightswitchField({
	label: 'Show Recent Searches'|t('search-manager'),
	instructions: 'Show recently searched terms when the modal opens'|t('search-manager'),
	id: 'behavior-showRecent',
	name: 'settings[behavior][showRecent]',
	on: widgetConfig.isShowRecentEnabled(),
	toggle: 'max-recent-searches-field',
}) }}

<div id="max-recent-searches-field"{% if not widgetConfig.isShowRecentEnabled() %} class="hidden"{% endif %}>
	{{ forms.textField({
		label: 'Max Recent Searches'|t('search-manager'),
		instructions: 'Maximum number of recent searches to store and display'|t('search-manager'),
		tip: 'Min: 1, Max: 50. Default: 5'|t('search-manager'),
		id: 'behavior-maxRecentSearches',
		name: 'settings[behavior][maxRecentSearches]',
		value: widgetConfig.getMaxRecentSearches(),
		type: 'number',
		min: 1,
		max: 50,
		errors: widgetConfig.getErrors('settings.behavior.maxRecentSearches')
	}) }}
</div>

{{ forms.lightswitchField({
	label: 'Group Results'|t('search-manager'),
	instructions: 'Group search results by type/section'|t('search-manager'),
	id: 'behavior-groupResults',
	name: 'settings[behavior][groupResults]',
	on: widgetConfig.isGroupResultsEnabled(),
}) }}

{{ forms.textField({
	label: 'Hotkey'|t('search-manager'),
	instructions: 'Keyboard shortcut key (used with Cmd/Ctrl, e.g., "k" for Cmd+K)'|t('search-manager'),
	tip: 'Single character. Default: k (Cmd+K / Ctrl+K)'|t('search-manager'),
	id: 'behavior-hotkey',
	name: 'settings[behavior][hotkey]',
	value: widgetConfig.getHotkey(),
	size: 1,
	maxlength: 1,
	errors: widgetConfig.getErrors('settings.behavior.hotkey')
}) }}

{{ forms.lightswitchField({
	label: 'Hide Results Without URL'|t('search-manager'),
	instructions: 'Hide search results that do not have a URL (e.g., entries without landing pages)'|t('search-manager'),
	id: 'behavior-hideResultsWithoutUrl',
	name: 'settings[behavior][hideResultsWithoutUrl]',
	on: widgetConfig.isHideResultsWithoutUrlEnabled(),
}) }}

{{ forms.lightswitchField({
	label: 'Show Loading Indicator'|t('search-manager'),
	instructions: 'Display a spinner while search results are loading'|t('search-manager'),
	id: 'behavior-showLoadingIndicator',
	name: 'settings[behavior][showLoadingIndicator]',
	on: widgetConfig.isShowLoadingIndicatorEnabled(),
}) }}

<hr>

{# Result Display Settings #}
<h2>{{ "Result Display"|t('search-manager') }}</h2>

{{ forms.selectField({
	label: 'Result Layout'|t('search-manager'),
	instructions: 'How results are displayed. Hierarchical groups results with heading children (Algolia DocSearch style).'|t('search-manager'),
	id: 'behavior-resultLayout',
	name: 'settings[behavior][resultLayout]',
	value: widgetConfig.getResultLayout(),
	options: [
		{value: 'default', label: 'Default'|t('search-manager')},
		{value: 'hierarchical', label: 'Hierarchical'|t('search-manager')},
	],
	toggle: true,
	targetPrefix: 'result-layout-',
	errors: widgetConfig.getErrors('settings.behavior.resultLayout')
}) }}

<div id="result-layout-hierarchical"{% if widgetConfig.getResultLayout() != 'hierarchical' %} class="hidden"{% endif %}>
	{{ forms.selectField({
		label: 'Hierarchy Display'|t('search-manager'),
		instructions: 'Individual shows each result as its own card. Unified wraps each page and its headings in a single card (Starlight-style).'|t('search-manager'),
		id: 'behavior-hierarchyDisplay',
		name: 'settings[behavior][hierarchyDisplay]',
		value: widgetConfig.getHierarchyDisplay(),
		options: [
			{value: 'individual', label: 'Individual'|t('search-manager')},
			{value: 'unified', label: 'Unified'|t('search-manager')},
		],
		errors: widgetConfig.getErrors('settings.behavior.hierarchyDisplay')
	}) }}

	{{ forms.textField({
		label: 'Max Headings per Result'|t('search-manager'),
		instructions: 'Maximum number of heading children to display per result'|t('search-manager'),
		tip: 'Min: 1, Max: 50. Default: 3. Set higher to show more heading anchors per document.'|t('search-manager'),
		id: 'behavior-maxHeadingsPerResult',
		name: 'settings[behavior][maxHeadingsPerResult]',
		value: widgetConfig.getMaxHeadingsPerResult(),
		type: 'number',
		min: 1,
		max: 50,
		errors: widgetConfig.getErrors('settings.behavior.maxHeadingsPerResult')
	}) }}

	{{ forms.textField({
		label: 'Group By Field'|t('search-manager'),
		instructions: 'Document field to group hierarchical results by (e.g., "section", "category"). Leave empty for default "section".'|t('search-manager'),
		tip: 'Max: 64 characters. Must match a field name in your indexed documents.'|t('search-manager'),
		id: 'behavior-hierarchyGroupBy',
		name: 'settings[behavior][hierarchyGroupBy]',
		value: widgetConfig.getHierarchyGroupBy(),
		placeholder: 'section',
		errors: widgetConfig.getErrors('settings.behavior.hierarchyGroupBy')
	}) }}
</div>

{{ forms.textField({
	label: 'Result Title Lines'|t('search-manager'),
	instructions: 'Maximum lines for result titles before truncating'|t('search-manager'),
	tip: 'Min: 1, Max: 5. Default: 1. Use 2-3 for longer titles.'|t('search-manager'),
	id: 'behavior-resultTitleLines',
	name: 'settings[behavior][resultTitleLines]',
	value: widgetConfig.getResultTitleLines(),
	type: 'number',
	min: 1,
	max: 5,
	errors: widgetConfig.getErrors('settings.behavior.resultTitleLines')
}) }}

{{ forms.textField({
	label: 'Result Description Lines'|t('search-manager'),
	instructions: 'Maximum lines for result descriptions before truncating'|t('search-manager'),
	tip: 'Min: 1, Max: 5. Default: 1. Use 2-3 for richer previews.'|t('search-manager'),
	id: 'behavior-resultDescLines',
	name: 'settings[behavior][resultDescLines]',
	value: widgetConfig.getResultDescLines(),
	type: 'number',
	min: 1,
	max: 5,
	errors: widgetConfig.getErrors('settings.behavior.resultDescLines')
}) }}

<hr>

{# Snippet Settings #}
<h2>{{ "Snippets"|t('search-manager') }}</h2>

{{ forms.lightswitchField({
	label: 'Allow Code Snippets'|t('search-manager'),
	instructions: 'Allow code blocks in result descriptions'|t('search-manager'),
	id: 'behavior-allowCodeSnippets',
	name: 'settings[behavior][allowCodeSnippets]',
	on: widgetConfig.isAllowCodeSnippetsEnabled(),
}) }}

{{ forms.selectField({
	label: 'Snippet Mode'|t('search-manager'),
	instructions: 'How result description snippets are generated. "Early" shows the beginning, "balanced" centers on the match, "deep" shows the most relevant section.'|t('search-manager'),
	tip: 'Default: balanced. Use "early" for blog posts, "deep" for documentation.'|t('search-manager'),
	id: 'behavior-snippetMode',
	name: 'settings[behavior][snippetMode]',
	value: widgetConfig.getSnippetMode(),
	options: [
		{value: 'early', label: 'Early'|t('search-manager')},
		{value: 'balanced', label: 'Balanced'|t('search-manager')},
		{value: 'deep', label: 'Deep'|t('search-manager')},
	],
	errors: widgetConfig.getErrors('settings.behavior.snippetMode')
}) }}

{{ forms.textField({
	label: 'Snippet Length'|t('search-manager'),
	instructions: 'Maximum character length for result description snippets'|t('search-manager'),
	tip: 'Min: 50, Max: 500 characters. Default: 150. Longer snippets show more context but use more space.'|t('search-manager'),
	id: 'behavior-snippetLength',
	name: 'settings[behavior][snippetLength]',
	value: widgetConfig.getSnippetLength(),
	type: 'number',
	min: 50,
	max: 500,
	errors: widgetConfig.getErrors('settings.behavior.snippetLength')
}) }}

{{ forms.lightswitchField({
	label: 'Parse Markdown Snippets'|t('search-manager'),
	instructions: 'Parse markdown formatting before building description snippets'|t('search-manager'),
	tip: 'Enable when indexing markdown content (e.g., documentation pages) for cleaner snippet text.'|t('search-manager'),
	id: 'behavior-parseMarkdownSnippets',
	name: 'settings[behavior][parseMarkdownSnippets]',
	on: widgetConfig.isParseMarkdownSnippetsEnabled(),
}) }}

<hr>

{# Trigger Button Settings #}
<h2>{{ "Trigger Button Settings"|t('search-manager') }}</h2>

{{ forms.lightswitchField({
	label: 'Show Trigger Button'|t('search-manager'),
	instructions: 'Display a visible search button that opens the modal'|t('search-manager'),
	id: 'trigger-showTrigger',
	name: 'settings[trigger][showTrigger]',
	on: widgetConfig.isShowTriggerEnabled(),
	toggle: 'trigger-text-field',
}) }}

<div id="trigger-text-field"{% if not widgetConfig.isShowTriggerEnabled() %} class="hidden"{% endif %}>
	{{ forms.textField({
		label: 'Trigger Text'|t('search-manager'),
		instructions: 'Text displayed on the trigger button'|t('search-manager'),
		tip: 'Max: 255 characters. Default: "Search"'|t('search-manager'),
		id: 'trigger-triggerText',
		name: 'settings[trigger][triggerText]',
		value: widgetConfig.getTriggerText(),
		errors: widgetConfig.getErrors('settings.trigger.triggerText')
	}) }}
</div>

<hr>

{# Analytics Settings #}
<h2>{{ "Analytics Settings"|t('search-manager') }}</h2>

{{ forms.textField({
	label: 'Source Identifier'|t('search-manager'),
	instructions: 'Custom identifier for this widget in analytics (e.g., "header-search", "mobile-nav"). Leave empty for default.'|t('search-manager'),
	tip: 'Max: 64 characters. Appears in analytics to distinguish traffic from different widget placements.'|t('search-manager'),
	id: 'analytics-source',
	name: 'settings[analytics][source]',
	value: widgetConfig.getAnalyticsSource(),
	placeholder: 'frontend-widget',
	errors: widgetConfig.getErrors('settings.analytics.source')
}) }}

{{ forms.textField({
	label: 'Idle Timeout'|t('search-manager'),
	instructions: 'Track search after user stops typing for this duration (milliseconds). Set to 0 to disable idle tracking.'|t('search-manager'),
	tip: 'Min: 0 (disabled), Max: 10000 (10 seconds). Default: 1500 (1.5 seconds)'|t('search-manager'),
	id: 'analytics-idleTimeout',
	name: 'settings[analytics][idleTimeout]',
	value: widgetConfig.getIdleTimeout(),
	type: 'number',
	min: 0,
	max: 10000,
	errors: widgetConfig.getErrors('settings.analytics.idleTimeout')
}) }}
