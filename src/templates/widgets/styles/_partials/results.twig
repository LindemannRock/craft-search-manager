		</div>

		<div>
			<h3>{{ "Active / Hover"|t('search-manager') }}</h3>
			<div class="flex" style="gap: 24px; flex-wrap: wrap;">
				{{ forms.colorField({
					label: 'Background'|t('search-manager'),
