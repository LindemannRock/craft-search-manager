		label: 'Gap (px)'|t('search-manager'),
		id: 'styles-resultGap',
		name: namePrefix ~ '[resultGap]',
		value: styles.resultGap,
		type: 'number',
		min: 0,
		max: 20,
		size: 10,
		tip: 'Min: 0, Max: 20. Default: 8. Space between result items.'|t('search-manager'),
		errors: widgetStyle is defined and widgetStyle ? widgetStyle.getErrors('styles.resultGap') : [],
	}) }}
	{{ forms.textField({
		label: 'Border Radius (px)'|t('search-manager'),
		id: 'styles-resultBorderRadius',
		name: namePrefix ~ '[resultBorderRadius]',
		value: styles.resultBorderRadius,
		type: 'number',
		min: 0,
		max: 20,
		size: 10,
		tip: 'Min: 0, Max: 20. Default: 8'|t('search-manager'),
		errors: widgetStyle is defined and widgetStyle ? widgetStyle.getErrors('styles.resultBorderRadius') : [],
