		</div>
	</div>
</div>

{# Shared Dimensions #}
<div style="margin-top: 24px;">
	<h4>{{ "Dimensions"|t('search-manager') }}</h4>
	{{ forms.textField({
		label: 'Gap (px)'|t('search-manager'),
		id: 'styles-resultGap',
		name: namePrefix ~ '[resultGap]',
		value: styles.resultGap,
		type: 'number',
		min: 0,
		max: 20,
		size: 10,
		tip: 'Min: 0, Max: 20. Default: 8. Space between result items.'|t('search-manager'),
		errors: widgetStyle is defined and widgetStyle ? widgetStyle.getErrors('styles.resultGap') : [],
	}) }}
	{{ forms.textField({
		label: 'Border Radius (px)'|t('search-manager'),
		id: 'styles-resultBorderRadius',
		name: namePrefix ~ '[resultBorderRadius]',
		value: styles.resultBorderRadius,
		type: 'number',
		min: 0,
		max: 20,
		size: 10,
		tip: 'Min: 0, Max: 20. Default: 8'|t('search-manager'),
		errors: widgetStyle is defined and widgetStyle ? widgetStyle.getErrors('styles.resultBorderRadius') : [],
	}) }}
	{{ forms.textField({
		label: 'Border Width (px)'|t('search-manager'),
		id: 'styles-resultBorderWidth',
		name: namePrefix ~ '[resultBorderWidth]',
		value: styles.resultBorderWidth,
		type: 'number',
		min: 0,
		max: 10,
		size: 10,
		tip: 'Min: 0, Max: 10. Default: 0. Set to 0 to remove border.'|t('search-manager'),
		errors: widgetStyle is defined and widgetStyle ? widgetStyle.getErrors('styles.resultBorderWidth') : [],
	}) }}
	{{ forms.textField({
		label: 'Padding X (px)'|t('search-manager'),
		id: 'styles-resultPaddingX',
		name: namePrefix ~ '[resultPaddingX]',
		value: styles.resultPaddingX,
		type: 'number',
		min: 0,
		max: 32,
		size: 10,
		tip: 'Min: 0, Max: 32. Default: 12'|t('search-manager'),
		errors: widgetStyle is defined and widgetStyle ? widgetStyle.getErrors('styles.resultPaddingX') : [],
	}) }}
	{{ forms.textField({
		label: 'Padding Y (px)'|t('search-manager'),
		id: 'styles-resultPaddingY',
		name: namePrefix ~ '[resultPaddingY]',
		value: styles.resultPaddingY,
		type: 'number',
		min: 0,
		max: 32,
		size: 10,
		tip: 'Min: 0, Max: 32. Default: 12'|t('search-manager'),
		errors: widgetStyle is defined and widgetStyle ? widgetStyle.getErrors('styles.resultPaddingY') : [],
	}) }}
</div>
