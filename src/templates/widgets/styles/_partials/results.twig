{% import "_includes/forms" as forms %}

<div class="color-scheme-toggle btngroup" style="margin-bottom: 14px;">
	<button type="button" class="btn secondary" data-color-scheme="light" aria-pressed="true">{{ "Light"|t('search-manager') }}</button>
	<button type="button" class="btn" data-color-scheme="dark" aria-pressed="false">{{ "Dark"|t('search-manager') }}</button>
</div>

{# ========================================
   SEARCH RESULTS
   ======================================== #}
<h2>{{ "Search Results"|t('search-manager') }}</h2>

{# Light Mode Colors #}
<div class="color-scheme-section" data-color-scheme="light">
	<div style="display: grid; gap: 16px;">
		<div>
			<h4>{{ "Base"|t('search-manager') }}</h4>
			<div class="flex" style="gap: 24px; flex-wrap: wrap;">
				{{ forms.colorField({
					label: 'Background'|t('search-manager'),
					id: 'styles-resultBg',
					name: namePrefix ~ '[resultBg]',
					value: styles.resultBg,
				}) }}
				{{ forms.colorField({
					label: 'Border'|t('search-manager'),
					id: 'styles-resultBorderColor',
					name: namePrefix ~ '[resultBorderColor]',
					value: styles.resultBorderColor,
				}) }}
				{{ forms.colorField({
					label: 'Text'|t('search-manager'),
					id: 'styles-resultTextColor',
					name: namePrefix ~ '[resultTextColor]',
					value: styles.resultTextColor,
				}) }}
				{{ forms.colorField({
					label: 'Description'|t('search-manager'),
					id: 'styles-resultDescColor',
					name: namePrefix ~ '[resultDescColor]',
					value: styles.resultDescColor,
				}) }}
				{{ forms.colorField({
					label: 'Muted'|t('search-manager'),
					id: 'styles-resultMutedColor',
					name: namePrefix ~ '[resultMutedColor]',
					value: styles.resultMutedColor,
				}) }}
				{{ forms.colorField({
					label: 'Icons'|t('search-manager'),
					id: 'styles-iconColor',
					name: namePrefix ~ '[iconColor]',
					value: styles.iconColor,
				}) }}
			</div>
		</div>

		<div>
			<h4>{{ "Active"|t('search-manager') }}</h4>
			<div class="flex" style="gap: 24px; flex-wrap: wrap;">
				{{ forms.colorField({
					label: 'Background'|t('search-manager'),
					id: 'styles-resultActiveBg',
					name: namePrefix ~ '[resultActiveBg]',
					value: styles.resultActiveBg,
				}) }}
				{{ forms.colorField({
					label: 'Border'|t('search-manager'),
					id: 'styles-resultActiveBorderColor',
					name: namePrefix ~ '[resultActiveBorderColor]',
					value: styles.resultActiveBorderColor,
				}) }}
				{{ forms.colorField({
					label: 'Text'|t('search-manager'),
					id: 'styles-resultActiveTextColor',
					name: namePrefix ~ '[resultActiveTextColor]',
					value: styles.resultActiveTextColor,
				}) }}
				{{ forms.colorField({
					label: 'Description'|t('search-manager'),
					id: 'styles-resultActiveDescColor',
					name: namePrefix ~ '[resultActiveDescColor]',
					value: styles.resultActiveDescColor,
				}) }}
				{{ forms.colorField({
					label: 'Muted'|t('search-manager'),
					id: 'styles-resultActiveMutedColor',
					name: namePrefix ~ '[resultActiveMutedColor]',
					value: styles.resultActiveMutedColor,
				}) }}
			</div>
		</div>
	</div>
</div>

