		<div>
			<h3>{{ "Base"|t('search-manager') }}</h3>
			<div class="flex" style="gap: 24px; flex-wrap: wrap;">
				{{ forms.colorField({
					label: 'Background'|t('search-manager'),
					id: 'styles-resultBg',
					name: namePrefix ~ '[resultBg]',
					value: styles.resultBg,
				}) }}
				{{ forms.colorField({
					label: 'Border'|t('search-manager'),
					id: 'styles-resultBorderColor',
					name: namePrefix ~ '[resultBorderColor]',
					value: styles.resultBorderColor,
				}) }}
				{{ forms.colorField({
					label: 'Title'|t('search-manager'),
					id: 'styles-resultTextColor',
					name: namePrefix ~ '[resultTextColor]',
					value: styles.resultTextColor,
				}) }}
				{{ forms.colorField({
