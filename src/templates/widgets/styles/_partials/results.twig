{# ========================================
   RESULT HIGHLIGHTING
   ======================================== #}
<h2>{{ "Result Highlighting"|t('search-manager') }}</h2>
<p class="light">{{ "Configure how matching search terms are highlighted in results."|t('search-manager') }}</p>

{{ forms.lightswitchField({
	label: 'Result Highlighting Enabled'|t('search-manager'),
	instructions: 'Enable search term highlighting in results'|t('search-manager'),
	id: 'styles-highlightResultsEnabled',
	name: namePrefix ~ '[highlightResultsEnabled]',
	on: styles.highlightResultsEnabled is not same as(false) and styles.highlightResultsEnabled not in ['0', 0, 'false', 'off', 'no'],
	toggle: 'styles-highlighting-options',
}) }}

<div id="styles-highlighting-options"{% if styles.highlightResultsEnabled is same as(false) or styles.highlightResultsEnabled in ['0', 0, 'false', 'off', 'no'] %} class="hidden"{% endif %}>

	{% set highlightTagValue = styles.highlightTag ?? '' %}
	{{ forms.selectField({
		label: 'HTML Tag'|t('search-manager'),
		instructions: 'HTML tag to wrap highlighted terms. Each tag has different semantic meaning and default browser styling.'|t('search-manager'),
		id: 'styles-highlightTag',
		name: namePrefix ~ '[highlightTag]',
		value: highlightTagValue,
		options: [
			{value: '', label: 'Use global default'|t('search-manager')},
				{value: 'mark', label: '<mark> - Highlighted text (yellow background)'|t('search-manager')},
				{value: 'em', label: '<em> - Emphasized text (italic)'|t('search-manager')},
				{value: 'strong', label: '<strong> - Strong importance (bold)'|t('search-manager')},
				{value: 'span', label: '<span> - Generic container (no default style)'|t('search-manager')},
				{value: 'b', label: '<b> - Bold text'|t('search-manager')},
				{value: 'i', label: '<i> - Italic text'|t('search-manager')},
		],
		tip: 'Default: <mark> (from global highlighting settings)'|t('search-manager'),
	}) }}

	{{ forms.textField({
		label: 'CSS Class'|t('search-manager'),
		instructions: 'Optional CSS class for highlighted terms (leave empty for none)'|t('search-manager'),
		id: 'styles-highlightClass',
		name: namePrefix ~ '[highlightClass]',
		value: styles.highlightClass ?? '',
		placeholder: 'search-highlight',
		tip: 'Use for custom styling via CSS'|t('search-manager'),
	}) }}

	{# Light Mode Colors #}
	<div class="color-scheme-section" data-color-scheme="light">
		<div style="display: grid; gap: 16px;">
			<div>
				<h3>{{ "Base"|t('search-manager') }}</h3>
				<div class="flex" style="gap: 24px; flex-wrap: wrap;">
					{{ forms.colorField({
						label: 'Background'|t('search-manager'),
						id: 'styles-highlightBgLight',
						name: namePrefix ~ '[highlightBgLight]',
						value: styles.highlightBgLight,
					}) }}
					{{ forms.colorField({
						label: 'Text'|t('search-manager'),
						id: 'styles-highlightColorLight',
						name: namePrefix ~ '[highlightColorLight]',
						value: styles.highlightColorLight,
					}) }}
				</div>
			</div>
			<div>
				<h3>{{ "Active / Hover"|t('search-manager') }}</h3>
				<p class="light">{{ 'On the hovered/selected row. Leave empty to reuse the base highlight.'|t('search-manager') }}</p>
				<div class="flex" style="gap: 24px; flex-wrap: wrap;">
					{{ forms.colorField({
						label: 'Background'|t('search-manager'),
						id: 'styles-highlightActiveBgLight',
						name: namePrefix ~ '[highlightActiveBgLight]',
						value: styles.highlightActiveBgLight,
					}) }}
					{{ forms.colorField({
						label: 'Text'|t('search-manager'),
						id: 'styles-highlightActiveColorLight',
						name: namePrefix ~ '[highlightActiveColorLight]',
						value: styles.highlightActiveColorLight,
					}) }}
				</div>
			</div>
		</div>
	</div>

	{# Dark Mode Colors #}
	<div class="color-scheme-section hidden" data-color-scheme="dark">
		<div style="display: grid; gap: 16px;">
			<div>
				<h3>{{ "Base"|t('search-manager') }}</h3>
				<div class="flex" style="gap: 24px; flex-wrap: wrap;">
					{{ forms.colorField({
						label: 'Background'|t('search-manager'),
						id: 'styles-highlightBgDark',
						name: namePrefix ~ '[highlightBgDark]',
						value: styles.highlightBgDark,
					}) }}
					{{ forms.colorField({
						label: 'Text'|t('search-manager'),
						id: 'styles-highlightColorDark',
						name: namePrefix ~ '[highlightColorDark]',
						value: styles.highlightColorDark,
					}) }}
				</div>
			</div>
			<div>
				<h3>{{ "Active / Hover"|t('search-manager') }}</h3>
				<p class="light">{{ 'On the hovered/selected row. Leave empty to reuse the base highlight.'|t('search-manager') }}</p>
				<div class="flex" style="gap: 24px; flex-wrap: wrap;">
					{{ forms.colorField({
						label: 'Background'|t('search-manager'),
						id: 'styles-highlightActiveBgDark',
						name: namePrefix ~ '[highlightActiveBgDark]',
						value: styles.highlightActiveBgDark,
					}) }}
					{{ forms.colorField({
						label: 'Text'|t('search-manager'),
						id: 'styles-highlightActiveColorDark',
						name: namePrefix ~ '[highlightActiveColorDark]',
						value: styles.highlightActiveColorDark,
					}) }}
				</div>
			</div>
		</div>
	</div>

</div>

