<p class="light">{{ "Customize the visual appearance of this style preset. Colors support hex values."|t('search-manager') }}</p>

{# Color scheme toggle #}
<div class="btngroup" id="color-scheme-toggle" style="margin-bottom: 24px;">
	<button type="button" class="btn secondary" data-color-scheme="light" aria-pressed="true">
		<span class="icon">{{ svg('@app/icons/sun.svg')|attr({ class: 'icon-sun' }) }}</span>
		{{ "Light Mode"|t('search-manager') }}
	</button>
	<button type="button" class="btn" data-color-scheme="dark" aria-pressed="false">
		<span class="icon">{{ svg('@app/icons/moon.svg')|attr({ class: 'icon-moon' }) }}</span>
		{{ "Dark Mode"|t('search-manager') }}
	</button>
</div>

{% include "search-manager/widgets/_shared/style-fields" with {
	namePrefix: 'styles',
	styles: styles,
	widgetStyle: widgetStyle ?? null,
} only %}
