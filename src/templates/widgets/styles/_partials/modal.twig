{% import "_includes/forms" as forms %}

{% macro shadowComposer(id, name, value) %}
	{% import "_includes/forms" as forms %}
	<div class="field" data-shadow-composer data-shadow-input="{{ id }}">
		<div class="heading">
			<label>{{ 'Box Shadow'|t('search-manager') }}</label>
		</div>
		<input type="hidden" id="{{ id }}" name="{{ name }}" value="{{ value }}">
		<div data-shadow-parts class="flex" style="gap: 12px; flex-wrap: wrap; align-items: flex-end;">
			{{ forms.textField({
				label: 'Offset X (px)'|t('search-manager'),
				id: id ~ '-x',
				type: 'number',
				size: 6,
			}) }}
			{{ forms.textField({
				label: 'Offset Y (px)'|t('search-manager'),
				id: id ~ '-y',
				type: 'number',
				size: 6,
			}) }}
			{{ forms.textField({
				label: 'Blur (px)'|t('search-manager'),
				id: id ~ '-blur',
				type: 'number',
				min: 0,
				size: 6,
			}) }}
			{{ forms.textField({
				label: 'Spread (px)'|t('search-manager'),
				id: id ~ '-spread',
				type: 'number',
				size: 6,
			}) }}
			{{ forms.colorField({
				label: 'Color'|t('search-manager'),
				id: id ~ '-color',
			}) }}
			{{ forms.textField({
				label: 'Opacity (%)'|t('search-manager'),
				id: id ~ '-opacity',
				type: 'number',
				min: 0,
				max: 100,
				size: 6,
			}) }}
		</div>
		<div data-shadow-custom class="hidden" style="margin-top: 8px;">
			{{ forms.text({
				id: id ~ '-custom',
				placeholder: '0 25px 50px -12px rgba(0,0,0,0.25)',
			}) }}
		</div>
		<div style="margin-top: 6px;">
			<button type="button" class="btn small" data-shadow-toggle
				data-label-css="{{ 'Edit as CSS'|t('search-manager') }}"
				data-label-visual="{{ 'Edit visually'|t('search-manager') }}">{{ 'Edit as CSS'|t('search-manager') }}</button>
		</div>
	</div>
{% endmacro %}

<div class="color-scheme-toggle btngroup" style="margin-bottom: 14px;">
	<button type="button" class="btn secondary" data-color-scheme="light" aria-pressed="true">{{ "Light"|t('search-manager') }}</button>
	<button type="button" class="btn" data-color-scheme="dark" aria-pressed="false">{{ "Dark"|t('search-manager') }}</button>
</div>

{# ========================================
   MODAL
   ======================================== #}
<h2>{{ "Modal"|t('search-manager') }}</h2>

{# Light Mode Colors #}
<div class="color-scheme-section" data-color-scheme="light">
	<div class="flex" style="gap: 24px; flex-wrap: wrap;">
		{{ forms.colorField({
			label: 'Background'|t('search-manager'),
			id: 'styles-modalBg',
			name: namePrefix ~ '[modalBg]',
			value: styles.modalBg,
		}) }}
		{{ forms.colorField({
			label: 'Border'|t('search-manager'),
			id: 'styles-modalBorderColor',
			name: namePrefix ~ '[modalBorderColor]',
			value: styles.modalBorderColor,
		}) }}
	</div>
	{{ forms.colorField({
		label: 'Scrollbar'|t('search-manager'),
		id: 'styles-scrollbarColor',
		name: namePrefix ~ '[scrollbarColor]',
		value: styles.scrollbarColor,
		tip: 'Results scrollbar. Leave empty for an automatic subtle thumb.'|t('search-manager'),
	}) }}
	{{ _self.shadowComposer('styles-modalShadow', namePrefix ~ '[modalShadow]', styles.modalShadow) }}
</div>

{# Dark Mode Colors #}
<div class="color-scheme-section hidden" data-color-scheme="dark">
	<div class="flex" style="gap: 24px; flex-wrap: wrap;">
		{{ forms.colorField({
			label: 'Background'|t('search-manager'),
