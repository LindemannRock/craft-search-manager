{% css %}
[data-shadow-parts] > .field {
	margin: 0;
}
[data-shadow-parts] input[type='number'] {
	width: 5.5em;
}
[data-shadow-parts] .color-container .color-input,
[data-shadow-parts] .color-container .text {
	width: 7em;
}
{% endcss %}

{% js %}
// Box-shadow composer: number inputs + color picker compose the stored CSS
// string; unparseable values (multi-layer shadows) fall back to raw CSS mode.
document.querySelectorAll('[data-shadow-composer]').forEach(function(composer) {
	var inputId = composer.getAttribute('data-shadow-input');
	var hidden = document.getElementById(inputId);
	var get = function(suffix) { return document.getElementById(inputId + '-' + suffix); };
	var x = get('x'), y = get('y'), blur = get('blur'), spread = get('spread'),
		color = get('color'), opacity = get('opacity'), custom = get('custom');
	var partsWrap = composer.querySelector('[data-shadow-parts]');
	var customWrap = composer.querySelector('[data-shadow-custom]');
	var toggle = composer.querySelector('[data-shadow-toggle]');
	var labels = { css: toggle.getAttribute('data-label-css'), visual: toggle.getAttribute('data-label-visual') };
	var customMode = false;

	function hexToRgb(hex) {
		hex = String(hex || '').replace('#', '');
		if (hex.length === 3) hex = hex.split('').map(function(c) { return c + c; }).join('');
		if (!/^[0-9a-fA-F]{6}$/.test(hex)) hex = '000000';
		var n = parseInt(hex, 16);
		return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
	}

	function compose() {
		if (customMode) { hidden.value = custom.value.trim(); return; }
		var allEmpty = !x.value && !y.value && !blur.value && !spread.value && !color.value;
		if (allEmpty) { hidden.value = ''; return; }
		var rgb = hexToRgb(color.value);
		var a = Math.min(100, Math.max(0, parseInt(opacity.value === '' ? '100' : opacity.value, 10) || 0)) / 100;
		hidden.value = (x.value || 0) + 'px ' + (y.value || 0) + 'px ' + (blur.value || 0) + 'px ' +
			(spread.value || 0) + 'px rgba(' + rgb.join(', ') + ', ' + a + ')';
	}

	function parseShadow(value) {
		var m = String(value || '').trim().match(
			/^(-?\d+(?:\.\d+)?)(?:px)?\s+(-?\d+(?:\.\d+)?)(?:px)?(?:\s+(-?\d+(?:\.\d+)?)(?:px)?)?(?:\s+(-?\d+(?:\.\d+)?)(?:px)?)?\s+(rgba?\([^)]*\)|#[0-9a-fA-F]{3,8})$/
		);
		if (!m) return null;
		var col = m[5], hex = '000000', alpha = 100;
		var rgba = col.match(/^rgba?\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)\s*(?:,\s*([\d.]+)\s*)?\)$/);
		if (rgba) {
			hex = [rgba[1], rgba[2], rgba[3]].map(function(c) {
				return ('0' + (+c).toString(16)).slice(-2);
			}).join('');
			alpha = rgba[4] !== undefined ? Math.round(parseFloat(rgba[4]) * 100) : 100;
		} else {
			hex = col.slice(1);
			if (hex.length === 3) hex = hex.split('').map(function(c) { return c + c; }).join('');
			if (hex.length === 8) {
				alpha = Math.round(parseInt(hex.slice(6), 16) / 255 * 100);
				hex = hex.slice(0, 6);
			}
		}
		return { x: m[1], y: m[2], blur: m[3] || '0', spread: m[4] || '0', hex: hex, alpha: alpha };
	}

	function setMode(toCustom) {
		customMode = toCustom;
		partsWrap.classList.toggle('hidden', toCustom);
		customWrap.classList.toggle('hidden', !toCustom);
		toggle.textContent = toCustom ? labels.visual : labels.css;
	}

	// Initialize from the stored value
	var initial = (hidden.value || '').trim();
	var parsed = parseShadow(initial);
	if (parsed) {
		x.value = parsed.x; y.value = parsed.y; blur.value = parsed.blur; spread.value = parsed.spread;
		color.value = '#' + parsed.hex; opacity.value = parsed.alpha;
		color.dispatchEvent(new Event('input', { bubbles: true }));
		setMode(false);
	} else if (initial === '') {
		setMode(false);
	} else {
		custom.value = initial;
		setMode(true);
	}

	toggle.addEventListener('click', function() {
		if (!customMode) { custom.value = hidden.value; setMode(true); }
		else {
			var p = parseShadow(custom.value);
			if (p) {
				x.value = p.x; y.value = p.y; blur.value = p.blur; spread.value = p.spread;
				color.value = '#' + p.hex; opacity.value = p.alpha;
				color.dispatchEvent(new Event('input', { bubbles: true }));
			}
			setMode(false);
			compose();
		}
	});

	composer.addEventListener('input', function(e) {
		if (e.target !== hidden) compose();
	});

	// Craft's color picker doesn't always fire input events — poll it
	var lastColor = color.value;
	setInterval(function() {
		if (!customMode && color.value !== lastColor) {
			lastColor = color.value;
			compose();
		}
	}, 250);
});
{% endjs %}
