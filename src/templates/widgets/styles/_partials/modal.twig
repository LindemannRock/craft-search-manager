{% import "_includes/forms" as forms %}

<div class="color-scheme-toggle btngroup" style="margin-bottom: 14px;">
	<button type="button" class="btn secondary" data-color-scheme="light" aria-pressed="true">{{ "Light"|t('search-manager') }}</button>
	<button type="button" class="btn" data-color-scheme="dark" aria-pressed="false">{{ "Dark"|t('search-manager') }}</button>
</div>

{# ========================================
   MODAL
   ======================================== #}
<h2>{{ "Modal"|t('search-manager') }}</h2>

{# Light Mode Colors #}
<div class="color-scheme-section" data-color-scheme="light">
	<div class="flex" style="gap: 24px; flex-wrap: wrap;">
		{{ forms.colorField({
			label: 'Background'|t('search-manager'),
			id: 'styles-modalBg',
			name: namePrefix ~ '[modalBg]',
			value: styles.modalBg,
		}) }}
		{{ forms.colorField({
			label: 'Border'|t('search-manager'),
			id: 'styles-modalBorderColor',
			name: namePrefix ~ '[modalBorderColor]',
			value: styles.modalBorderColor,
		}) }}
	</div>
	{{ forms.textField({
		label: 'Box Shadow'|t('search-manager'),
		instructions: 'CSS box-shadow value (e.g., "0 25px 50px -12px rgba(0,0,0,0.25)")'|t('search-manager'),
		id: 'styles-modalShadow',
		name: namePrefix ~ '[modalShadow]',
		value: styles.modalShadow,
	}) }}
</div>

{# Dark Mode Colors #}
<div class="color-scheme-section hidden" data-color-scheme="dark">
	<div class="flex" style="gap: 24px; flex-wrap: wrap;">
		{{ forms.colorField({
			label: 'Background'|t('search-manager'),
			id: 'styles-modalBgDark',
			name: namePrefix ~ '[modalBgDark]',
			value: styles.modalBgDark,
		}) }}
		{{ forms.colorField({
			label: 'Border'|t('search-manager'),
			id: 'styles-modalBorderColorDark',
			name: namePrefix ~ '[modalBorderColorDark]',
			value: styles.modalBorderColorDark,
		}) }}
	</div>
	{{ forms.textField({
		label: 'Box Shadow'|t('search-manager'),
		instructions: 'CSS box-shadow value (e.g., "0 25px 50px -12px rgba(0,0,0,0.5)")'|t('search-manager'),
		id: 'styles-modalShadowDark',
		name: namePrefix ~ '[modalShadowDark]',
		value: styles.modalShadowDark,
	}) }}
</div>

{# Shared Dimensions #}
<div style="margin-top: 24px;">
	<h4>{{ "Dimensions"|t('search-manager') }}</h4>
	{{ forms.textField({
		label: 'Max Width (px)'|t('search-manager'),
		id: 'styles-modalMaxWidth',
		name: namePrefix ~ '[modalMaxWidth]',
		value: styles.modalMaxWidth,
		type: 'number',
		min: 300,
		max: 1200,
		size: 10,
		tip: 'Min: 300, Max: 1200. Default: 640'|t('search-manager'),
		errors: widgetStyle is defined and widgetStyle ? widgetStyle.getErrors('styles.modalMaxWidth') : [],
	}) }}
	{{ forms.textField({
		label: 'Max Height (vh)'|t('search-manager'),
		id: 'styles-modalMaxHeight',
		name: namePrefix ~ '[modalMaxHeight]',
		value: styles.modalMaxHeight,
		type: 'number',
		min: 30,
		max: 95,
		size: 10,
		tip: 'Min: 30, Max: 95. Default: 80. Percentage of viewport height.'|t('search-manager'),
		errors: widgetStyle is defined and widgetStyle ? widgetStyle.getErrors('styles.modalMaxHeight') : [],
	}) }}
	{{ forms.textField({
		label: 'Border Radius (px)'|t('search-manager'),
		id: 'styles-modalBorderRadius',
		name: namePrefix ~ '[modalBorderRadius]',
		value: styles.modalBorderRadius,
		type: 'number',
		min: 0,
		max: 50,
		size: 10,
		tip: 'Min: 0, Max: 50. Default: 12'|t('search-manager'),
		errors: widgetStyle is defined and widgetStyle ? widgetStyle.getErrors('styles.modalBorderRadius') : [],
	}) }}
	{{ forms.textField({
		label: 'Border Width (px)'|t('search-manager'),
		id: 'styles-modalBorderWidth',
		name: namePrefix ~ '[modalBorderWidth]',
		value: styles.modalBorderWidth,
		type: 'number',
		min: 0,
		max: 10,
		size: 10,
		tip: 'Min: 0, Max: 10. Default: 1. Set to 0 to remove border.'|t('search-manager'),
		errors: widgetStyle is defined and widgetStyle ? widgetStyle.getErrors('styles.modalBorderWidth') : [],
	}) }}
	{{ forms.textField({
		label: 'Padding X (px)'|t('search-manager'),
		id: 'styles-modalPaddingX',
		name: namePrefix ~ '[modalPaddingX]',
		value: styles.modalPaddingX,
		type: 'number',
		min: 0,
		max: 64,
		size: 10,
		tip: 'Min: 0, Max: 64. Default: 16. Horizontal inner padding.'|t('search-manager'),
		errors: widgetStyle is defined and widgetStyle ? widgetStyle.getErrors('styles.modalPaddingX') : [],
	}) }}
	{{ forms.textField({
		label: 'Padding Y (px)'|t('search-manager'),
		id: 'styles-modalPaddingY',
		name: namePrefix ~ '[modalPaddingY]',
		value: styles.modalPaddingY,
		type: 'number',
		min: 0,
		max: 64,
		size: 10,
		tip: 'Min: 0, Max: 64. Default: 16. Vertical inner padding.'|t('search-manager'),
		errors: widgetStyle is defined and widgetStyle ? widgetStyle.getErrors('styles.modalPaddingY') : [],
	}) }}
</div>

<hr>

{# ========================================
   BACKDROP
   ======================================== #}
<h2>{{ "Backdrop"|t('search-manager') }}</h2>
<p class="light">{{ "The overlay behind the modal when it is open."|t('search-manager') }}</p>

{{ forms.textField({
	label: 'Opacity'|t('search-manager'),
	instructions: 'Opacity of the dark overlay (0 = transparent, 100 = opaque)'|t('search-manager'),
	id: 'styles-backdropOpacity',
	name: namePrefix ~ '[backdropOpacity]',
	value: styles.backdropOpacity,
	type: 'number',
	min: 0,
	max: 100,
	size: 10,
	tip: 'Min: 0 (transparent), Max: 100 (opaque). Default: 50'|t('search-manager'),
	errors: widgetStyle is defined and widgetStyle ? widgetStyle.getErrors('styles.backdropOpacity') : [],
}) }}

{{ forms.lightswitchField({
	label: 'Enable Backdrop Blur'|t('search-manager'),
	instructions: 'Apply a blur effect to the page content behind the modal'|t('search-manager'),
	id: 'styles-backdropBlur',
	name: namePrefix ~ '[backdropBlur]',
	on: styles.backdropBlur != '0',
}) }}
