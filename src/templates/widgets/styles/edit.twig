{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set title = isNew ? "New Widget Style"|t('search-manager') : widgetStyle.name %}
{% set fullPageForm = true %}
{% set selectedSubnavItem = 'widgets' %}
{% set saveShortcutRedirect = cpUrl('search-manager/widgets/styles/edit/{id}') %}
{% set retainScrollOnSaveShortcut = true %}

{% set crumbs = [
	{ label: searchHelper.fullName, url: url('search-manager') },
	{ label: 'Widgets'|t('search-manager'), url: url('search-manager/widgets') },
	{ label: 'Styles'|t('search-manager'), url: url('search-manager/widgets/styles') },
	{ label: isNew ? 'New Widget Style'|t('search-manager') : widgetStyle.name }
] %}


{% set styles = isNew ? defaultStyles : defaultStyles|merge(widgetStyle.getStyles()) %}

{% block actionButton %}
	<div class="btngroup submit">
		<button type="submit" class="btn submit">{{ "Save"|t('app') }}</button>
		<button type="button" class="btn submit menubtn"></button>
		<div class="menu">
			<ul role="listbox">
				<li>
					<a class="formsubmit" role="option" tabindex="0" data-redirect="{{ cpUrl('search-manager/widgets/styles/edit/{id}')|hash }}">
						<span class="label">{{ 'Save and continue editing'|t('app') }}</span>
						<span class="shortcut" id="save-shortcut"></span>
					</a>
				</li>
			</ul>
		</div>
	</div>
	{% if not isNew and currentUser.can('searchManager:deleteWidgetConfigs') and widgetStyle.canEdit() %}
		<button type="button" id="action-btn" class="btn menubtn action-btn hairline-dark m" title="{{ 'Actions'|t('app') }}" aria-controls="action-menu" aria-label="{{ 'Actions'|t('app') }}" data-disclosure-trigger="true" aria-expanded="false"></button>
		<div id="action-menu" class="menu menu--disclosure">
			<ul>
				<li>
					<button class="menu-item error formsubmit" data-destructive data-action="search-manager/widgets/delete-style" data-params='{"styleId":{{ widgetStyle.id }}}' data-confirm="{{ 'Are you sure you want to delete this style? Widgets using it will fall back to inline styles.'|t('search-manager') }}" data-redirect="{{ 'search-manager/widgets/styles'|hash }}" data-headers='{"Accept":"application/json"}'>
						<span class="icon">{{ svg('@app/icons/trash.svg') }}</span>
						<span class="menu-item-label">{{ "Delete"|t('app') }}</span>
					</button>
				</li>
			</ul>
		</div>
	{% endif %}
{% endblock %}

{# Display validation errors summary before content #}
{% if widgetStyle.hasErrors() %}
	{% set errorList = [] %}
	{% for attribute, errors in widgetStyle.getErrors() %}
		{% for error in errors %}
			{% set errorList = errorList|merge([{
				attribute: attribute,
				message: error
			}]) %}
		{% endfor %}
	{% endfor %}

	{% set errorSummary %}
		<div class="error-summary" tabindex="-1">
			<div>
				<span class="notification-icon" data-icon="alert" aria-label="error" role="img"></span>
				<h2>{{ 'Found {count, number} {count, plural, =1{error} other{errors}}'|t('app', {count: errorList|length}) }}</h2>
			</div>
			<ul class="errors">
				{% for error in errorList %}
					<li>
						<a href="#" data-field-error-key="{{ error.attribute }}">{{ error.message }}</a>
					</li>
				{% endfor %}
			</ul>
		</div>
	{% endset %}
{% endif %}

{% block content %}
	<input type="hidden" name="action" value="search-manager/widgets/save-style">
	<input type="hidden" name="redirect" value="{{ 'search-manager/widgets/styles'|hash }}">
	{% if not isNew %}
		<input type="hidden" name="styleId" value="{{ widgetStyle.id }}">
	{% endif %}
	{{ csrfInput() }}

	{# Settings Tab #}
	<div id="settings">
		{{ forms.textField({
			label: 'Name'|t('search-manager'),
			instructions: 'What this style is called in the Control Panel.'|t('search-manager'),
			id: 'name',
			name: 'name',
			value: widgetStyle.name,
			required: true,
			first: true,
			errors: widgetStyle.getErrors('name')
		}) }}

		{{ forms.textField({
			label: 'Handle'|t('search-manager'),
			instructions: 'How you reference this style in templates and config.'|t('search-manager'),
			id: 'handle',
			name: 'handle',
			value: widgetStyle.handle,
			required: true,
			class: 'code',
			errors: widgetStyle.getErrors('handle')
		}) }}

		<hr>

		{% include "search-manager/widgets/styles/_partials/appearance" with {
			styles: styles,
			widgetStyle: widgetStyle,
		} %}
	</div>
{% endblock %}

{% block details %}
	<div class="meta">
		{{ forms.lightswitchField({
			label: 'Enabled'|t('search-manager'),
			id: 'enabled',
			name: 'enabled',
			on: widgetStyle.enabled ?? true,
		}) }}

		{{ forms.selectField({
			label: 'Widget Type'|t('search-manager'),
			id: 'type',
			name: 'type',
			value: widgetStyle.type,
			options: widgetTypeOptions,
			errors: widgetStyle.getErrors('type')
		}) }}
	</div>

	{# Widget Preview - only visible on Appearance tab #}
	<div id="widget-preview-wrapper">
		{% include "search-manager/widgets/_shared/preview" with {
			widgetConfig: null,
			styles: styles,
		} only %}
	</div>

	{# Style Info - only for existing styles #}
	{% if not isNew %}
		<fieldset>
			<dl class="meta read-only">
				<div class="data">
					<dt class="heading">{{ 'Status'|t('search-manager') }}</dt>
					<dd class="value">
						<span class="status {{ widgetStyle.enabled ? 'live' : 'disabled' }}"></span>
						<span>{{ widgetStyle.enabled ? 'Enabled'|t('search-manager') : 'Disabled'|t('search-manager') }}</span>
					</dd>
				</div>
				<div class="data">
					<dt class="heading">{{ 'Handle'|t('search-manager') }}</dt>
					<dd class="value"><code>{{ widgetStyle.handle }}</code></dd>
				</div>
				<div class="data">
					{% set typeLabels = {modal: 'Modal', page: 'Search Page', inline: 'Inline Search'} %}
					<dt class="heading">{{ 'Type'|t('search-manager') }}</dt>
					<dd class="value">{{ typeLabels[widgetStyle.type] ?? widgetStyle.type|capitalize }}</dd>
				</div>
				<div class="data">
					<dt class="heading">{{ 'Source'|t('search-manager') }}</dt>
					<dd class="value">{{ widgetStyle.source == 'config' ? 'Config File'|t('search-manager') : 'Database'|t('search-manager') }}</dd>
				</div>
				{% if usageCount is defined and usageCount > 0 %}
					<div class="data">
						<dt class="heading">{{ 'Widgets Using'|t('search-manager') }}</dt>
						<dd class="value">{{ usageCount }}</dd>
					</div>
				{% endif %}
			</dl>
		</fieldset>
	{% endif %}
{% endblock %}

{% do view.registerAssetBundle('lindemannrock\\searchmanager\\web\\assets\\widgetpreview\\WidgetPreviewAsset') %}

{% js %}
// Set platform-specific keyboard shortcut
const isMac = navigator.platform.toUpperCase().indexOf('MAC') >= 0;
const saveShortcut = document.getElementById('save-shortcut');
if (saveShortcut) {
	saveShortcut.textContent = isMac ? '⌘S' : 'Ctrl+S';
}

// Handle auto-generation from name
(function() {
	const nameInput = document.getElementById('name');
	const handleInput = document.getElementById('handle');
	const isNew = {{ isNew ? 'true' : 'false' }};
	let handleModifiedManually = !isNew;

	function nameToHandle(name) {
		return name
			.toLowerCase()
			.replace(/[^a-z0-9]+/g, '-')
			.replace(/^-+|-+$/g, '');
	}

	if (isNew && nameInput && handleInput) {
		nameInput.addEventListener('input', function() {
			if (!handleModifiedManually) {
				handleInput.value = nameToHandle(this.value);
			}
		});
		handleInput.addEventListener('input', function() {
			handleModifiedManually = true;
		});
	}
})();

// Shared preview engine
SearchManagerPreview.initColorSchemeToggle();
SearchManagerPreview.initPreview('styles');
{% endjs %}
