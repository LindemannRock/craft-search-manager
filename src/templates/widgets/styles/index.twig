{% extends 'lindemannrock-base/_layouts/cp-table' %}

{# Follows the canonical CP table index-page pattern (in-memory variant) —
   see plugins/base/docs/template-guides/cp-table-index-pattern.md.
   WidgetsController::actionStylesIndex() owns query-param parsing, allowlist
   validation, filter, sort, and pagination. This template stays
   presentational and just renders what's handed in. #}

{% set tableConfig = {
	plugin: {
		handle: 'search-manager',
		name: searchHelper.fullName,
	},
	page: {
		title: 'Widget Styles'|t('search-manager'),
		subnav: 'widgets',
		crumbs: [
			{ label: searchHelper.fullName, url: url('search-manager') },
			{ label: 'Widgets'|t('search-manager'), url: url('search-manager/widgets') },
			{ label: 'Styles'|t('search-manager') }
		],
	},
	sidebarMenu: {
		label: 'Widgets'|t('search-manager'),
		items: {
			configurations: { label: 'Configurations'|t('search-manager'), url: url('search-manager/widgets') },
			styles: { label: 'Styles'|t('search-manager'), url: url('search-manager/widgets/styles') },
		},
		selected: 'styles',
	},
	filters: [
		{
			type: 'status',
			param: 'status',
			current: statusFilter,
			label: 'All'|t('search-manager'),
			groups: [
				{
					param: 'status',
					current: statusFilter,
					colorSet: 'status',
					options: [
						{value: 'all', label: 'All'|t('search-manager'), status: 'all'},
						{value: 'enabled', label: 'Enabled'|t('search-manager'), colorKey: 'enabled'},
						{value: 'disabled', label: 'Disabled'|t('search-manager'), colorKey: 'disabled'},
					],
				},
				{
					header: 'Config Source'|t('search-manager'),
					param: 'source',
					current: sourceFilter,
					colorSet: 'configSource',
					options: [
						{value: 'all', label: 'All Sources'|t('search-manager'), status: 'all'},
						{value: 'config', label: 'Config File'|t('search-manager'), colorKey: 'config'},
						{value: 'database', label: 'Database'|t('search-manager'), colorKey: 'database'},
					],
				},
				{
					header: 'Widget Type'|t('search-manager'),
					param: 'type',
					current: typeFilter,
					colorSet: 'widgetType',
					options: [
						{value: 'all', label: 'All Types'|t('search-manager'), status: 'all'},
						{value: 'modal', label: 'Modal'|t('search-manager'), colorKey: 'modal'},
						{value: 'page', label: 'Search Page'|t('search-manager'), colorKey: 'page'},
						{value: 'inline', label: 'Inline Search'|t('search-manager'), colorKey: 'inline'},
					],
				},
			],
		},
	],
	search: {
		placeholder: 'Search widget styles...'|t('search-manager'),
		value: search,
	},
	sort: {
		field: sort,
		direction: dir,
	},
	table: {
		columns: [
			{key: 'name', label: 'Name'|t('search-manager'), sortable: true},
			{key: 'handle', label: 'Handle'|t('search-manager'), sortable: true, hideable: true},
			{key: 'type', label: 'Type'|t('search-manager'), sortable: true, hideable: true},
			{key: 'source', label: 'Source'|t('search-manager'), sortable: true, hideable: true},
			{key: 'enabled', label: 'Status'|t('search-manager'), sortable: true, hideable: true},
			{key: 'widgets', label: 'Widgets'|t('search-manager'), hideable: true},
		],
		items: widgetStyles,
		emptyMessage: 'No widget styles found.'|t('search-manager'),
		hasConfigItems: hasConfigItems,
	},
	pagination: {
		page: page,
		limit: limit,
		totalCount: totalCount,
		itemLabel: {singular: 'style'|t('search-manager'), plural: 'styles'|t('search-manager')},
	},
	checkboxes: canEdit or canDelete,
	newButton: canCreate ?? false ? {
		url: url('search-manager/widgets/styles/new'),
		label: 'New Widget Style'|t('search-manager'),
	} : null,
} %}

{% block beforeTable %}
	{% if collisionHandles is defined and collisionHandles|length %}
		{% set boldHandles = [] %}
		{% for handle in collisionHandles %}
			{% set boldHandles = boldHandles|merge(['<strong>' ~ handle|e ~ '</strong>']) %}
		{% endfor %}
		{% set warningMessage %}
		<strong>{{ 'Warning'|t('search-manager') }}:</strong>
		{{ 'These style handles exist in both config/search-manager.php and the database:'|t('search-manager') }} {{ boldHandles|join(', ')|raw }}.
		{{ 'Config takes precedence; database entries with the same handle are ignored.'|t('search-manager') }}
		{{ 'Update your config/search-manager.php or remove the database entries to resolve this.'|t('search-manager') }}
		{% endset %}
		<div class="lr-info-box-table-wrapper">
			{% include 'lindemannrock-base/_components/info-box' with {
				message: warningMessage,
				type: 'warning',
				margin: 'none',
				stretch: true,
			} %}
		</div>
	{% endif %}
{% endblock %}

{% block tableRow %}
	{# Name #}
	<td data-column="name">
		{% if item.canEdit() %}
			<a class="label-link" href="{{ url('search-manager/widgets/styles/edit/' ~ item.id) }}">
				<span>{{ item.name }}</span>
			</a>
		{% else %}
			<a class="label-link" href="{{ url('search-manager/widgets/styles/view/' ~ item.handle) }}">
				<span>{{ item.name }}</span>
			</a>
			<span class="lr-config-info-icon" data-config="{{ item.rawConfigDisplay|e('html_attr') }}" data-config-source="config/search-manager.php"></span>
		{% endif %}
	</td>

	{# Handle #}
	<td data-column="handle">
		<code>{{ item.handle }}</code>
	</td>

	{# Type #}
	<td data-column="type">
		{% set typeLabels = {modal: 'Modal', page: 'Search Page', inline: 'Inline Search'} %}
		{% include 'lindemannrock-base/_components/badge' with {
			label: typeLabels[item.type] ?? item.type|capitalize,
			value: item.type,
			colorSet: 'widgetType',
		} only %}
	</td>

	{# Source #}
	<td data-column="source">
		{% include 'lindemannrock-base/_components/badge' with {
			label: item.source == 'config' ? 'Config'|t('search-manager') : 'Database'|t('search-manager'),
			value: item.source,
			colorSet: 'configSource',
		} only %}
	</td>

	{# Status #}
	<td data-column="enabled">
		{% include 'lindemannrock-base/_components/badge' with {
			label: item.enabled ? 'Enabled'|t('search-manager') : 'Disabled'|t('search-manager'),
			value: item.enabled ? 'enabled' : 'disabled',
			colorSet: 'status',
		} only %}
	</td>

	{# Widgets using this style #}
	<td data-column="widgets">
		{% set usageCount = styleUsageCounts[item.handle] ?? 0 %}
		{% if usageCount > 0 %}
			<span>{{ usageCount }}</span>
		{% else %}
			<span class="light">-</span>
		{% endif %}
	</td>
{% endblock %}

{% block rowActions %}
	{% set actionItems = [] %}

	{% if item.canEdit() %}
		{% if canEdit %}
			{% set actionItems = actionItems|merge([{
				label: 'Edit'|t('search-manager'),
				url: url('search-manager/widgets/styles/edit/' ~ item.id),
			}]) %}
		{% endif %}
		{% if canDelete %}
			{% set actionItems = actionItems|merge([
				{type: 'divider'},
				{
					label: 'Delete'|t('search-manager'),
					class: 'error',
					jsAction: 'delete',
					data: {name: item.name},
				},
			]) %}
		{% endif %}
	{% else %}
		{% set actionItems = actionItems|merge([{
			label: 'View'|t('search-manager'),
			url: url('search-manager/widgets/styles/view/' ~ item.handle),
		}]) %}
	{% endif %}

	{% if actionItems|length > 0 %}
		{% include 'lindemannrock-base/_components/row-actions' with {
			item: {id: item.id},
			actions: {
				type: 'menu',
				icon: 'settings',
				title: 'Actions'|t('search-manager'),
				items: actionItems,
			},
		} only %}
	{% endif %}
{% endblock %}

{% block bulkActions %}
	{% if canEdit %}
		{% include 'lindemannrock-base/_components/bulk-status-menu' with {
			label: 'Set status'|t('search-manager'),
			countId: 'lr-bulk-status-count',
			items: [
				{id: 'lr-bulk-enable-action', label: 'Enable'|t('search-manager'), status: 'enabled'},
				{id: 'lr-bulk-disable-action', label: 'Disable'|t('search-manager'), status: 'disabled'},
			],
		} only %}
	{% endif %}

	{% if canDelete %}
		{% include 'lindemannrock-base/_components/bulk-actions-menu' with {
			label: 'Actions'|t('search-manager'),
			countId: 'lr-bulk-actions-count',
			items: [
				{id: 'lr-bulk-delete-btn', label: 'Delete'|t('search-manager'), class: 'error'},
			],
		} only %}
	{% endif %}
{% endblock %}

{% block scripts %}
<script>
(function() {
	if (typeof Craft === 'undefined') return;

	const T = {
		deleted: {{ 'Widget style deleted'|t('search-manager')|json_encode|raw }},
		deleteFailed: {{ 'Failed to delete style'|t('search-manager')|json_encode|raw }},
		deleteConfirm: {{ 'Delete style "{name}"? Widgets using this style will fall back to inline styles.'|t('search-manager')|json_encode|raw }},
		bulkDeleteConfirmTemplate: {{ 'Delete {count} style(s)? This cannot be undone.'|t('search-manager')|json_encode|raw }},
		bulkDeletedTemplate: {{ 'Deleted {count} style(s)'|t('search-manager')|json_encode|raw }},
		bulkEnabledTemplate: {{ 'Enabled {count} styles'|t('search-manager')|json_encode|raw }},
		bulkEnableFailed: {{ 'Failed to enable styles'|t('search-manager')|json_encode|raw }},
		bulkDisabledTemplate: {{ 'Disabled {count} styles'|t('search-manager')|json_encode|raw }},
		bulkDisableFailed: {{ 'Failed to disable styles'|t('search-manager')|json_encode|raw }},
	};

	function selectedIds() {
		return window.lrTableSelection ? window.lrTableSelection.getSelectedIds() : [];
	}

	function deleteStyle(id) {
		return Craft.sendActionRequest('POST', 'search-manager/widgets/delete-style', {
			data: { styleId: id },
		});
	}

	function runBulkStatus(endpoint, successTemplate, errorFallback) {
		const ids = selectedIds();
		if (!ids.length) return;
		Craft.sendActionRequest('POST', endpoint, {
			data: { styleIds: ids },
		}).then(function(response) {
			const count = response.data.count || 0;
			if (count > 0) {
				Craft.cp.displayNotice(successTemplate.replace('{count}', count));
				setTimeout(function() { window.location.reload(); }, 500);
			}
		}).catch(function() {
			Craft.cp.displayError(errorFallback);
		});
	}

	document.addEventListener('click', function(e) {
		const trigger = e.target.closest('a[data-action]');
		if (!trigger) return;
		if (trigger.dataset.action !== 'delete') return;

		const id = parseInt(trigger.dataset.id || '0', 10);
		if (!id) return;
		e.preventDefault();

		const name = trigger.dataset.name || '';
		if (!confirm(T.deleteConfirm.replace('{name}', name))) return;

		deleteStyle(id).then(function(response) {
			if (response.data.success) {
				Craft.cp.displayNotice(T.deleted);
				setTimeout(function() { window.location.reload(); }, 500);
			} else {
				Craft.cp.displayError(response.data.error || T.deleteFailed);
			}
		}).catch(function() {
			Craft.cp.displayError(T.deleteFailed);
		});
	});

	document.getElementById('lr-bulk-enable-action')?.addEventListener('click', function(e) {
		e.preventDefault();
		runBulkStatus('search-manager/widgets/bulk-enable-style', T.bulkEnabledTemplate, T.bulkEnableFailed);
	});

	document.getElementById('lr-bulk-disable-action')?.addEventListener('click', function(e) {
		e.preventDefault();
		runBulkStatus('search-manager/widgets/bulk-disable-style', T.bulkDisabledTemplate, T.bulkDisableFailed);
	});

	document.getElementById('lr-bulk-delete-btn')?.addEventListener('click', function() {
		const ids = selectedIds();
		if (!ids.length) return;
		if (!confirm(T.bulkDeleteConfirmTemplate.replace('{count}', ids.length))) return;

		// `delete-style` is a single-row endpoint; for bulk we fan out per id
		// and aggregate successes/failures client-side. Acceptable today since
		// the user-controlled selection is bounded by the page-size limit;
		// promote to a server-side bulk-delete endpoint if that ceiling rises.
		let deleted = 0;
		const errors = [];
		const promises = ids.map(function(id) {
			return deleteStyle(id).then(function(response) {
				if (response.data.success) {
					deleted++;
				} else {
					errors.push(response.data.error || T.deleteFailed);
				}
			}).catch(function() {
				errors.push(T.deleteFailed);
			});
		});

		Promise.all(promises).then(function() {
			if (deleted > 0) {
				Craft.cp.displayNotice(T.bulkDeletedTemplate.replace('{count}', deleted));
			}
			errors.forEach(function(err) { Craft.cp.displayError(err); });
			if (deleted > 0) {
				setTimeout(function() { window.location.reload(); }, 500);
			}
		});
	});

	const collisionHandles = {{ collisionHandles is defined ? collisionHandles|json_encode|raw : '[]' }};
	if (collisionHandles.length > 0) {
		document.querySelectorAll('#lr-data-table tbody tr.lr-data-row').forEach(function(row) {
			const handleCell = row.querySelector('td[data-column="handle"] code');
			if (handleCell && collisionHandles.includes(handleCell.textContent.trim())) {
				row.classList.add('lr-row--warning');
			}
		});
	}
})();
</script>
{% endblock %}
