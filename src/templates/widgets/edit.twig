{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}
{% do view.registerAssetBundle('lindemannrock\\base\\web\\assets\\components\\ComponentsAsset') %}
{% do view.registerAssetBundle('lindemannrock\\searchmanager\\web\\assets\\widgetconfig\\WidgetConfigAsset') %}

{% set title = isNew ? "New Widget Config"|t('search-manager') : widgetConfig.name %}
{% set fullPageForm = true %}
{% set selectedSubnavItem = 'widgets' %}
{% set saveShortcutRedirect = cpUrl('search-manager/widgets/edit/{id}') %}
{% set retainScrollOnSaveShortcut = true %}
{% set setupIncompleteSummary = include('search-manager/_partials/setup-incomplete-summary', {
    selectedSubnavItem: selectedSubnavItem,
})|trim %}

{% set crumbs = [
    { label: searchHelper.fullName, url: url('search-manager') },
    { label: 'Widgets'|t('search-manager'), url: url('search-manager/widgets') },
    { label: 'Configurations'|t('search-manager'), url: url('search-manager/widgets') },
    { label: isNew ? 'New Widget Config'|t('search-manager') : widgetConfig.name }
] %}

{# Set up tabs #}
{% set tabs = {
	general: {
		label: 'General'|t('search-manager'),
		url: '#general',
	},
	searchInput: {
		label: 'Search Input'|t('search-manager'),
		url: '#searchInput',
	},
	modalTrigger: {
		label: 'Modal & Trigger'|t('search-manager'),
		url: '#modalTrigger',
	},
	recentlyViewed: {
		label: 'Recently Viewed'|t('search-manager'),
		url: '#recentlyViewed',
	},
	results: {
		label: 'Results'|t('search-manager'),
		url: '#results',
	},
	snippets: {
		label: 'Snippets'|t('search-manager'),
		url: '#snippets',
	},
	destinationHighlighting: {
		label: 'Destination Highlighting'|t('search-manager'),
		url: '#destinationHighlighting',
	},
	analytics: {
		label: 'Analytics'|t('search-manager'),
        url: '#analytics',
    },
} %}

{% set selectedTab = 'general' %}
{% if widgetConfig.hasErrors() %}
	{% set errorKeys = widgetConfig.getErrors()|keys %}
	{% if errorKeys|filter(k => k starts with 'settings.analytics.')|length %}
		{% set selectedTab = 'analytics' %}
	{% elseif errorKeys|filter(k => k starts with 'settings.behavior.highlightDestination')|length %}
		{% set selectedTab = 'destinationHighlighting' %}
	{% elseif errorKeys|filter(k => k starts with 'settings.behavior.snippet')|length %}
		{% set selectedTab = 'snippets' %}
	{% elseif errorKeys|filter(k => k starts with 'settings.behavior.hierarchy')|length %}
		{% set selectedTab = 'results' %}
	{% elseif errorKeys|filter(k => k starts with 'settings.behavior.results' or k starts with 'settings.behavior.promotion')|length %}
		{% set selectedTab = 'results' %}
	{% elseif errorKeys|filter(k => k starts with 'settings.behavior.recentlyViewed')|length %}
		{% set selectedTab = 'recentlyViewed' %}
	{% elseif errorKeys|filter(k => k starts with 'settings.behavior.search' or k starts with 'settings.search.placeholder')|length %}
		{% set selectedTab = 'searchInput' %}
	{% elseif errorKeys|filter(k => k starts with 'settings.behavior.modal' or k starts with 'settings.behavior.trigger' or k starts with 'settings.behavior.loadingIndicator' or k starts with 'settings.trigger.')|length %}
		{% set selectedTab = 'modalTrigger' %}
	{% endif %}
{% endif %}

{% block actionButton %}
	<div class="btngroup submit">
		<button type="submit" class="btn submit">{{ "Save"|t('search-manager') }}</button>
		<button type="button" class="btn submit menubtn"></button>
		<div class="menu">
			<ul role="listbox">
				<li>
					<a class="formsubmit" role="option" tabindex="0" data-redirect="{{ cpUrl('search-manager/widgets/edit/{id}')|hash }}">
						<span class="label">{{ 'Save and continue editing'|t('search-manager') }}</span>
						<span class="shortcut" id="save-shortcut"></span>
					</a>
				</li>
			</ul>
		</div>
	</div>
	{% set isDefault = defaultWidgetHandle == widgetConfig.handle %}
	{% if not isNew and currentUser.can('searchManager:deleteWidgetConfigs') and not isDefault %}
		<button type="button" id="action-btn" class="btn menubtn action-btn hairline-dark m" title="{{ 'Actions'|t('search-manager') }}" aria-controls="action-menu" aria-label="{{ 'Actions'|t('search-manager') }}" data-disclosure-trigger="true" aria-expanded="false"></button>
		<div id="action-menu" class="menu menu--disclosure">
			<ul>
				<li>
					<button class="menu-item error formsubmit" data-destructive data-action="search-manager/widgets/delete" data-params='{"configId":{{ widgetConfig.id }}}' data-confirm="{{ 'Are you sure you want to delete this widget config?'|t('search-manager') }}" data-redirect="{{ 'search-manager/widgets'|hash }}" data-headers='{"Accept":"application/json"}'>
						<span class="icon">{{ svg('@app/icons/trash.svg') }}</span>
						<span class="menu-item-label">{{ "Delete"|t('search-manager') }}</span>
					</button>
				</li>
			</ul>
		</div>
	{% endif %}
{% endblock %}

{# Display validation errors summary before content #}
{% set validationSummary = '' %}
{% if widgetConfig.hasErrors() %}
	{% set validationSummary = include('lindemannrock-base/_partials/error-summary', {
		errors: widgetConfig.getErrors(),
		linkMode: 'data-key',
	})|trim %}
{% endif %}
{% set errorSummary = [setupIncompleteSummary, validationSummary]|filter(v => v)|join("\n") %}

{% block content %}
	<input type="hidden" name="action" value="search-manager/widgets/save">
	<input type="hidden" name="redirect" value="{{ 'search-manager/widgets'|hash }}">
	{% if not isNew %}
		<input type="hidden" name="configId" value="{{ widgetConfig.id }}">
	{% endif %}
	{{ csrfInput() }}

	{# General Tab #}
	<div id="general"{% if selectedTab != 'general' %} class="hidden"{% endif %}>
		{% include "search-manager/widgets/_partials/settings" with {
			widgetConfig: widgetConfig,
			indices: indices,
			widgetApiKeyOptions: widgetApiKeyOptions,
			widgetApiKeyScopes: widgetApiKeyScopes,
			selectedApiKey: selectedApiKey,
			hasWidgetUsableApiKeys: hasWidgetUsableApiKeys,
			isNew: isNew,
		} %}
	</div>

	{# Search Input Tab #}
	<div id="searchInput"{% if selectedTab != 'searchInput' %} class="hidden"{% endif %}>
		{% include "search-manager/widgets/_partials/search-input" with {
			widgetConfig: widgetConfig,
		} %}
	</div>

	{# Modal & Trigger Tab #}
	<div id="modalTrigger"{% if selectedTab != 'modalTrigger' %} class="hidden"{% endif %}>
		{% include "search-manager/widgets/_partials/modal-trigger" with {
			widgetConfig: widgetConfig,
		} %}
	</div>

	{# Recently Viewed Tab #}
	<div id="recentlyViewed"{% if selectedTab != 'recentlyViewed' %} class="hidden"{% endif %}>
		{% include "search-manager/widgets/_partials/recently-viewed" with {
			widgetConfig: widgetConfig,
		} %}
	</div>

	{# Results Tab #}
	<div id="results"{% if selectedTab != 'results' %} class="hidden"{% endif %}>
		{% include "search-manager/widgets/_partials/results" with {
			widgetConfig: widgetConfig,
		} %}
	</div>

	{# Snippets Tab #}
	<div id="snippets"{% if selectedTab != 'snippets' %} class="hidden"{% endif %}>
		{% include "search-manager/widgets/_partials/snippets" with {
			widgetConfig: widgetConfig,
		} %}
	</div>

	{# Destination Highlighting Tab #}
	<div id="destinationHighlighting"{% if selectedTab != 'destinationHighlighting' %} class="hidden"{% endif %}>
		{% include "search-manager/widgets/_partials/destination-highlighting" with {
			widgetConfig: widgetConfig,
		} %}
	</div>

	{# Analytics Tab #}
	<div id="analytics"{% if selectedTab != 'analytics' %} class="hidden"{% endif %}>
		{% include "search-manager/widgets/_partials/analytics" with {
			widgetConfig: widgetConfig,
		} %}
	</div>

	{% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}

{% block details %}
	<div class="meta">
		{# Check if this widget is the default #}
		{% set isDefault = defaultWidgetHandle == widgetConfig.handle %}

		{# Enabled toggle - disabled when widget is default #}
		{% if isDefault %}
			{{ forms.lightswitchField({
				label: 'Enabled'|t('search-manager'),
				instructions: 'Default widget cannot be disabled.'|t('search-manager'),
				id: 'enabled',
				on: true,
				disabled: true
			}) }}
			<input type="hidden" name="enabled" value="1">
		{% else %}
			{{ forms.lightswitchField({
				label: 'Enabled'|t('search-manager'),
				id: 'enabled',
				name: 'enabled',
				on: widgetConfig.enabled ?? true
			}) }}
		{% endif %}

		{# Default toggle with 3 states #}
		{% if isDefaultFromConfig %}
			{# Default set via config file - show disabled toggle #}
			{{ forms.lightswitchField({
				label: 'Default'|t('search-manager'),
				instructions: 'Set via config/search-manager.php. Edit the file to change.'|t('search-manager'),
				id: 'isDefault',
				on: isDefault,
				disabled: true
			}) }}
			{% if isDefault %}
				<input type="hidden" name="isDefault" value="1">
			{% endif %}
		{% elseif isDefault %}
			{# This is the default - show disabled toggle #}
			{{ forms.lightswitchField({
				label: 'Default'|t('search-manager'),
				instructions: 'To change, set another widget as default first.'|t('search-manager'),
				id: 'isDefault',
				on: true,
				disabled: true
			}) }}
			<input type="hidden" name="isDefault" value="1">
		{% else %}
			{# Not default - show enabled toggle #}
			{{ forms.lightswitchField({
				label: 'Default'|t('search-manager'),
				instructions: 'Use as default when no widget handle is specified'|t('search-manager'),
				id: 'isDefault',
				name: 'isDefault',
				on: false
			}) }}
		{% endif %}

		{{ forms.selectField({
			label: 'Widget Type'|t('search-manager'),
			id: 'type',
			name: 'type',
			value: widgetConfig.type,
			options: widgetTypeOptions,
			errors: widgetConfig.getErrors('type')
		}) }}

		{# Style Preset #}
		{% set _defaultStyles = widgetConfig.defaultStyleValues() %}
		{% set _styleMap = {} %}
		{% for style in widgetStyles %}
			{% set _styleMap = _styleMap|merge({ (style.handle): _defaultStyles|merge(style.getStyles()) }) %}
		{% endfor %}
		<div id="sidebar-style-data" class="hidden"
			data-style-map="{{ _styleMap|json_encode|e('html_attr') }}"
			data-default-styles="{{ _defaultStyles|json_encode|e('html_attr') }}"
		></div>
		{% set _styleOptions = [] %}
		{% for style in widgetStyles %}
			{% set _styleOptions = _styleOptions|merge([{
				value: style.handle,
				label: style.name
			}]) %}
		{% endfor %}
		{{ forms.selectField({
			label: 'Widget Style'|t('search-manager'),
			id: 'sidebarStylePreset',
			name: 'styleHandle',
			value: widgetConfig.styleHandle ?? '',
			options: _styleOptions,
			errors: widgetConfig.getErrors('styleHandle')
		}) }}
	</div>

	{# Widget Preview #}
	<div id="widget-preview-wrapper">
		{% include "search-manager/widgets/_shared/preview" with {
			widgetConfig: widgetConfig
		} %}
	</div>

	{# Template Usage - only for existing widgets #}
	{% if not isNew %}
		<fieldset>
			<legend class="h6">{{ 'Template Usage'|t('search-manager') }}</legend>
			<div class="meta">
				<div class="field">
					<dd class="value">
						<div style="background: #f3f7fc; padding: 10px; border-radius: 4px; font-family: monospace; font-size: 11px; line-height: 1.4; overflow-x: auto;">
						<code style="display: block; white-space: pre; user-select: all;">{% verbatim %}{% include 'search-manager/_widget/search-modal' with {
    configHandle: '{% endverbatim %}{{ widgetConfig.handle }}{% verbatim %}',
} %}{% endverbatim %}</code>
					</div>
					</dd>
				</div>
			</div>
		</fieldset>
	{% endif %}

	{# Widget Info - only for existing widgets #}
	{% if not isNew %}
		<fieldset>
			<dl class="meta read-only">
				{% if widgetConfig.id %}
					<div class="data">
						<dt class="heading">{{ 'ID'|t('search-manager') }}</dt>
						<dd class="value">{{ widgetConfig.id }}</dd>
					</div>
				{% endif %}
				<div class="data">
					<dt class="heading">{{ 'Status'|t('search-manager') }}</dt>
					<dd class="value">
						{% include 'lindemannrock-base/_components/status-dot' with {
							value: widgetConfig.enabled ? 'enabled' : 'disabled',
							colorSet: 'status',
						} only %}
						<span>{{ widgetConfig.enabled ? 'Enabled'|t('search-manager') : 'Disabled'|t('search-manager') }}</span>
					</dd>
				</div>
				<div class="data">
					<dt class="heading">{{ 'Source'|t('search-manager') }}</dt>
					<dd class="value">
						{% include 'lindemannrock-base/_components/status-dot' with {
							value: widgetConfig.isFromConfig() ? 'config' : 'database',
							colorSet: 'configSource',
						} only %}
						<span>{{ widgetConfig.isFromConfig() ? 'Config File'|t('search-manager') : 'Database'|t('search-manager') }}</span>
					</dd>
				</div>
				<div class="data">
					<dt class="heading">{{ 'Handle'|t('search-manager') }}</dt>
					<dd class="value"><code>{{ widgetConfig.handle }}</code></dd>
				</div>
				<div class="data">
					{% set typeLabels = {modal: 'Modal'|t('search-manager'), page: 'Search Page'|t('search-manager'), inline: 'Inline Search'|t('search-manager')} %}
					<dt class="heading">{{ 'Type'|t('search-manager') }}</dt>
					<dd class="value">
						{% include 'lindemannrock-base/_components/status-dot' with {
							value: widgetConfig.type,
							colorSet: 'widgetType',
						} only %}
						<span>{{ typeLabels[widgetConfig.type] ?? widgetConfig.type|capitalize }}</span>
					</dd>
				</div>
				{% if isDefault %}
					<div class="data">
						<dt class="heading">{{ 'Default'|t('search-manager') }}</dt>
						<dd class="value">
							{% include 'lindemannrock-base/_components/status-dot' with {
								value: 'yes',
								colorSet: 'yesNo',
							} only %}
							<span>{{ 'Yes'|t('search-manager') }}</span>
						</dd>
					</div>
				{% endif %}
				{% if not widgetConfig.isFromConfig() %}
					<div class="data">
						<dt class="heading">{{ 'Created at'|t('search-manager') }}</dt>
						<dd class="value">{{ widgetConfig.dateCreated|lrDatetime }}</dd>
					</div>
					<div class="data">
						<dt class="heading">{{ 'Updated at'|t('search-manager') }}</dt>
						<dd class="value">{{ widgetConfig.dateUpdated|lrDatetime }}</dd>
					</div>
				{% endif %}
			</dl>
		</fieldset>
	{% endif %}
{% endblock %}

{% do view.registerAssetBundle('lindemannrock\\searchmanager\\web\\assets\\widgetpreview\\WidgetPreviewAsset') %}

{% js %}
// Set platform-specific keyboard shortcut
const isMac = navigator.platform.toUpperCase().indexOf('MAC') >= 0;
const saveShortcut = document.getElementById('save-shortcut');
if (saveShortcut) {
	saveShortcut.textContent = isMac ? '⌘S' : 'Ctrl+S';
}

// Handle auto-generation from name
(function() {
	const nameInput = document.getElementById('name');
	const handleInput = document.getElementById('handle');
	const isNew = {{ isNew ? 'true' : 'false' }};
	window.lrIdentifiers.bindSlugHandle(nameInput, handleInput, { isNew });
})();

// Sidebar style preset → update preview
(function() {
	const sidebarSelect = document.getElementById('sidebarStylePreset');
	const dataEl = document.getElementById('sidebar-style-data');
	if (!sidebarSelect || !dataEl) return;

	const styleMap = JSON.parse(dataEl.dataset.styleMap || '{}');
	const defaultStyles = JSON.parse(dataEl.dataset.defaultStyles || '{}');

	function applySelectedStyle() {
		const selected = sidebarSelect.value;
		const values = selected && styleMap[selected] ? styleMap[selected] : defaultStyles;
		SearchManagerPreview.applyStyles(values);
	}

	// Apply initial style on load
	applySelectedStyle();

	// Update preview when style changes
	sidebarSelect.addEventListener('change', applySelectedStyle);
})();

// Preview color scheme toggle
SearchManagerPreview.initColorSchemeToggle();

// Live promotion display/text/position sync
SearchManagerPreview.initPromotionPreview();
{% endjs %}
