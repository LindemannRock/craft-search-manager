{% extends 'lindemannrock-base/_layouts/cp-table' %}

{# Follows the canonical CP table index-page pattern (in-memory variant) —
   see plugins/base/docs/template-guides/cp-table-index-pattern.md.
   IndicesController::actionIndex() owns query-param parsing, allowlist
   validation, filter, sort, and pagination. This template stays
   presentational and just renders what's handed in. #}

{% set globalSettings = craft.searchManager.getSettings() %}

{# Build columns array — Analytics column is conditional on the global toggle. #}
{% set columns = [
    {key: 'name', label: 'Name'|t('search-manager'), sortable: true},
    {key: 'handle', label: 'Handle'|t('search-manager'), sortable: true, hideable: true},
    {key: 'elementType', label: 'Element Type'|t('search-manager'), sortable: true, hideable: true},
    {key: 'backend', label: 'Backend'|t('search-manager'), hideable: true},
    {key: 'type', label: 'Type'|t('search-manager'), hideable: true},
    {key: 'craft', label: 'Craft'|t('search-manager'), hideable: true},
    {key: 'indexed', label: 'Indexed'|t('search-manager'), hideable: true},
    {key: 'lastIndexed', label: 'Last Indexed'|t('search-manager'), hideable: true},
    {key: 'source', label: 'Source'|t('search-manager'), sortable: true, hideable: true},
    {key: 'enabled', label: 'Status'|t('search-manager'), sortable: true, hideable: true},
] %}

{% if globalSettings.enableAnalytics %}
    {% set columns = columns|merge([{key: 'analytics', label: 'Analytics'|t('search-manager'), hideable: true}]) %}
{% endif %}

{% set tableConfig = {
    plugin: {
        handle: 'search-manager',
        name: searchHelper.fullName,
    },
    page: {
        title: 'Indices'|t('search-manager'),
        subnav: 'indices',
        crumbs: [
            { label: searchHelper.fullName, url: url('search-manager') },
            { label: 'Indices'|t('search-manager'), url: url('search-manager/indices') }
        ],
    },
    filters: [
        {
            type: 'status',
            param: 'status',
            current: statusFilter,
            label: 'All'|t('search-manager'),
            groups: [
                {
                    param: 'status',
                    current: statusFilter,
                    options: [
                        {value: 'all', label: 'All'|t('search-manager'), status: 'all'},
                        {value: 'enabled', label: 'Enabled'|t('search-manager'), status: 'green'},
                        {value: 'disabled', label: 'Disabled'|t('search-manager'), status: 'disabled'},
                    ],
                },
                {
                    header: 'Config Source'|t('search-manager'),
                    param: 'source',
                    current: sourceFilter,
                    colorSet: 'configSource',
                    options: [
                        {value: 'all', label: 'All Sources'|t('search-manager'), status: 'all'},
                        {value: 'config', label: 'Config File'|t('search-manager'), colorKey: 'config'},
                        {value: 'database', label: 'Database'|t('search-manager'), colorKey: 'database'},
                    ],
                },
                {
                    header: 'Backend'|t('search-manager'),
                    param: 'backend',
                    current: backendFilter,
                    colorSet: 'backendType',
                    options: [
                        {value: 'all', label: 'All Backends'|t('search-manager'), status: 'all'},
                        {value: 'mysql', label: 'MySQL'|t('search-manager'), colorKey: 'mysql'},
                        {value: 'pgsql', label: 'PostgreSQL'|t('search-manager'), colorKey: 'pgsql'},
                        {value: 'file', label: 'File'|t('search-manager'), colorKey: 'file'},
                        {value: 'redis', label: 'Redis'|t('search-manager'), colorKey: 'redis'},
                        {value: 'typesense', label: 'Typesense'|t('search-manager'), colorKey: 'typesense'},
                        {value: 'algolia', label: 'Algolia'|t('search-manager'), colorKey: 'algolia'},
                        {value: 'meilisearch', label: 'Meilisearch'|t('search-manager'), colorKey: 'meilisearch'},
                    ],
                },
            ],
        },
    ],
    search: {
        placeholder: 'Search indices...'|t('search-manager'),
        value: search,
    },
    sort: {
        field: sort,
        direction: dir,
    },
    table: {
        columns: columns,
        items: indices,
        emptyMessage: 'No indices found.'|t('search-manager'),
        hasConfigItems: true,
    },
    pagination: {
        page: page,
        limit: limit,
        totalCount: totalCount,
        itemLabel: {singular: 'index'|t('search-manager'), plural: 'indices'|t('search-manager')},
    },
    checkboxes: canEdit or canDelete,
    newButton: canCreate ?? false ? {
        url: url('search-manager/indices/create'),
        label: 'New Index'|t('search-manager'),
    } : null,
} %}

{% block beforeTable %}
    {% if collisionHandles is defined and collisionHandles|length %}
        {% set boldHandles = [] %}
        {% for handle in collisionHandles %}
            {% set boldHandles = boldHandles|merge(['<strong>' ~ handle|e ~ '</strong>']) %}
        {% endfor %}
        {% set warningMessage %}
        <strong>{{ 'Warning'|t('search-manager') }}:</strong>
        {{ 'These index handles exist in both config/search-manager.php and the database:'|t('search-manager') }} {{ boldHandles|join(', ')|raw }}.
        {{ 'Config takes precedence; database entries with the same handle are ignored.'|t('search-manager') }}
        {{ 'Update your config/search-manager.php or remove the database entries to resolve this.'|t('search-manager') }}
        {% endset %}
        <div class="lr-info-box-table-wrapper">
            {% include 'lindemannrock-base/_components/info-box' with {
                message: warningMessage,
                type: 'warning',
                margin: 'none',
                stretch: true,
            } %}
        </div>
    {% endif %}
{% endblock %}

{% block tableRow %}
    {% set indexBackendType = item.effectiveBackendType %}
    {% set configuredBackend = item.configuredBackend %}

    {# Name #}
    <td data-column="name">
        {% if item.canEdit() %}
            <a class="label-link" href="{{ url('search-manager/indices/edit/' ~ item.id) }}">
                <span>{{ item.name }}</span>
            </a>
        {% else %}
            <a class="label-link" href="{{ url('search-manager/indices/view/' ~ item.handle) }}">
                <span>{{ item.name }}</span>
            </a>
            <span class="lr-config-info-icon" data-config="{{ item.rawConfigDisplay|e('html_attr') }}" data-config-source="config/search-manager.php"></span>
        {% endif %}
    </td>

    {# Handle #}
    <td data-column="handle">
        <code>{{ item.handle }}</code>
    </td>

    {# Element Type #}
    <td data-column="elementType">
        {{ item.elementType|split('\\')|last }}
    </td>

    {# Backend #}
    <td data-column="backend">
        {% if configuredBackend %}
            {% if configuredBackend.source == 'config' %}
                <a href="{{ url('search-manager/backends/view/' ~ configuredBackend.handle) }}">{{ configuredBackend.name }}</a>
            {% else %}
                <a href="{{ url('search-manager/backends/' ~ configuredBackend.id) }}">{{ configuredBackend.name }}</a>
            {% endif %}
        {% elseif indexBackendType %}
            <span class="light">{{ indexBackendType|capitalize }}</span>
        {% else %}
            <span class="light">{{ 'Default'|t('search-manager') }}</span>
        {% endif %}
    </td>

    {# Type (backend badge) #}
    <td data-column="type">
        {% if indexBackendType %}
            {% include 'lindemannrock-base/_components/badge' with {
                label: indexBackendType|upper,
                value: indexBackendType,
                colorSet: 'backendType',
            } only %}
        {% endif %}
    </td>

    {# Craft (expected count) #}
    <td data-column="craft">
        {{ item.expectedCount }}
    </td>

    {# Indexed (document count) #}
    <td data-column="indexed">
        {% set expected = item.expectedCount %}
        {% if item.documentCount == expected %}
            <span class="lr-text-green">{{ item.documentCount }}</span>
        {% elseif item.documentCount < expected %}
            <span class="lr-text-amber" title="{{ expected - item.documentCount }} missing">{{ item.documentCount }}</span>
        {% else %}
            <span class="lr-text-red" title="{{ item.documentCount - expected }} stale">{{ item.documentCount }}</span>
        {% endif %}
    </td>

    {# Last Indexed #}
    <td data-column="lastIndexed">
        {% if item.lastIndexed %}
            {{ item.lastIndexed|lrDatetime }}
        {% else %}
            <span class="light">{{ "Never"|t('search-manager') }}</span>
        {% endif %}
    </td>

    {# Source #}
    <td data-column="source">
        {% include 'lindemannrock-base/_components/badge' with {
            label: item.source == 'config' ? 'Config'|t('search-manager') : 'Database'|t('search-manager'),
            value: item.source == 'config' ? 'config' : 'database',
            colorSet: 'configSource',
        } only %}
    </td>

    {# Status #}
    <td data-column="enabled">
        {% include 'lindemannrock-base/_components/badge' with {
            label: item.enabled ? 'Enabled'|t('search-manager') : 'Disabled'|t('search-manager'),
            value: item.enabled ? 'enabled' : 'disabled',
            colorSet: 'status',
        } only %}
    </td>

    {# Analytics (conditional) #}
    {% if globalSettings.enableAnalytics %}
        <td data-column="analytics">
            {% include 'lindemannrock-base/_components/badge' with {
                label: item.enableAnalytics ? 'Enabled'|t('search-manager') : 'Disabled'|t('search-manager'),
                value: item.enableAnalytics ? 'enabled' : 'disabled',
                colorSet: 'status',
            } only %}
        </td>
    {% endif %}
{% endblock %}

{% block rowActions %}
    {% set indexBackendType = item.effectiveBackendType %}
    {% set itemId = item.id ?: item.handle %}

    {% set actionItems = [] %}

    {% if item.canEdit() %}
        {% set actionItems = actionItems|merge([{
            label: 'Edit'|t('search-manager'),
            url: url('search-manager/indices/edit/' ~ item.id),
            permission: 'searchManager:editIndices',
        }]) %}
    {% else %}
        {% set actionItems = actionItems|merge([{
            label: 'View'|t('search-manager'),
            url: url('search-manager/indices/view/' ~ item.handle),
        }]) %}
    {% endif %}

    {% set actionItems = actionItems|merge([
        {type: 'divider'},
        {
            label: 'Rebuild Index'|t('search-manager'),
            jsAction: 'rebuild',
            data: {name: item.name},
            permission: 'searchManager:rebuildIndices',
        },
        {
            label: 'Sync Count from Backend'|t('search-manager'),
            jsAction: 'sync-count',
            data: {name: item.name},
            showIf: indexBackendType in ['algolia', 'meilisearch', 'typesense'],
            permission: 'searchManager:rebuildIndices',
        },
        {
            label: 'Clear Index Data'|t('search-manager') ~ ' (' ~ item.documentCount|number_format ~ ')',
            jsAction: 'clear',
            data: {name: item.name},
            permission: 'searchManager:clearIndices',
        },
        {
            label: 'Clear Index Cache'|t('search-manager'),
            jsAction: 'clear-cache',
            data: {name: item.name},
            showIf: globalSettings.enableCache or globalSettings.enableAutocompleteCache,
            permission: 'searchManager:clearCache',
        },
        {type: 'divider'},
        {
            label: 'Delete Index'|t('search-manager'),
            class: 'error',
            jsAction: 'delete',
            data: {name: item.name},
            showIf: item.canEdit(),
            permission: 'searchManager:deleteIndices',
        },
    ]) %}

    {% include 'lindemannrock-base/_components/row-actions' with {
        item: {id: itemId},
        actions: {
            type: 'menu',
            icon: 'settings',
            title: 'Actions'|t('search-manager'),
            items: actionItems,
        },
    } only %}
{% endblock %}

{% block bulkActions %}
    {% if canEdit %}
        <button type="button" class="btn menubtn secondary" id="lr-bulk-status-btn">
            {{ 'Set status'|t('search-manager') }}
        </button>
        <div class="menu">
            <ul>
                <li><a id="lr-bulk-enable-action">{{ 'Enable'|t('search-manager') }}</a></li>
                <li><a id="lr-bulk-disable-action">{{ 'Disable'|t('search-manager') }}</a></li>
            </ul>
        </div>
    {% endif %}

    {% if canDelete %}
        <button type="button" class="btn secondary" id="lr-bulk-delete-btn">
            {{ 'Delete'|t('search-manager') }} (<span class="lr-bulk-count">0</span>)
        </button>
    {% endif %}
{% endblock %}

{% block scripts %}
<script>
(function() {
    if (typeof Craft === 'undefined') return;

    const bulkStatusBtn = document.getElementById('lr-bulk-status-btn');
    if (bulkStatusBtn && Craft.MenuBtn) {
        new Craft.MenuBtn(bulkStatusBtn);
    }

    const T = {
        rebuildQueued: {{ 'Index rebuild queued'|t('search-manager')|json_encode|raw }},
        rebuildFailed: {{ 'Failed to queue index rebuild'|t('search-manager')|json_encode|raw }},
        cleared: {{ 'Index data cleared'|t('search-manager')|json_encode|raw }},
        clearFailed: {{ 'Failed to clear index data'|t('search-manager')|json_encode|raw }},
        clearConfirm: {{ 'Clear all data from index "{name}"? This cannot be undone.'|t('search-manager')|json_encode|raw }},
        cacheClearConfirm: {{ 'Clear cached search results and autocomplete suggestions for "{name}"?'|t('search-manager')|json_encode|raw }},
        cacheClearFailedTemplate: {{ 'Failed to clear cache for "{name}"'|t('search-manager')|json_encode|raw }},
        deleted: {{ 'Index deleted'|t('search-manager')|json_encode|raw }},
        deleteFailed: {{ 'Failed to delete index'|t('search-manager')|json_encode|raw }},
        deleteConfirm: {{ 'Delete index "{name}"? This will remove the index and all its data.'|t('search-manager')|json_encode|raw }},
        syncFailedTemplate: {{ 'Failed to sync count for "{name}"'|t('search-manager')|json_encode|raw }},
        bulkEnabledTemplate: {{ 'Enabled {count} indices'|t('search-manager')|json_encode|raw }},
        bulkEnableFailed: {{ 'Failed to enable indices'|t('search-manager')|json_encode|raw }},
        bulkDisabledTemplate: {{ 'Disabled {count} indices'|t('search-manager')|json_encode|raw }},
        bulkDisableFailed: {{ 'Failed to disable indices'|t('search-manager')|json_encode|raw }},
        bulkDeletedTemplate: {{ 'Deleted {count} indices'|t('search-manager')|json_encode|raw }},
        bulkDeleteFailed: {{ 'Failed to delete indices'|t('search-manager')|json_encode|raw }},
        bulkDeleteConfirmTemplate: {{ 'Delete {count} index(es)? This cannot be undone.'|t('search-manager')|json_encode|raw }},
    };

    document.addEventListener('lr:selectionChanged', function(e) {
        const ids = (e.detail && Array.isArray(e.detail.selectedIds))
            ? e.detail.selectedIds
            : [];
        document.querySelectorAll('.lr-bulk-count').forEach(function(el) {
            el.textContent = ids.length;
        });
    });

    function selectedIds() {
        return window.lrTableSelection ? window.lrTableSelection.getSelectedIds() : [];
    }

    // ---------------------------------------------------------------------
    // Row-action handler — delegated on document, narrowed by anchor +
    // action name. preventDefault after match. Replaces the previous
    // broad-selector (Smell A) implementation. See cp-table-index-pattern.md.
    // ---------------------------------------------------------------------
    document.addEventListener('click', function(e) {
        const trigger = e.target.closest('a[data-action]');
        if (!trigger) return;

        const action = trigger.dataset.action;
        if (
            action !== 'rebuild' &&
            action !== 'clear' &&
            action !== 'clear-cache' &&
            action !== 'delete' &&
            action !== 'sync-count'
        ) return;

        const indexId = trigger.dataset.id;
        const indexName = trigger.dataset.name || '';
        if (!indexId) return;
        e.preventDefault();

        if (action === 'rebuild') {
            Craft.sendActionRequest('POST', 'search-manager/indices/rebuild', {
                data: { indexId: indexId },
            }).then(function(response) {
                Craft.cp.displayNotice(response.data.message || T.rebuildQueued);
                setTimeout(function() { window.location.reload(); }, 1000);
            }).catch(function() {
                Craft.cp.displayError(T.rebuildFailed);
            });
        } else if (action === 'clear') {
            if (!confirm(T.clearConfirm.replace('{name}', indexName))) return;
            Craft.sendActionRequest('POST', 'search-manager/indices/clear', {
                data: { indexId: indexId },
            }).then(function(response) {
                Craft.cp.displayNotice(response.data.message || T.cleared);
                setTimeout(function() { window.location.reload(); }, 1000);
            }).catch(function() {
                Craft.cp.displayError(T.clearFailed);
            });
        } else if (action === 'clear-cache') {
            if (!confirm(T.cacheClearConfirm.replace('{name}', indexName))) return;
            Craft.sendActionRequest('POST', 'search-manager/indices/clear-cache', {
                data: { indexId: indexId },
            }).then(function(response) {
                if (response.data.success) {
                    Craft.cp.displayNotice(response.data.message);
                } else {
                    Craft.cp.displayError(response.data.error || T.cacheClearFailedTemplate.replace('{name}', indexName));
                }
            }).catch(function() {
                Craft.cp.displayError(T.cacheClearFailedTemplate.replace('{name}', indexName));
            });
        } else if (action === 'delete') {
            if (!confirm(T.deleteConfirm.replace('{name}', indexName))) return;
            Craft.sendActionRequest('POST', 'search-manager/indices/delete', {
                data: { indexId: indexId },
            }).then(function(response) {
                if (response.data && response.data.success === false) {
                    Craft.cp.displayError(response.data.error || T.deleteFailed);
                    return;
                }
                Craft.cp.displayNotice((response.data && response.data.message) || T.deleted);
                setTimeout(function() { window.location.reload(); }, 1000);
            }).catch(function() {
                Craft.cp.displayError(T.deleteFailed);
            });
        } else if (action === 'sync-count') {
            Craft.sendActionRequest('POST', 'search-manager/indices/sync-count', {
                data: { indexId: indexId },
            }).then(function(response) {
                if (response.data.success) {
                    Craft.cp.displayNotice(response.data.message);
                    setTimeout(function() { window.location.reload(); }, 1000);
                } else {
                    Craft.cp.displayError(response.data.error || T.syncFailedTemplate.replace('{name}', indexName));
                }
            }).catch(function() {
                Craft.cp.displayError(T.syncFailedTemplate.replace('{name}', indexName));
            });
        }
    });

    function runBulk(endpoint, successTemplate, errorFallback) {
        const ids = selectedIds();
        if (!ids.length) return;
        Craft.sendActionRequest('POST', endpoint, {
            data: { indexIds: ids },
        }).then(function(response) {
            const count = response.data.count || 0;
            if (count > 0) {
                Craft.cp.displayNotice(successTemplate.replace('{count}', count));
                setTimeout(function() { window.location.reload(); }, 1000);
            }
        }).catch(function() {
            Craft.cp.displayError(errorFallback);
        });
    }

    document.getElementById('lr-bulk-enable-action')?.addEventListener('click', function(e) {
        e.preventDefault();
        runBulk('search-manager/indices/bulk-enable', T.bulkEnabledTemplate, T.bulkEnableFailed);
    });

    document.getElementById('lr-bulk-disable-action')?.addEventListener('click', function(e) {
        e.preventDefault();
        runBulk('search-manager/indices/bulk-disable', T.bulkDisabledTemplate, T.bulkDisableFailed);
    });

    document.getElementById('lr-bulk-delete-btn')?.addEventListener('click', function() {
        const ids = selectedIds();
        if (!ids.length) return;
        if (!confirm(T.bulkDeleteConfirmTemplate.replace('{count}', ids.length))) return;
        runBulk('search-manager/indices/bulk-delete', T.bulkDeletedTemplate, T.bulkDeleteFailed);
    });

    const collisionHandles = {{ collisionHandles is defined ? collisionHandles|json_encode|raw : '[]' }};
    if (collisionHandles.length > 0) {
        document.querySelectorAll('#lr-data-table tbody tr.lr-data-row').forEach(function(row) {
            const handleCell = row.querySelector('td[data-column="handle"] code');
            if (handleCell && collisionHandles.includes(handleCell.textContent.trim())) {
                row.classList.add('lr-row--warning');
            }
        });
    }
})();
</script>
{% endblock %}
