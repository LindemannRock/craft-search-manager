{#
/**
 * Search Manager - Search Modal Widget (Refactored)
 *
 * Include this in your templates to add a CMD+K style search modal.
 * Uses the new refactored SearchModalWidget architecture.
 *
 * Usage:
 * {% include 'search-manager/_widget/search-modal' %}
 *
 * With a named config:
 * {% include 'search-manager/_widget/search-modal' with {
 *     configHandle: 'homepage',
 * } %}
 *
 * With inline overrides:
 * {% include 'search-manager/_widget/search-modal' with {
 *     configHandle: 'homepage',
 *     indexHandles: ['blog', 'products'], // or 'blog,products'
 *     placeholder: 'Search articles...',
 *     theme: 'dark',
 * } %}
 *
 * @link https://lindemannrock.com
 * @copyright Copyright (c) 2025 LindemannRock
 */
#}

{# ============================================================================
   Boolean normalizer - handles true/false, 1/0, on/off, yes/no
   ============================================================================ #}
{% macro toBool(value, default) %}
    {%- set normalized = value is string ? value|trim|lower : value -%}
    {%- if value is same as(true) or value is same as(1) or normalized in ['true', '1', 'on', 'yes'] -%}
        true
    {%- elseif value is same as(false) or value is same as(0) or normalized in ['false', '0', 'off', 'no'] -%}
        false
    {%- else -%}
        {{ default ? 'true' : 'false' }}
    {%- endif -%}
{% endmacro %}

{# Get plugin instance and widget config #}
{% set plugin = craft.app.plugins.getPlugin('search-manager') %}
{% set widgetConfig = plugin.widgetConfigs.getConfigForWidget(configHandle ?? null) %}

{# Search settings - support indexHandles as an array or comma-separated string #}
{% if indexHandles is defined and indexHandles is iterable %}
    {% set selectedIndexHandles = indexHandles %}
{% elseif indexHandles is defined and indexHandles %}
    {% set selectedIndexHandles = indexHandles|split(',')|map(handle => handle|trim)|filter(handle => handle) %}
{% else %}
    {% set selectedIndexHandles = widgetConfig.getIndexHandles() %}
{% endif %}

{% set placeholder = placeholder ?? widgetConfig.getPlaceholder()|t('search-manager') %}
{% set theme = theme ?? 'light' %}
{% set siteId = siteId ?? '' %}
{% set cssClass = cssClass ?? '' %}
{% set dir = dir ?? (craft.app.locale.getOrientation() == 'rtl' ? 'rtl' : 'ltr') %}

{# Behavior settings - use inline param override or fall back to widget config #}
{% set resultsLimit = resultsLimit ?? widgetConfig.getResultsLimit() %}
{% set searchDebounceMs = searchDebounceMs ?? widgetConfig.getSearchDebounceMs() %}
{% set searchMinChars = searchMinChars ?? widgetConfig.getSearchMinChars() %}
{% set recentSearchesEnabled = recentSearchesEnabled ?? widgetConfig.isRecentSearchesEnabled() %}
{% set recentSearchesLimit = recentSearchesLimit ?? widgetConfig.getRecentSearchesLimit() %}
{% set resultsGroupingEnabled = resultsGroupingEnabled ?? widgetConfig.isResultsGroupingEnabled() %}
{% set triggerHotkey = triggerHotkey ?? widgetConfig.getTriggerHotkey() %}
{% set resultsRequireUrl = resultsRequireUrl ?? widgetConfig.isResultsRequireUrlEnabled() %}
{% set snippetIncludeCodeBlocks = snippetIncludeCodeBlocks ?? widgetConfig.isSnippetIncludeCodeBlocksEnabled() %}
{% set snippetMode = snippetMode ?? widgetConfig.getSnippetMode() %}
{% set highlightDestinationEnabled = highlightDestinationEnabled ?? widgetConfig.isHighlightDestinationEnabled() %}
{% set highlightDestinationPersistQuery = highlightDestinationPersistQuery ?? widgetConfig.isHighlightDestinationPersistQueryEnabled() %}
{% set highlightDestinationQueryParam = highlightDestinationQueryParam ?? widgetConfig.getHighlightDestinationQueryParam() %}
{% set highlightDestinationContentSelector = highlightDestinationContentSelector ?? widgetConfig.getHighlightDestinationContentSelector() %}

{# Trigger settings #}
{% set triggerEnabled = triggerEnabled ?? widgetConfig.isTriggerEnabled() %}
{% set triggerLabel = triggerLabel ?? widgetConfig.getTriggerLabel()|t('search-manager') %}
{% set triggerSelector = triggerSelector ?? '' %}

{# Analytics settings — forwarded to the web component as HTML attributes #}
{% set analyticsSource = analyticsSource ?? widgetConfig.getAnalyticsSource() %}
{% set analyticsIdleTimeoutMs = analyticsIdleTimeoutMs ?? widgetConfig.getAnalyticsIdleTimeoutMs() %}

{# Public API key — render-time override wins over the saved widget setting.
   Sent as the X-Search-Manager-Key header by the widget when requireApiKey is on. #}
{% set apiKey = apiKey ?? widgetConfig.getApiKey() %}
{% set apiKey = apiKey is string and apiKey|trim starts with 'sm_pub_' ? apiKey|trim : '' %}

{# Resolve render styles first (needed for highlighting/backdrop defaults) #}
{% set styleOverrides = styles is defined and styles is iterable ? styles : {} %}
{% set resolvedStyles = widgetConfig.getStylesForRender(styleOverrides) %}

{# Highlighting settings - from style preset, with inline override support #}
{% set highlightResultsEnabled = highlightResultsEnabled ?? (resolvedStyles.highlightResultsEnabled ?? '1') %}
{% set highlightTag = highlightTag ?? (resolvedStyles.highlightTag is defined and resolvedStyles.highlightTag ? resolvedStyles.highlightTag : 'mark') %}
{% set highlightClass = highlightClass ?? (resolvedStyles.highlightClass ?? '') %}

{# Backdrop settings - from style preset, with inline override support #}
{% set modalBackdropOpacity = modalBackdropOpacity ?? (resolvedStyles.backdropOpacity ?? 50) %}
{% set modalBackdropBlurEnabled = modalBackdropBlurEnabled ?? (resolvedStyles.backdropBlur ?? '1') %}
{% set modalPreventBodyScroll = modalPreventBodyScroll ?? widgetConfig.isModalPreventBodyScrollEnabled() %}

{# Loading indicator - shows spinner during search (defaults to true) #}
{% set loadingIndicatorEnabled = loadingIndicatorEnabled ?? widgetConfig.isLoadingIndicatorEnabled() %}

{# Debug mode - shows index handle, score, element ID for each result #}
{% set debugEnabled = debugEnabled ?? false %}

{# Hierarchical display - parent results with optional heading children #}
{% set resultsLayout = resultsLayout ?? widgetConfig.getResultsLayout() %}
{% set hierarchyGroupBy = hierarchyGroupBy ?? widgetConfig.getHierarchyGroupBy() %}
{% set hierarchyStyle = hierarchyStyle ?? widgetConfig.getHierarchyStyle() %}
{% set hierarchyDisplay = hierarchyDisplay ?? widgetConfig.getHierarchyDisplay() %}
{% set hierarchyMaxHeadings = hierarchyMaxHeadings ?? widgetConfig.getHierarchyMaxHeadings() %}
{% set resultsTitleLines = resultsTitleLines ?? widgetConfig.getResultsTitleLines() %}
{% set resultsDescriptionLines = resultsDescriptionLines ?? widgetConfig.getResultsDescriptionLines() %}
{% set snippetMaxLength = snippetMaxLength ?? widgetConfig.getSnippetMaxLength() %}
{% set snippetCleanMarkdown = snippetCleanMarkdown ?? widgetConfig.isSnippetCleanMarkdownEnabled() %}
{% set snippetDefaults = widgetConfig.getSnippetDefaults() %}

{% set widgetTranslations = {
    'Search': 'Search'|t('search-manager'),
    'Close search': 'Close search'|t('search-manager'),
    'Search results': 'Search results'|t('search-manager'),
    'navigate': 'navigate'|t('search-manager'),
    'select': 'select'|t('search-manager'),
    'close': 'close'|t('search-manager'),
    'Powered by': 'Powered by'|t('search-manager'),
    'Untitled': 'Untitled'|t('search-manager'),
    'Recent searches': 'Recent searches'|t('search-manager'),
    'Clear': 'Clear'|t('search-manager'),
    'Start typing to search': 'Start typing to search'|t('search-manager'),
    'No results for "{query}"': 'No results for "{query}"'|t('search-manager'),
    'Searching...': 'Searching...'|t('search-manager'),
    'Search failed.': 'Search failed.'|t('search-manager'),
    'No results found for "{query}"': 'No results found for "{query}"'|t('search-manager'),
    '1 result found for "{query}"': '1 result found for "{query}"'|t('search-manager'),
    '{count} results found for "{query}"': '{count} results found for "{query}"'|t('search-manager'),
    'No recent searches': 'No recent searches'|t('search-manager'),
    '1 recent search available': '1 recent search available'|t('search-manager'),
    '{count} recent searches available': '{count} recent searches available'|t('search-manager'),
    'results': 'results'|t('search-manager'),
    'time': 'time'|t('search-manager'),
    'cache': 'cache'|t('search-manager'),
    'off': 'off'|t('search-manager'),
    'hit': 'hit'|t('search-manager'),
    'miss': 'miss'|t('search-manager'),
    'storage': 'storage'|t('search-manager'),
    '{count} indices': '{count} indices'|t('search-manager'),
    'indices': 'indices'|t('search-manager'),
    'synonyms': 'synonyms'|t('search-manager'),
    'rules': 'rules'|t('search-manager'),
    'promoted': 'promoted'|t('search-manager'),
    'Debug': 'Debug'|t('search-manager'),
    'Collapse debug panel': 'Collapse debug panel'|t('search-manager'),
    'index': 'index'|t('search-manager'),
    'backend': 'backend'|t('search-manager'),
    'element': 'element'|t('search-manager'),
    'score': 'score'|t('search-manager'),
    'site': 'site'|t('search-manager'),
    'lang': 'lang'|t('search-manager'),
    'matched': 'matched'|t('search-manager'),
    'yes': 'yes'|t('search-manager'),
    'boosted': 'boosted'|t('search-manager'),
    'h': 'h'|t('search-manager'),
    'anchor': 'anchor'|t('search-manager'),
    'parent': 'parent'|t('search-manager'),
    'Search requires an API key.': 'Search requires an API key.'|t('search-manager'),
    'This API key cannot access this search.': 'This API key cannot access this search.'|t('search-manager'),
    'Search rate limit exceeded. Try again in a moment.': 'Search rate limit exceeded. Try again in a moment.'|t('search-manager'),
} %}

{# Merged styles already resolved above (resolvedStyles) #}
{% set mergedStyles = resolvedStyles %}

{# Register the bundled SearchModalWidget JS #}
{% do view.registerJsFile(craft.app.assetManager.getPublishedUrl('@searchmanager/web/assets/searchwidget/dist', true) ~ '/SearchModalWidget.js', {
    position: 3
}) %}

{# Render the widget #}
<search-modal
    {% if selectedIndexHandles|length %}index-handles="{{ selectedIndexHandles|join(',') }}"{% endif %}
    placeholder="{{ placeholder }}"
    theme="{{ theme }}"
    results-limit="{{ resultsLimit }}"
    search-debounce-ms="{{ searchDebounceMs }}"
    search-min-chars="{{ searchMinChars }}"
    recent-searches-enabled="{{ _self.toBool(recentSearchesEnabled, widgetConfig.isRecentSearchesEnabled()) }}"
    recent-searches-limit="{{ recentSearchesLimit }}"
    results-grouping-enabled="{{ _self.toBool(resultsGroupingEnabled, widgetConfig.isResultsGroupingEnabled()) }}"
    trigger-hotkey="{{ triggerHotkey }}"
    results-require-url="{{ _self.toBool(resultsRequireUrl, widgetConfig.isResultsRequireUrlEnabled()) }}"
    snippet-include-code-blocks="{{ _self.toBool(snippetIncludeCodeBlocks, widgetConfig.isSnippetIncludeCodeBlocksEnabled()) }}"
    snippet-mode="{{ snippetMode }}"
    snippet-defaults="{{ snippetDefaults|json_encode|e('html_attr') }}"
    highlight-destination-persist-query="{{ _self.toBool(highlightDestinationPersistQuery, true) }}"
    highlight-destination-query-param="{{ highlightDestinationQueryParam|e('html_attr') }}"
    highlight-destination-enabled="{{ _self.toBool(highlightDestinationEnabled, true) }}"
    highlight-destination-content-selector="{{ highlightDestinationContentSelector|e('html_attr') }}"
    {% if siteId %}site-id="{{ siteId }}"{% endif %}
    {% if cssClass %}class="{{ cssClass }}"{% endif %}
    {% if apiKey %}api-key="{{ apiKey|e('html_attr') }}"{% endif %}
    {% if analyticsSource %}analytics-source="{{ analyticsSource|e('html_attr') }}"{% endif %}
    analytics-idle-timeout-ms="{{ analyticsIdleTimeoutMs }}"
    dir="{{ dir }}"
    highlight-results-enabled="{{ _self.toBool(highlightResultsEnabled, true) }}"
    highlight-tag="{{ highlightTag|e('html_attr') }}"
    {% if highlightClass %}highlight-class="{{ highlightClass|e('html_attr') }}"{% endif %}
    modal-backdrop-opacity="{{ modalBackdropOpacity }}"
    modal-backdrop-blur-enabled="{{ _self.toBool(modalBackdropBlurEnabled, true) }}"
    modal-prevent-body-scroll="{{ _self.toBool(modalPreventBodyScroll, widgetConfig.isModalPreventBodyScrollEnabled()) }}"
    trigger-enabled="{{ _self.toBool(triggerEnabled, widgetConfig.isTriggerEnabled()) }}"
    trigger-label="{{ triggerLabel|e('html_attr') }}"
    {% if triggerSelector %}trigger-selector="{{ triggerSelector }}"{% endif %}
    styles="{{ mergedStyles|json_encode|e('html_attr') }}"
    translations="{{ widgetTranslations|json_encode|e('html_attr') }}"
    loading-indicator-enabled="{{ _self.toBool(loadingIndicatorEnabled, true) }}"
    debug-enabled="{{ _self.toBool(debugEnabled, false) }}"
    {% if resultsLayout != 'default' %}results-layout="{{ resultsLayout }}"{% endif %}
    {% if hierarchyGroupBy %}hierarchy-group-by="{{ hierarchyGroupBy }}"{% endif %}
    {% if hierarchyStyle != 'tree' %}hierarchy-style="{{ hierarchyStyle }}"{% endif %}
    {% if hierarchyDisplay != 'individual' %}hierarchy-display="{{ hierarchyDisplay }}"{% endif %}
    hierarchy-max-headings="{{ hierarchyMaxHeadings }}"
    results-title-lines="{{ resultsTitleLines }}"
    results-description-lines="{{ resultsDescriptionLines }}"
    snippet-max-length="{{ snippetMaxLength }}"
    snippet-clean-markdown="{{ _self.toBool(snippetCleanMarkdown, false) }}"
></search-modal>
