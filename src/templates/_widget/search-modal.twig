{#
/**
 * Search Manager - Search Modal Widget (Refactored)
 *
 * Include this in your templates to add a CMD+K style search modal.
 * Uses the new refactored SearchModalWidget architecture.
 *
 * Usage:
 * {% include 'search-manager/_widget/search-modal' %}
 *
 * With a named config:
 * {% include 'search-manager/_widget/search-modal' with {
 *     config: 'homepage',
 * } %}
 *
 * With inline overrides:
 * {% include 'search-manager/_widget/search-modal' with {
 *     config: 'homepage',
 *     indices: ['blog', 'products'], // or 'blog,products'
 *     placeholder: 'Search articles...',
 *     theme: 'dark',
 * } %}
 *
 * @link https://lindemannrock.com
 * @copyright Copyright (c) 2025 LindemannRock
 */
#}

{# ============================================================================
   Boolean normalizer - handles true/false, 1/0, on/off, yes/no
   ============================================================================ #}
{% macro toBool(value, default) %}
    {%- set normalized = value is string ? value|trim|lower : value -%}
    {%- if value is same as(true) or value is same as(1) or normalized in ['true', '1', 'on', 'yes'] -%}
        true
    {%- elseif value is same as(false) or value is same as(0) or normalized in ['false', '0', 'off', 'no'] -%}
        false
    {%- else -%}
        {{ default ? 'true' : 'false' }}
    {%- endif -%}
{% endmacro %}

{# Get plugin instance and widget config #}
{% set plugin = craft.app.plugins.getPlugin('search-manager') %}
{% set widgetConfig = plugin.widgetConfigs.getConfigForWidget(config ?? null) %}

{# Search settings - support indices as an array or comma-separated string #}
{% if indices is defined and indices is iterable %}
    {% set indexHandles = indices %}
{% elseif indices is defined and indices %}
    {% set indexHandles = indices|split(',')|map(handle => handle|trim)|filter(handle => handle) %}
{% else %}
    {% set indexHandles = widgetConfig.getIndexHandles() %}
{% endif %}

{% set placeholder = placeholder ?? widgetConfig.getPlaceholder()|t('search-manager') %}
{% set theme = theme ?? 'light' %}
{% set siteId = siteId ?? '' %}
{% set class = class ?? '' %}
{% set dir = dir ?? (craft.app.locale.getOrientation() == 'rtl' ? 'rtl' : 'ltr') %}

{# Behavior settings - use inline param override or fall back to widget config #}
{% set maxResults = maxResults ?? widgetConfig.getMaxResults() %}
{% set debounce = debounce ?? widgetConfig.getDebounce() %}
{% set minChars = minChars ?? widgetConfig.getMinChars() %}
{% set showRecent = showRecent ?? widgetConfig.isShowRecentEnabled() %}
{% set maxRecentSearches = maxRecentSearches ?? widgetConfig.getMaxRecentSearches() %}
{% set groupResults = groupResults ?? widgetConfig.isGroupResultsEnabled() %}
{% set hotkey = hotkey ?? widgetConfig.getHotkey() %}
{% set hideResultsWithoutUrl = hideResultsWithoutUrl ?? widgetConfig.isHideResultsWithoutUrlEnabled() %}
{% set showCodeSnippets = showCodeSnippets ?? widgetConfig.isShowCodeSnippetsEnabled() %}
{% set snippetMode = snippetMode ?? widgetConfig.getSnippetMode() %}
{% set highlightDestinationPage = highlightDestinationPage ?? widgetConfig.isHighlightDestinationPageEnabled() %}
{% set persistQueryInUrl = persistQueryInUrl ?? widgetConfig.isPersistQueryInUrlEnabled() %}
{% set queryParamName = queryParamName ?? widgetConfig.getQueryParamName() %}
{% set destinationHighlightSelector = destinationHighlightSelector ?? widgetConfig.getDestinationHighlightSelector() %}

{# Trigger settings #}
{% set showTrigger = showTrigger ?? widgetConfig.isShowTriggerEnabled() %}
{% set triggerText = triggerText ?? widgetConfig.getTriggerText()|t('search-manager') %}
{% set triggerSelector = triggerSelector ?? '' %}

{# Analytics settings — forwarded to the web component as HTML attributes #}
{% set source = source ?? widgetConfig.getAnalyticsSource() %}
{% set idleTimeout = idleTimeout ?? widgetConfig.getIdleTimeout() %}

{# Public API key — render-time override wins over the saved widget setting.
   Sent as the X-Search-Manager-Key header by the widget when requireApiKey is on. #}
{% set apiKey = apiKey ?? widgetConfig.getApiKey() %}
{% set apiKey = apiKey is string and apiKey|trim starts with 'sm_pub_' ? apiKey|trim : '' %}

{# Resolve render styles first (needed for highlighting/backdrop defaults) #}
{% set styleOverrides = styles is defined and styles is iterable ? styles : {} %}
{% set resolvedStyles = widgetConfig.getStylesForRender(styleOverrides) %}

{# Highlighting settings - from style preset, with inline override support #}
{% set enableHighlighting = enableHighlighting ?? (resolvedStyles.highlightEnabled ?? '1') %}
{% set highlightTag = highlightTag ?? (resolvedStyles.highlightTag is defined and resolvedStyles.highlightTag ? resolvedStyles.highlightTag : 'mark') %}
{% set highlightClass = highlightClass ?? (resolvedStyles.highlightClass ?? '') %}

{# Backdrop settings - from style preset, with inline override support #}
{% set backdropOpacity = backdropOpacity ?? (resolvedStyles.backdropOpacity ?? 50) %}
{% set enableBackdropBlur = enableBackdropBlur ?? (resolvedStyles.backdropBlur ?? '1') %}
{% set preventBodyScroll = preventBodyScroll ?? widgetConfig.isPreventBodyScrollEnabled() %}

{# Loading indicator - shows spinner during search (defaults to true) #}
{% set showLoadingIndicator = showLoadingIndicator ?? widgetConfig.isShowLoadingIndicatorEnabled() %}

{# Debug mode - shows index handle, score, element ID for each result #}
{% set debug = debug ?? false %}

{# Hierarchical display - Algolia DocSearch-style grouped results with heading children #}
{% set resultLayout = resultLayout ?? widgetConfig.getResultLayout() %}
{% set hierarchyGroupBy = hierarchyGroupBy ?? widgetConfig.getHierarchyGroupBy() %}
{% set hierarchyStyle = hierarchyStyle ?? widgetConfig.getHierarchyStyle() %}
{% set hierarchyDisplay = hierarchyDisplay ?? widgetConfig.getHierarchyDisplay() %}
{% set maxHeadingsPerResult = maxHeadingsPerResult ?? widgetConfig.getMaxHeadingsPerResult() %}
{% set resultTitleLines = resultTitleLines ?? widgetConfig.getResultTitleLines() %}
{% set resultDescLines = resultDescLines ?? widgetConfig.getResultDescLines() %}
{% set snippetLength = snippetLength ?? widgetConfig.getSnippetLength() %}
{% set parseMarkdownSnippets = parseMarkdownSnippets ?? widgetConfig.isParseMarkdownSnippetsEnabled() %}
{% set snippetDefaults = widgetConfig.getSnippetDefaults() %}

{# Merged styles already resolved above (resolvedStyles) #}
{% set mergedStyles = resolvedStyles %}

{# Register the bundled SearchModalWidget JS #}
{% do view.registerJsFile(craft.app.assetManager.getPublishedUrl('@searchmanager/web/assets/searchwidget/dist', true) ~ '/SearchModalWidget.js', {
    position: 3
}) %}

{# Render the widget #}
<search-modal
    {% if indexHandles|length %}indices="{{ indexHandles|join(',') }}"{% endif %}
    placeholder="{{ placeholder }}"
    theme="{{ theme }}"
    max-results="{{ maxResults }}"
    debounce="{{ debounce }}"
    min-chars="{{ minChars }}"
    show-recent="{{ _self.toBool(showRecent, widgetConfig.isShowRecentEnabled()) }}"
    max-recent-searches="{{ maxRecentSearches }}"
    group-results="{{ _self.toBool(groupResults, widgetConfig.isGroupResultsEnabled()) }}"
    hotkey="{{ hotkey }}"
    hide-results-without-url="{{ _self.toBool(hideResultsWithoutUrl, widgetConfig.isHideResultsWithoutUrlEnabled()) }}"
    show-code-snippets="{{ _self.toBool(showCodeSnippets, widgetConfig.isShowCodeSnippetsEnabled()) }}"
    snippet-mode="{{ snippetMode }}"
    snippet-defaults="{{ snippetDefaults|json_encode|e('html_attr') }}"
    persist-query-in-url="{{ _self.toBool(persistQueryInUrl, true) }}"
    query-param-name="{{ queryParamName|e('html_attr') }}"
    highlight-destination-page="{{ _self.toBool(highlightDestinationPage, true) }}"
    destination-highlight-selector="{{ destinationHighlightSelector|e('html_attr') }}"
    {% if siteId %}site-id="{{ siteId }}"{% endif %}
    {% if class %}class="{{ class }}"{% endif %}
    {% if apiKey %}api-key="{{ apiKey|e('html_attr') }}"{% endif %}
    {% if source %}source="{{ source|e('html_attr') }}"{% endif %}
    idle-timeout="{{ idleTimeout }}"
    dir="{{ dir }}"
    enable-highlighting="{{ _self.toBool(enableHighlighting, true) }}"
    highlight-tag="{{ highlightTag|e('html_attr') }}"
    {% if highlightClass %}highlight-class="{{ highlightClass|e('html_attr') }}"{% endif %}
    backdrop-opacity="{{ backdropOpacity }}"
    enable-backdrop-blur="{{ _self.toBool(enableBackdropBlur, true) }}"
    prevent-body-scroll="{{ _self.toBool(preventBodyScroll, widgetConfig.isPreventBodyScrollEnabled()) }}"
    show-trigger="{{ _self.toBool(showTrigger, widgetConfig.isShowTriggerEnabled()) }}"
    {% if triggerSelector %}trigger-selector="{{ triggerSelector }}"{% endif %}
    styles="{{ mergedStyles|json_encode|e('html_attr') }}"
    show-loading-indicator="{{ _self.toBool(showLoadingIndicator, true) }}"
    debug="{{ _self.toBool(debug, false) }}"
    {% if resultLayout != 'default' %}result-layout="{{ resultLayout }}"{% endif %}
    {% if hierarchyGroupBy %}hierarchy-group-by="{{ hierarchyGroupBy }}"{% endif %}
    {% if hierarchyStyle != 'tree' %}hierarchy-style="{{ hierarchyStyle }}"{% endif %}
    {% if hierarchyDisplay != 'individual' %}hierarchy-display="{{ hierarchyDisplay }}"{% endif %}
    max-headings-per-result="{{ maxHeadingsPerResult }}"
    result-title-lines="{{ resultTitleLines }}"
    result-desc-lines="{{ resultDescLines }}"
    snippet-length="{{ snippetLength }}"
    parse-markdown-snippets="{{ _self.toBool(parseMarkdownSnippets, false) }}"
></search-modal>
