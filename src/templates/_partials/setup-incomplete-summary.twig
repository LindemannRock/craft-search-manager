{% set currentSubnavItem = selectedSubnavItem ?? '' %}
{% set setupStatus = setupStatus ?? craft.app.plugins.getPlugin('search-manager').setup.getStatus() %}

{% if currentSubnavItem != 'setup' %}
    {% include 'lindemannrock-base/_components/setup-incomplete' with {
        complete: setupStatus.complete,
        setupUrl: setupStatus.setupUrl,
        heading: 'Setup incomplete'|t('search-manager'),
        message: 'Finish setup before tracking search analytics.'|t('search-manager'),
        actionLabel: 'Open setup'|t('search-manager'),
    } only %}
{% endif %}
