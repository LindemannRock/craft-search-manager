{% extends 'lindemannrock-base/_layouts/cp-table' %}

{# Follows the canonical CP table index-page pattern (in-memory variant) —
   see plugins/base/docs/template-guides/cp-table-index-pattern.md.
   PromotionsController::actionIndex() owns query-param parsing, allowlist
   validation, filter, sort, and pagination. This template stays
   presentational and just renders what's handed in. #}

{# Match type labels — used by both the table row and the filter dropdown,
   so memoised once at the top of the template. #}
{% set matchTypeLabels = {
    'exact': 'Exact'|t('search-manager'),
    'contains': 'Contains'|t('search-manager'),
    'prefix': 'Starts With'|t('search-manager'),
} %}

{% set tableConfig = {
    plugin: {
        handle: 'search-manager',
        name: searchHelper.fullName,
    },
    page: {
        title: 'Promotions'|t('search-manager'),
        subnav: 'promotions',
        crumbs: [
            { label: searchHelper.fullName, url: url('search-manager') },
            { label: 'Promotions'|t('search-manager'), url: url('search-manager/promotions') }
        ],
    },
    filters: [
        {
            type: 'status',
            param: 'status',
            current: statusFilter,
            label: 'All'|t('search-manager'),
            groups: [
                {
                    param: 'status',
                    current: statusFilter,
                    colorSet: 'status',
                    options: [
                        {value: 'all', label: 'All'|t('search-manager'), status: 'all'},
                        {value: 'enabled', label: 'Enabled'|t('search-manager'), colorKey: 'enabled'},
                        {value: 'disabled', label: 'Disabled'|t('search-manager'), colorKey: 'disabled'},
                    ],
                },
                {
                    header: 'Match Type'|t('search-manager'),
                    param: 'matchType',
                    current: matchTypeFilter,
                    colorSet: 'matchType',
                    options: [
                        {value: 'all', label: 'All Types'|t('search-manager'), status: 'all'},
                        {value: 'exact', label: 'Exact Match'|t('search-manager'), colorKey: 'exact'},
                        {value: 'contains', label: 'Contains'|t('search-manager'), colorKey: 'contains'},
                        {value: 'prefix', label: 'Starts With'|t('search-manager'), colorKey: 'prefix'},
                    ],
                },
            ],
        },
    ],
    search: {
        placeholder: 'Search promotions...'|t('search-manager'),
        value: search,
    },
    sort: {
        field: sort,
        direction: dir,
    },
    table: {
        columns: [
            {key: 'title', label: 'Title'|t('search-manager'), sortable: true},
            {key: 'query', label: 'Query Pattern'|t('search-manager'), sortable: true},
            {key: 'matchType', label: 'Match'|t('search-manager'), sortable: true, hideable: true},
            {key: 'element', label: 'Promoted Element'|t('search-manager'), hideable: true},
            {key: 'position', label: 'Position'|t('search-manager'), sortable: true, hideable: true},
            {key: 'siteId', label: 'Site'|t('search-manager'), sortable: true, hideable: true},
            {key: 'enabled', label: 'Status'|t('search-manager'), sortable: true, hideable: true},
        ],
        items: promotions,
        emptyMessage: 'No promotions found.'|t('search-manager'),
    },
    pagination: {
        page: page,
        limit: limit,
        totalCount: totalCount,
        itemLabel: {singular: 'promotion'|t('search-manager'), plural: 'promotions'|t('search-manager')},
    },
    checkboxes: canEdit or canDelete,
    newButton: canCreate ?? false ? {
        url: url('search-manager/promotions/create'),
        label: 'New Promotion'|t('search-manager'),
    } : null,
} %}

{% block tableRow %}
    {# Title #}
    <td data-column="title">
        <a class="label-link" href="{{ url('search-manager/promotions/edit/' ~ item.id) }}">
            {% if item.title %}
                {{ item.title }}
            {% else %}
                <span class="light">{{ 'Untitled'|t('search-manager') }}</span>
            {% endif %}
        </a>
    </td>

    {# Query Pattern #}
    <td data-column="query">
        <code>{{ item.query }}</code>
    </td>

    {# Match Type #}
    <td data-column="matchType">
        {% include 'lindemannrock-base/_components/badge' with {
            label: matchTypeLabels[item.matchType] ?? item.matchType|capitalize,
            value: item.matchType,
            colorSet: 'matchType',
        } only %}
    </td>

    {# Promoted Element #}
    <td data-column="element">
        {% set element = craft.entries.id(item.elementId).status(null).one() %}
        {% if element and element.id %}
            <a href="{{ element.cpEditUrl }}" target="_blank">
                {{ element.title ?? element.id }}
            </a>
            <span class="light">(#{{ element.id }})</span>
        {% else %}
            <span class="light">{{ 'ID'|t('search-manager') }}: {{ item.elementId }}</span>
        {% endif %}
    </td>

    {# Position #}
    <td data-column="position">
        <strong>{{ item.position }}</strong>
    </td>

    {# Site #}
    <td data-column="siteId">
        {% if item.siteId %}
            {% set site = craft.app.sites.getSiteById(item.siteId) %}
            {{ site ? site.name : 'Unknown' }}
        {% else %}
            <span class="light">{{ 'All Sites'|t('search-manager') }}</span>
        {% endif %}
    </td>

    {# Status #}
    <td data-column="enabled">
        {% if item.enabled %}
            {% include 'lindemannrock-base/_components/badge' with {
                label: 'Enabled'|t('search-manager'),
                value: 'enabled',
                colorSet: 'status',
            } only %}
        {% else %}
            {% include 'lindemannrock-base/_components/badge' with {
                label: 'Disabled'|t('search-manager'),
                value: 'disabled',
                colorSet: 'status',
            } only %}
        {% endif %}
    </td>
{% endblock %}

{% block rowActions %}
    {% set actionItems = [] %}

    {% if canEdit %}
        {% set actionItems = actionItems|merge([{
            label: 'Edit'|t('search-manager'),
            url: url('search-manager/promotions/edit/' ~ item.id),
        }]) %}
    {% endif %}

    {% if canDelete %}
        {% if canEdit %}
            {% set actionItems = actionItems|merge([{type: 'divider'}]) %}
        {% endif %}
        {% set actionItems = actionItems|merge([{
            label: 'Delete'|t('search-manager'),
            class: 'error',
            jsAction: 'delete',
            data: {name: item.title ?: ('#' ~ item.id)},
        }]) %}
    {% endif %}

    {% if actionItems|length %}
        {% include 'lindemannrock-base/_components/row-actions' with {
            item: {id: item.id},
            actions: {
                type: 'menu',
                icon: 'settings',
                title: 'Actions'|t('search-manager'),
                items: actionItems,
            },
        } only %}
    {% endif %}
{% endblock %}

{% block bulkActions %}
    {% if canEdit %}
        {% include 'lindemannrock-base/_components/bulk-status-menu' with {
            label: 'Set status'|t('search-manager'),
            countId: 'lr-bulk-status-count',
            items: [
                {id: 'lr-bulk-enable-action', label: 'Enable'|t('search-manager'), status: 'enabled'},
                {id: 'lr-bulk-disable-action', label: 'Disable'|t('search-manager'), status: 'disabled'},
            ],
        } only %}
    {% endif %}

    {% if canDelete %}
        {% include 'lindemannrock-base/_components/bulk-actions-menu' with {
            label: 'Actions'|t('search-manager'),
            countId: 'lr-bulk-actions-count',
            items: [
                {id: 'lr-bulk-delete-btn', label: 'Delete'|t('search-manager'), class: 'error'},
            ],
        } only %}
    {% endif %}
{% endblock %}

{% block scripts %}
<script>
(function() {
    if (typeof Craft === 'undefined') return;

    const T = {
        deleted: {{ 'Promotion deleted'|t('search-manager')|json_encode|raw }},
        deleteFailed: {{ 'Failed to delete promotion'|t('search-manager')|json_encode|raw }},
        deleteConfirm: {{ 'Delete promotion for "{name}"? This cannot be undone.'|t('search-manager')|json_encode|raw }},
        bulkEnabledTemplate: {{ 'Enabled {count} promotions'|t('search-manager')|json_encode|raw }},
        bulkEnableFailed: {{ 'Failed to enable promotions'|t('search-manager')|json_encode|raw }},
        bulkDisabledTemplate: {{ 'Disabled {count} promotions'|t('search-manager')|json_encode|raw }},
        bulkDisableFailed: {{ 'Failed to disable promotions'|t('search-manager')|json_encode|raw }},
        bulkDeletedTemplate: {{ 'Deleted {count} promotions'|t('search-manager')|json_encode|raw }},
        bulkDeleteFailed: {{ 'Failed to delete promotions'|t('search-manager')|json_encode|raw }},
        bulkDeleteConfirmSingular: {{ 'Delete {count} promotion? This cannot be undone.'|t('search-manager')|json_encode|raw }},
        bulkDeleteConfirmPlural: {{ 'Delete {count} promotions? This cannot be undone.'|t('search-manager')|json_encode|raw }},
    };

    function selectedIds() {
        return window.lrTableSelection ? window.lrTableSelection.getSelectedIds() : [];
    }

    // Row-action handler — delegated on document, narrowed by anchor +
    // action name. See cp-table-index-pattern.md.
    document.addEventListener('click', function(e) {
        const trigger = e.target.closest('a[data-action]');
        if (!trigger) return;
        if (trigger.dataset.action !== 'delete') return;

        const id = parseInt(trigger.dataset.id || '0', 10);
        if (!id) return;
        e.preventDefault();

        const name = trigger.dataset.name || '';
        if (!confirm(T.deleteConfirm.replace('{name}', name))) return;

        Craft.sendActionRequest('POST', 'search-manager/promotions/delete', {
            data: { promotionId: id },
        }).then(function() {
            Craft.cp.displayNotice(T.deleted);
            setTimeout(function() { window.location.reload(); }, 1000);
        }).catch(function() {
            Craft.cp.displayError(T.deleteFailed);
        });
    });

    function runBulk(endpoint, successTemplate, errorFallback) {
        const ids = selectedIds();
        if (!ids.length) return;
        Craft.sendActionRequest('POST', endpoint, {
            data: { promotionIds: ids },
        }).then(function(response) {
            const count = response.data.count || 0;
            if (count > 0) {
                Craft.cp.displayNotice(successTemplate.replace('{count}', count));
                setTimeout(function() { window.location.reload(); }, 1000);
            }
        }).catch(function() {
            Craft.cp.displayError(errorFallback);
        });
    }

    document.getElementById('lr-bulk-enable-action')?.addEventListener('click', function(e) {
        e.preventDefault();
        runBulk('search-manager/promotions/bulk-enable', T.bulkEnabledTemplate, T.bulkEnableFailed);
    });

    document.getElementById('lr-bulk-disable-action')?.addEventListener('click', function(e) {
        e.preventDefault();
        runBulk('search-manager/promotions/bulk-disable', T.bulkDisabledTemplate, T.bulkDisableFailed);
    });

    document.getElementById('lr-bulk-delete-btn')?.addEventListener('click', function() {
        const ids = selectedIds();
        if (!ids.length) return;
        const confirmTemplate = ids.length === 1 ? T.bulkDeleteConfirmSingular : T.bulkDeleteConfirmPlural;
        if (!confirm(confirmTemplate.replace('{count}', ids.length))) return;
        runBulk('search-manager/promotions/bulk-delete', T.bulkDeletedTemplate, T.bulkDeleteFailed);
    });
})();
</script>
{% endblock %}
