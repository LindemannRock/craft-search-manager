{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set plugin = craft.app.plugins.getPlugin('search-manager') %}
{% set title = isNew ? 'New Query Rule'|t('search-manager') : 'Edit Query Rule'|t('search-manager') %}
{% set fullPageForm = true %}
{% set selectedSubnavItem = 'query-rules' %}
{% set saveShortcutRedirect = cpUrl('search-manager/query-rules/edit/{id}') %}
{% set retainScrollOnSaveShortcut = true %}
{% set setupIncompleteSummary = include('search-manager/_partials/setup-incomplete-summary', {
    selectedSubnavItem: selectedSubnavItem,
})|trim %}

{% set crumbs = [
    { label: searchHelper.fullName, url: url('search-manager') },
    { label: 'Query Rules'|t('search-manager'), url: url('search-manager/query-rules') },
    { label: isNew ? 'New Query Rule'|t('search-manager') : rule.name }
] %}

{# Set up tabs #}
{% set tabs = {
    fields: {
        label: 'Settings'|t('search-manager'),
        url: '#fields',
    },
} %}

{# Add analytics tab if rule exists and analytics are enabled #}
{% if not isNew and plugin.settings.enableAnalytics and currentUser.can('searchManager:viewAnalytics') %}
    {% set tabs = tabs|merge({
        analytics: {
            label: 'Analytics'|t('search-manager'),
            url: '#analytics',
        },
    }) %}
{% endif %}

{% block actionButton %}
	<div class="btngroup submit">
		<button type="submit" class="btn submit">{{ "Save"|t('search-manager') }}</button>
		<button type="button" class="btn submit menubtn"></button>
		<div class="menu">
			<ul role="listbox">
				<li>
					<a class="formsubmit" role="option" tabindex="0" data-redirect="{{ cpUrl('search-manager/query-rules/edit/{id}')|hash }}">
						<span class="label">{{ 'Save and continue editing'|t('search-manager') }}</span>
						<span class="shortcut" id="save-shortcut"></span>
					</a>
				</li>
			</ul>
		</div>
	</div>
	{% if not isNew and currentUser.can('searchManager:deleteQueryRules') %}
		<button type="button" id="action-btn" class="btn menubtn action-btn hairline-dark m" title="{{ 'Actions'|t('search-manager') }}" aria-controls="action-menu" aria-label="{{ 'Actions'|t('search-manager') }}" data-disclosure-trigger="true" aria-expanded="false"></button>
		<div id="action-menu" class="menu menu--disclosure">
			<ul>
				<li>
					<button class="menu-item error formsubmit" data-destructive data-action="search-manager/query-rules/delete" data-params='{"ruleId":{{ rule.id }}}' data-confirm="{{ 'Are you sure you want to delete this query rule?'|t('search-manager') }}" data-redirect="{{ 'search-manager/query-rules'|hash }}" data-headers='{"Accept":"application/json"}'>
						<span class="icon">{{ svg('@app/icons/trash.svg') }}</span>
						<span class="menu-item-label">{{ "Delete"|t('search-manager') }}</span>
					</button>
				</li>
			</ul>
		</div>
	{% endif %}
{% endblock %}

{# Display validation errors summary before content #}
{% set validationSummary = '' %}
{% if rule.hasErrors() %}
	{% set validationSummary = include('lindemannrock-base/_partials/error-summary', {
		errors: rule.getErrors(),
		linkMode: 'data-key',
	})|trim %}
{% endif %}
{% set errorSummary = [setupIncompleteSummary, validationSummary]|filter(v => v)|join("\n") %}

{% block content %}
	<input type="hidden" name="action" value="search-manager/query-rules/save">
	<input type="hidden" name="redirect" value="{{ 'search-manager/query-rules'|hash }}">
	{% if not isNew %}
		<input type="hidden" name="ruleId" value="{{ rule.id }}">
	{% endif %}
	{{ csrfInput() }}

	<div id="fields">
		{{ forms.textField({
			first: true,
			label: 'Name'|t('search-manager'),
			instructions: 'A descriptive name for this rule (e.g., "Phone synonyms" or "Holiday redirect").'|t('search-manager'),
			id: 'name',
			name: 'name',
			value: rule.name,
			placeholder: 'Phone synonyms'|t('search-manager'),
			required: true,
			errors: rule.getErrors('name'),
		}) }}

		{{ forms.selectField({
			label: 'Index'|t('search-manager'),
			instructions: 'Apply this rule to a specific index, or all indices.'|t('search-manager'),
			id: 'indexHandle',
			name: 'indexHandle',
			options: indexOptions,
			value: rule.indexHandle,
			errors: rule.getErrors('indexHandle'),
		}) }}

		<hr>

		<div class="field{% if rule.getErrors('matchType') %} has-errors{% endif %}">
			<div class="heading">
				<label for="matchType">{{ 'Match Type'|t('search-manager') }}
					<span class="required" aria-label="{{ 'Required'|t('search-manager') }}"></span>
				</label>
				<div class="instructions">
					<p id="matchTypeInstructions">
						{% if rule.matchType == 'contains' %}
							{{ 'Match if the search query contains this pattern anywhere.'|t('search-manager') }}
						{% elseif rule.matchType == 'prefix' %}
							{{ 'Match if the search query starts with this pattern.'|t('search-manager') }}
						{% elseif rule.matchType == 'regex' %}
							{{ 'Match using a regular expression pattern for complex matching.'|t('search-manager') }}
						{% else %}
							{{ 'Match only if the search query exactly matches this pattern.'|t('search-manager') }}
						{% endif %}
					</p>
				</div>
			</div>
			<div class="input">
				<div class="select">
					<select id="matchType" name="matchType" required>
						<option value="exact" {% if rule.matchType == 'exact' %} selected {% endif %}>{{ 'Exact Match'|t('search-manager') }}</option>
						<option value="contains" {% if rule.matchType == 'contains' %} selected {% endif %}>{{ 'Contains'|t('search-manager') }}</option>
						<option value="prefix" {% if rule.matchType == 'prefix' %} selected {% endif %}>{{ 'Starts With'|t('search-manager') }}</option>
						<option value="regex" {% if rule.matchType == 'regex' %} selected {% endif %}>{{ 'Regex'|t('search-manager') }}</option>
					</select>
				</div>
			</div>
			{% if rule.getErrors('matchType') %}
				<ul class="errors">
					{% for error in rule.getErrors('matchType') %}
						<li>{{ error }}</li>
					{% endfor %}
				</ul>
			{% endif %}
		</div>

		<div class="field{% if rule.getErrors('matchValue') %} has-errors{% endif %}" id="matchValue-field">
			<div class="heading">
				<label for="matchValue">{{ 'Match Pattern'|t('search-manager') }}
					<span class="required" aria-label="{{ 'Required'|t('search-manager') }}"></span>
				</label>
				<div class="instructions">
					<p id="matchValueInstructions">
						{% if rule.matchType == 'contains' %}
							{{ 'Enter text that should appear anywhere in the search query.'|t('search-manager') }}
							{{ 'Use commas for multiple patterns (e.g., sale, تخفيض, soldes, angebot).'|t('search-manager') }}
						{% elseif rule.matchType == 'prefix' %}
							{{ 'Enter text that the search query should start with.'|t('search-manager') }}
							{{ 'Use commas for multiple patterns (e.g., sale, تخفيض, soldes, angebot).'|t('search-manager') }}
						{% elseif rule.matchType == 'regex' %}
							{{ 'Enter a regular expression pattern (without delimiters).'|t('search-manager') }}
						{% else %}
							{{ 'Enter the exact search query to match.'|t('search-manager') }}
							{{ 'Use commas for multiple patterns (e.g., sale, تخفيض, soldes, angebot).'|t('search-manager') }}
						{% endif %}
					</p>
				</div>
			</div>
			<div class="input ltr">
					<input type="text" id="matchValue" name="matchValue" value="{{ rule.matchValue }}" placeholder="{{ rule.matchType == 'regex' ? '^(sale|تخفيض|soldes|angebot)'|t('search-manager') : (rule.matchType == 'contains' ? 'sale'|t('search-manager') : (rule.matchType == 'prefix' ? 'buy '|t('search-manager') : 'sale'|t('search-manager'))) }}" required class="text fullwidth{% if rule.getErrors('matchValue') %} error{% endif %}">
			</div>
			{% if rule.getErrors('matchValue') %}
				<ul class="errors">
					{% for error in rule.getErrors('matchValue') %}
						<li>{{ error }}</li>
					{% endfor %}
				</ul>
			{% endif %}
			<p id="matchTypeTip" class="notice has-icon" style="margin-top: 10px;">
				<span class="icon" aria-hidden="true"></span>
				<span class="visually-hidden">{{ 'Tip:'|t('search-manager') }}</span>
				<span id="matchTypeTipText">
					{% if rule.matchType == 'contains' %}
							{{ 'Example: "phone" matches "buy phone", "phone case", "smartphone"'|t('search-manager') }}
					{% elseif rule.matchType == 'prefix' %}
							{{ 'Example: "buy " matches "buy phone", "buy laptop", "buy headphones"'|t('search-manager') }}
					{% elseif rule.matchType == 'regex' %}
							{{ 'Example: "^(phone|mobile|cell)" matches "phone", "mobile", "cell" at the start'|t('search-manager') }}
					{% else %}
							{{ 'Example: "phone" only matches exactly "phone", not "smartphone"'|t('search-manager') }}
					{% endif %}
				</span>
			</p>
			<p id="regexTip" class="notice has-icon" style="margin-top: 10px; display: {{ rule.matchType == 'regex' ? 'block' : 'none' }};">
				<span class="icon" aria-hidden="true"></span>
				<span class="visually-hidden">{{ 'Tip:'|t('search-manager') }}</span>
					<span>{{ 'Test your pattern at {link} before saving.'|t('search-manager', {
						link: '<a class="go" href="https://regexr.com/" target="_blank" rel="noopener">regexr.com</a>'
					})|raw }}</span>
			</p>
		</div>

		<hr>

		<div class="field{% if rule.getErrors('actionType') %} has-errors{% endif %}">
			<div class="heading">
				<label for="actionType">{{ 'Action Type'|t('search-manager') }}
					<span class="required" aria-label="{{ 'Required'|t('search-manager') }}"></span>
				</label>
				<div class="instructions">
					<p id="actionTypeInstructions">
						{% if rule.actionType == 'synonym' %}
							{{ 'Add synonym terms - search results will also include matches for these related terms.'|t('search-manager') }}
						{% elseif rule.actionType == 'boost_section' %}
							{{ 'Boost results from a specific section - multiply their scores.'|t('search-manager') }}
						{% elseif rule.actionType == 'boost_category' %}
							{{ 'Boost results in a specific category - multiply their scores.'|t('search-manager') }}
						{% elseif rule.actionType == 'boost_element' %}
							{{ 'Boost a specific element - multiply its score.'|t('search-manager') }}
						{% elseif rule.actionType == 'redirect' %}
							{{ 'Redirect to a URL instead of showing search results.'|t('search-manager') }}
						{% else %}
							{{ 'Select what should happen when this rule matches.'|t('search-manager') }}
						{% endif %}
					</p>
				</div>
			</div>
			<div class="input">
				<div class="select">
					<select id="actionType" name="actionType" required>
						<option value="synonym" {% if rule.actionType == 'synonym' %} selected {% endif %}>{{ 'Synonyms'|t('search-manager') }}</option>
						<option value="boost_section" {% if rule.actionType == 'boost_section' %} selected {% endif %}>{{ 'Boost Section'|t('search-manager') }}</option>
						<option value="boost_category" {% if rule.actionType == 'boost_category' %} selected {% endif %}>{{ 'Boost Category'|t('search-manager') }}</option>
						<option value="boost_element" {% if rule.actionType == 'boost_element' %} selected {% endif %}>{{ 'Boost Element'|t('search-manager') }}</option>
						<option value="redirect" {% if rule.actionType == 'redirect' %} selected {% endif %}>{{ 'Redirect'|t('search-manager') }}</option>
					</select>
				</div>
			</div>
			{% if rule.getErrors('actionType') %}
				<ul class="errors">
					{% for error in rule.getErrors('actionType') %}
						<li>{{ error }}</li>
					{% endfor %}
				</ul>
			{% endif %}
		</div>

		{# Synonym fields #}
		<div id="action-synonym" class="action-fields" style="{{ rule.actionType != 'synonym' ? 'display: none;' : '' }}">
			<div class="field{% if rule.actionType == 'synonym' and rule.getErrors('actionValue') %} has-errors{% endif %}">
				<div class="heading">
					<label for="synonyms">{{ 'Synonyms'|t('search-manager') }}</label>
					<div class="instructions">
						<p>{{ 'Comma-separated list of synonym terms. When the pattern matches, search will also include results for these terms.'|t('search-manager') }}</p>
					</div>
				</div>
				<div class="input ltr">
						<textarea id="synonyms" name="synonyms" rows="3" class="text fullwidth{% if rule.actionType == 'synonym' and rule.getErrors('actionValue') %} error{% endif %}" placeholder="{{ 'mobile, cell phone, smartphone, cellular'|t('search-manager') }}">{{ rule.actionValue.terms is defined ? rule.actionValue.terms|join(', ') : '' }}</textarea>
				</div>
				{% if rule.actionType == 'synonym' and rule.getErrors('actionValue') %}
					<ul class="errors">
						{% for error in rule.getErrors('actionValue') %}
							<li>{{ error }}</li>
						{% endfor %}
					</ul>
				{% endif %}
				<p class="notice has-icon" style="margin-top: 10px;">
					<span class="icon" aria-hidden="true"></span>
					<span class="visually-hidden">{{ 'Tip:'|t('search-manager') }}</span>
						<span>{{ 'Example: For query "phone", add synonyms "mobile, cell phone, smartphone" to show results containing any of these terms. Maximum 10 synonyms per rule.'|t('search-manager') }}</span>
				</p>
			</div>
		</div>

		{# Boost multiplier options (shared) #}
		{% set boostMultiplierOptions = [
				{ label: '1.5× - Slight boost'|t('search-manager'), value: '1.5' },
				{ label: '2.0× - Double score (recommended)'|t('search-manager'), value: '2.0' },
				{ label: '3.0× - Triple score'|t('search-manager'), value: '3.0' },
				{ label: '5.0× - Strong boost'|t('search-manager'), value: '5.0' },
				{ label: '10.0× - Very strong boost'|t('search-manager'), value: '10.0' },
		] %}

		{# Boost section fields #}
		<div id="action-boost_section" class="action-fields" style="{{ rule.actionType != 'boost_section' ? 'display: none;' : '' }}">
			{{ forms.selectField({
				label: 'Section'|t('search-manager'),
				instructions: 'Select the section to boost when this rule matches.'|t('search-manager'),
				id: 'boostSectionHandle',
				name: 'boostSectionHandle',
				options: sectionOptions,
				value: rule.actionValue.sectionHandle ?? '',
				errors: rule.actionType == 'boost_section' ? rule.getErrors('actionValue') : [],
			}) }}

			{{ forms.selectField({
				label: 'Boost Multiplier'|t('search-manager'),
				instructions: 'Score multiplier for matching results. Higher values push results higher in the rankings.'|t('search-manager'),
				id: 'boostMultiplier-section',
				name: 'boostSectionMultiplier',
				options: boostMultiplierOptions,
				value: (rule.actionValue.multiplier ?? 2.0)|number_format(1),
			}) }}
		</div>

		{# Boost category fields #}
		<div id="action-boost_category" class="action-fields" style="{{ rule.actionType != 'boost_category' ? 'display: none;' : '' }}">
			{{ forms.elementSelectField({
				label: 'Boost Category'|t('search-manager'),
				instructions: 'Select the category to boost when this rule matches.'|t('search-manager'),
				id: 'boostCategory',
				name: 'boostCategory',
				elementType: 'craft\\elements\\Category',
				selectionLabel: 'Select a category'|t('search-manager'),
				limit: 1,
				elements: (rule.actionValue.categoryId ?? null) ? [craft.categories.id(rule.actionValue.categoryId).status(null).one()] : [],
				errors: rule.actionType == 'boost_category' ? rule.getErrors('actionValue') : [],
			}) }}

			{{ forms.selectField({
				label: 'Boost Multiplier'|t('search-manager'),
				instructions: 'Score multiplier for matching results. Higher values push results higher in the rankings.'|t('search-manager'),
				id: 'boostMultiplier-category',
				name: 'boostCategoryMultiplier',
				options: boostMultiplierOptions,
				value: (rule.actionValue.multiplier ?? 2.0)|number_format(1),
			}) }}
		</div>

		{# Boost element fields #}
		<div id="action-boost_element" class="action-fields" style="{{ rule.actionType != 'boost_element' ? 'display: none;' : '' }}">
			{{ forms.selectField({
				label: 'Type'|t('search-manager'),
				id: 'boostElementType',
				name: 'boostElementType',
				options: targetTypeOptions,
				value: boostElementTargetType,
			}) }}

			{% for targetTypeOption in targetTypeOptions %}
				{% set targetType = targetTypeOption.value %}
				<div id="boost-element-{{ targetType }}-field" class="boost-element-field{{ boostElementTargetType != targetType ? ' hidden' : '' }}">
					{{ forms.elementSelectField({
						label: 'Boost Element'|t('search-manager'),
						instructions: 'Select the element to boost when this rule matches.'|t('search-manager'),
						id: 'boostElement' ~ targetType|capitalize,
						name: 'boostElement' ~ targetType|capitalize,
						elementType: targetTypeOption.elementType,
						selectionLabel: 'Select an element'|t('search-manager'),
						limit: 1,
						elements: boostTargetElements[targetType] ?? [],
						errors: rule.actionType == 'boost_element' and boostElementTargetType == targetType ? rule.getErrors('actionValue') : [],
					}) }}
				</div>
			{% endfor %}

			{{ forms.selectField({
				label: 'Boost Multiplier'|t('search-manager'),
				instructions: 'Score multiplier for matching results. Higher values push results higher in the rankings.'|t('search-manager'),
				id: 'boostMultiplier-element',
				name: 'boostElementMultiplier',
				options: boostMultiplierOptions,
				value: (rule.actionValue.multiplier ?? 2.0)|number_format(1),
			}) }}
		</div>

		{# Redirect fields #}
		<div id="action-redirect" class="action-fields" style="{{ rule.actionType != 'redirect' ? 'display: none;' : '' }}">
			{# Determine current redirect type #}
			{% set redirectType = rule.actionValue.elementId is defined and rule.actionValue.elementId and rule.actionValue.elementType is defined ? redirectTargetType : 'url' %}
			{% set redirectTypeOptions = [{ value: 'url', label: 'Custom URL'|t('search-manager') }]|merge(targetTypeOptions) %}

			{{ forms.selectField({
				label: 'Redirect To'|t('search-manager'),
				instructions: 'Choose what to redirect to when this rule matches.'|t('search-manager'),
				id: 'redirectType',
				name: 'redirectType',
				value: redirectType,
				options: redirectTypeOptions,
			}) }}

			{# Custom URL field #}
			<div id="redirect-url-field" class="{{ redirectType != 'url' ? 'hidden' : '' }}">
				{{ forms.textField({
					label: 'Redirect URL'|t('search-manager'),
					instructions: 'The URL to redirect to. Can be a path (/page) or full URL (https://...).'|t('search-manager'),
					id: 'redirectUrl',
					name: 'redirectUrl',
					value: redirectType == 'url' ? (rule.actionValue.url ?? '') : '',
					placeholder: '/special-offers',
					errors: redirectType == 'url' ? rule.getErrors('actionValue') : [],
				}) }}
			</div>

			{% for targetTypeOption in targetTypeOptions %}
				{% set targetType = targetTypeOption.value %}
				<div id="redirect-{{ targetType }}-field" class="redirect-element-field{{ redirectType != targetType ? ' hidden' : '' }}">
					{{ forms.elementSelectField({
						label: 'Element'|t('search-manager'),
						id: 'redirectElement' ~ targetType|capitalize,
						name: 'redirectElement' ~ targetType|capitalize,
						elementType: targetTypeOption.elementType,
						selectionLabel: 'Select an element'|t('search-manager'),
						limit: 1,
						elements: redirectTargetElements[targetType] ?? [],
						showSiteMenu: true,
						errors: redirectType == targetType ? rule.getErrors('actionValue') : [],
					}) }}
				</div>
			{% endfor %}

			<p class="notice has-icon" style="margin-top: 10px;">
				<span class="icon" aria-hidden="true"></span>
				<span class="visually-hidden">{{ 'Tip:'|t('search-manager') }}</span>
					<span>{{ 'Use redirects for seasonal promotions (e.g., "christmas" → /holiday-deals) or to guide users to specific pages.'|t('search-manager') }}</span>
			</p>
		</div>

		<hr>

		<div class="field{% if rule.getErrors('priority') %} has-errors{% endif %}">
			<div class="heading">
				<label for="priority">{{ 'Priority'|t('search-manager') }}</label>
				<div class="instructions">
					<p>{{ 'Rules are applied in priority order. Higher priority rules are applied first. Use this when you have overlapping patterns.'|t('search-manager') }}</p>
				</div>
			</div>
			<div class="input ltr">
				<div class="select">
					<select id="priority" name="priority" style="width: 300px;">
						{% for i in [10, 5, 0, -5, -10] %}
							<option value="{{ i }}" {% if (rule.priority ?? 0) == i %} selected {% endif %}>
									{{ i }} - {{ i == 10 ? 'Highest priority'|t('search-manager') : (i == 5 ? 'High priority'|t('search-manager') : (i == 0 ? 'Normal (default)'|t('search-manager') : (i == -5 ? 'Low priority'|t('search-manager') : 'Lowest priority'|t('search-manager')))) }}
							</option>
						{% endfor %}
					</select>
				</div>
			</div>
			{% if rule.getErrors('priority') %}
				<ul class="errors">
					{% for error in rule.getErrors('priority') %}
						<li>{{ error }}</li>
					{% endfor %}
				</ul>
			{% endif %}
			<p class="notice has-icon" style="margin-top: 10px;">
				<span class="icon" aria-hidden="true"></span>
				<span class="visually-hidden">{{ 'Tip:'|t('search-manager') }}</span>
					<span>{{ 'Set specific rules to high priority and general catch-all rules to low priority. For example, "buy iphone 15" (priority 10) before "buy" (priority 0).'|t('search-manager') }}</span>
			</p>
		</div>

		{% include 'lindemannrock-base/_components/plugin-credit' %}
	</div>

	{# Analytics Tab #}
	{% if not isNew and plugin.settings.enableAnalytics and currentUser.can('searchManager:viewAnalytics') %}
		<div id="analytics" class="hidden">
			{% include "search-manager/query-rules/_partials/analytics" with {
				rule: rule,
				analyticsService: analyticsService ?? null
			} %}

			{% include 'lindemannrock-base/_components/plugin-credit' %}
		</div>
	{% endif %}
{% endblock %}

{% block details %}
	<div class="meta">
		{{ forms.lightswitchField({
			label: 'Enabled'|t('search-manager'),
			id: 'enabled',
			name: 'enabled',
			on: rule.enabled ?? true
		}) }}

		{% if craft.app.getIsMultiSite() %}
			{{ forms.selectField({
				label: 'Site'|t('search-manager'),
				id: 'siteId',
				name: 'siteId',
				options: siteOptions,
				value: rule.siteId,
				errors: rule.getErrors('siteId')
			}) }}
		{% endif %}
	</div>

	{% if not isNew %}
		<fieldset>
			<dl class="meta read-only">
				{% if rule.id %}
					<div class="data">
						<dt class="heading">{{ 'ID'|t('search-manager') }}</dt>
						<dd class="value">{{ rule.id }}</dd>
					</div>
				{% endif %}
				<div class="data">
					<dt class="heading">{{ 'Status'|t('search-manager') }}</dt>
					<dd class="value">
						{% include 'lindemannrock-base/_components/status-dot' with {
							value: rule.enabled ? 'enabled' : 'disabled',
							colorSet: 'status',
						} only %}
						<span>{{ rule.enabled ? 'Enabled'|t('search-manager') : 'Disabled'|t('search-manager') }}</span>
					</dd>
				</div>
				<div class="data">
					<dt class="heading">{{ 'Created at'|t('search-manager') }}</dt>
					<dd class="value">{{ rule.dateCreated|lrDatetime }}</dd>
				</div>
				<div class="data">
					<dt class="heading">{{ 'Updated at'|t('search-manager') }}</dt>
					<dd class="value">{{ rule.dateUpdated|lrDatetime }}</dd>
				</div>
			</dl>
		</fieldset>
	{% endif %}
{% endblock %}

{% js %}
// Toggle action fields based on action type
function toggleActionFields() {
	const actionType = document.getElementById('actionType').value;

	// Hide all action-specific field containers
	document.querySelectorAll('.action-fields').forEach(el => {
		el.style.display = 'none';
	});

	// Show the relevant action-specific fields
	const fieldEl = document.getElementById('action-' + actionType);
	if (fieldEl) {
		fieldEl.style.display = 'block';
	}

	// Update action type instructions
	const actionTypeInstructions = document.getElementById('actionTypeInstructions');
	if (actionTypeInstructions) {
		switch(actionType) {
			case 'synonym':
				actionTypeInstructions.textContent = '{{ 'Add synonym terms - search results will also include matches for these related terms.'|t('search-manager') }}';
				break;
			case 'boost_section':
				actionTypeInstructions.textContent = '{{ 'Boost results from a specific section - multiply their scores.'|t('search-manager') }}';
				break;
			case 'boost_category':
				actionTypeInstructions.textContent = '{{ 'Boost results in a specific category - multiply their scores.'|t('search-manager') }}';
				break;
			case 'boost_element':
				actionTypeInstructions.textContent = '{{ 'Boost a specific element - multiply its score.'|t('search-manager') }}';
				break;
			case 'redirect':
				actionTypeInstructions.textContent = '{{ 'Redirect to a URL instead of showing search results.'|t('search-manager') }}';
				break;
		}
	}
}

// Update match type UI
function updateMatchTypeUI() {
	const matchType = document.getElementById('matchType').value;
	const matchTypeInstructions = document.getElementById('matchTypeInstructions');
	const matchValueInstructions = document.getElementById('matchValueInstructions');
	const matchValueInput = document.getElementById('matchValue');
	const matchTypeTipText = document.getElementById('matchTypeTipText');
	const regexTip = document.getElementById('regexTip');
	const commaHint = ' {{ 'Use commas for multiple patterns (e.g., sale, تخفيض, soldes, angebot).'|t('search-manager') }}';

	switch(matchType) {
		case 'contains':
			matchTypeInstructions.textContent = '{{ 'Match if the search query contains this pattern anywhere.'|t('search-manager') }}';
			matchValueInstructions.textContent = '{{ 'Enter text that should appear anywhere in the search query.'|t('search-manager') }}' + commaHint;
				matchValueInput.placeholder = {{ 'sale'|t('search-manager')|json_encode|raw }};
			matchTypeTipText.textContent = {{ 'Example: "sale" matches "big sale", "sale items", "flash sale"'|t('search-manager')|json_encode|raw }};
			regexTip.style.display = 'none';
			break;
		case 'prefix':
			matchTypeInstructions.textContent = '{{ 'Match if the search query starts with this pattern.'|t('search-manager') }}';
			matchValueInstructions.textContent = '{{ 'Enter text that the search query should start with.'|t('search-manager') }}' + commaHint;
				matchValueInput.placeholder = {{ 'buy '|t('search-manager')|json_encode|raw }};
			matchTypeTipText.textContent = {{ 'Example: "buy " matches "buy phone", "buy laptop", "buy headphones"'|t('search-manager')|json_encode|raw }};
			regexTip.style.display = 'none';
			break;
		case 'regex':
			matchTypeInstructions.textContent = '{{ 'Match using a regular expression pattern for complex matching.'|t('search-manager') }}';
			matchValueInstructions.textContent = '{{ 'Enter a regular expression pattern (without delimiters).'|t('search-manager') }}';
				matchValueInput.placeholder = {{ '^(sale|تخفيض|soldes|angebot)'|t('search-manager')|json_encode|raw }};
			matchTypeTipText.textContent = {{ 'Example: "^(sale|تخفيض|soldes|angebot)" matches any of these at the start'|t('search-manager')|json_encode|raw }};
			regexTip.style.display = 'block';
			break;
		default: // exact
			matchTypeInstructions.textContent = '{{ 'Match only if the search query exactly matches this pattern.'|t('search-manager') }}';
			matchValueInstructions.textContent = '{{ 'Enter the exact search query to match.'|t('search-manager') }}' + commaHint;
				matchValueInput.placeholder = {{ 'sale'|t('search-manager')|json_encode|raw }};
			matchTypeTipText.textContent = {{ 'Example: "sale" only matches exactly "sale", not "flash sale"'|t('search-manager')|json_encode|raw }};
			regexTip.style.display = 'none';
	}
}

// Toggle redirect type fields
function toggleRedirectFields() {
	const redirectTypeSelect = document.getElementById('redirectType');
	if (!redirectTypeSelect) return;

	const type = redirectTypeSelect.value;
	document.getElementById('redirect-url-field').classList.toggle('hidden', type !== 'url');
	document.querySelectorAll('.redirect-element-field').forEach(field => {
		const active = field.id === 'redirect-' + type + '-field';
		field.classList.toggle('hidden', !active);
		field.querySelectorAll('input, select, textarea, button').forEach(input => {
			input.disabled = !active;
		});
	});
}

function toggleBoostElementFields() {
	const boostTypeSelect = document.getElementById('boostElementType');
	if (!boostTypeSelect) return;

	document.querySelectorAll('.boost-element-field').forEach(field => {
		const active = field.id === 'boost-element-' + boostTypeSelect.value + '-field';
		field.classList.toggle('hidden', !active);
		field.querySelectorAll('input, select, textarea, button').forEach(input => {
			input.disabled = !active;
		});
	});
}

// Initialize
toggleActionFields();
updateMatchTypeUI();
toggleRedirectFields();
toggleBoostElementFields();

// Listen for changes
document.getElementById('actionType').addEventListener('change', toggleActionFields);
document.getElementById('matchType').addEventListener('change', updateMatchTypeUI);
const redirectTypeSelect = document.getElementById('redirectType');
if (redirectTypeSelect) {
	redirectTypeSelect.addEventListener('change', toggleRedirectFields);
}
const boostElementTypeSelect = document.getElementById('boostElementType');
if (boostElementTypeSelect) {
	boostElementTypeSelect.addEventListener('change', toggleBoostElementFields);
}

// Set platform-specific keyboard shortcut
const isMac = navigator.platform.toUpperCase().indexOf('MAC') >= 0;
const saveShortcut = document.getElementById('save-shortcut');
if (saveShortcut) {
	saveShortcut.textContent = isMac ? '⌘S' : 'Ctrl+S';
}
{% endjs %}
