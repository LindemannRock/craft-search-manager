{# Traffic & Devices Tab - Traffic Type, Agents, Device Types, Browsers, OS, Peak Hours #}

<h2 class="lr-section-heading">{{ "Traffic Analysis"|t('search-manager') }}</h2>

<div class="lr-analytics-charts two-columns">
    <div class="lr-chart-container">
        <h3>{{ "Traffic Type"|t('search-manager') }}</h3>
        <canvas id="bot-chart"></canvas>
        <div class="lr-muted-center" id="bot-percentage-label">
            {{ "Loading..."|t('search-manager') }}
        </div>
    </div>

    <div class="lr-chart-container">
        <h3>{{ "Top Agents"|t('search-manager') }}</h3>
        <div class="lr-table-scroll">
            <table class="data fullwidth">
                <thead>
                    <tr>
                        <th>{{ "Agent"|t('search-manager') }}</th>
                        <th>{{ "Traffic Type"|t('search-manager') }}</th>
                        <th>{{ "Category"|t('search-manager') }}</th>
                        <th>{{ "Producer"|t('search-manager') }}</th>
                        <th>{{ "Searches"|t('search-manager') }}</th>
                    </tr>
                </thead>
                <tbody id="top-bots-body">
                    <tr><td colspan="5" class="light lr-text-center">{{ "Loading..."|t('search-manager') }}</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<h2 class="lr-section-heading">{{ "Device Analytics"|t('search-manager') }}</h2>

<div class="lr-analytics-charts two-columns">
    <div class="lr-chart-container">
        <h3>{{ "Device Types"|t('search-manager') }}</h3>
        <canvas id="device-chart"></canvas>
    </div>

    <div class="lr-chart-container">
        <h3>{{ "Browser Usage"|t('search-manager') }}</h3>
        <canvas id="browser-chart"></canvas>
    </div>
</div>

<div class="lr-analytics-charts two-columns">
    <div class="lr-chart-container">
        <h3>{{ "Operating Systems"|t('search-manager') }}</h3>
        <canvas id="os-chart"></canvas>
    </div>

    <div class="lr-chart-container">
        <h3>{{ "Peak Usage Hours"|t('search-manager') }}</h3>
        <canvas id="hourly-chart"></canvas>
    </div>
</div>
