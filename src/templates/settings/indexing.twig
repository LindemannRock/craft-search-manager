{% extends "search-manager/_layouts/settings" %}
{% import "_includes/forms" as forms %}

{% set title = "Indexing Settings"|t('search-manager') %}
{% set fullPageForm = true %}
{% set selectedSettingsItem = 'indexing' %}


{% set crumbs = [
    {
        label: searchHelper.fullName|t('search-manager'),
        url: url('search-manager'),
    },
    {
        label: 'Settings'|t('search-manager'),
        url: url('search-manager/settings'),
    },
    {
        label: 'Indexing'|t('search-manager'),
        url: url('search-manager/settings/indexing'),
    },
] %}

{% block actionButton %}
	<div class="btngroup">
		<input type="submit" class="btn submit" value="{{ 'Save'|t('search-manager') }}">
	</div>
{% endblock %}

{% block content %}
    
	{{ actionInput('search-manager/settings/save') }}
	{{ redirectInput('search-manager/settings/indexing') }}
	{{ hiddenInput('section', 'indexing') }}

		<h2 class="first">{{ "Indexing Settings"|t('search-manager') }}</h2>

		{{ forms.lightswitchField({
            label: 'Auto-Index Elements'|t('search-manager'),
            instructions: 'Automatically index elements when they are saved'|t('search-manager'),
            id: 'autoIndex',
            name: 'settings[autoIndex]',
            on: settings.autoIndex,
            disabled: settings.isOverriddenByConfig('autoIndex'),
            warning: settings.isOverriddenByConfig('autoIndex') ?
                "This is being overridden by the <code>autoIndex</code> setting in <code>config/search-manager.php</code>."|t('search-manager')|raw : null,
        }) }}

		{% set activeBackend = craft.app.plugins.getPlugin('search-manager').backend.getActiveBackend() %}
		{% set backendType = activeBackend ? activeBackend.getName() : 'file' %}
		{% set isBuiltinBackend = backendType in ['mysql', 'pgsql', 'redis', 'file'] %}
		{% if isBuiltinBackend %}
			{{ forms.lightswitchField({
				label: 'Replace Native Search'|t('search-manager'),
				instructions: 'Enhance Craft\'s Control Panel and template search with Search Manager for element types that have a full-coverage index. Types without one keep using Craft\'s native search.'|t('search-manager'),
				id: 'replaceNativeSearch',
				name: 'settings[replaceNativeSearch]',
				on: settings.replaceNativeSearch,
				tip: "When disabled, use craft.searchManager.search() in templates instead."|t('search-manager'),
				disabled: settings.isOverriddenByConfig('replaceNativeSearch'),
				warning: settings.isOverriddenByConfig('replaceNativeSearch') ?
					"This is being overridden by the <code>replaceNativeSearch</code> setting in <code>config/search-manager.php</code>."|t('search-manager')|raw : null,
			}) }}

			<div id="native-search-coverage-settings" class="{{ not settings.replaceNativeSearch ? 'hidden' }}">
				{% include 'lindemannrock-base/_components/info-box' with {
					type: 'info',
					message: '<p>' ~ 'Search Manager enhances Craft\'s Control Panel and template search for element types you\'ve indexed with a full-coverage index — one that covers all sites, has no filters, and runs on a local backend (MySQL, PostgreSQL, Redis, or File). Element types without a full-coverage index continue to use Craft\'s native search.'|t('search-manager') ~ '</p><p>' ~ 'Review coverage below, or create a catch-all index to extend Search Manager to more element types.'|t('search-manager') ~ '</p>',
				} %}

				<h3>{{ 'Native Search Coverage'|t('search-manager') }}</h3>
				<p class="light">{{ 'While Replace Native Search is on, this shows which element types Search Manager answers and which fall back to Craft\'s native search.'|t('search-manager') }}</p>

				{% if nativeSearchHasLocalBackend %}
					<table class="data fullwidth">
						<thead>
							<tr>
								<th scope="col">{{ 'Element Type'|t('search-manager') }}</th>
								<th scope="col">{{ 'Coverage'|t('search-manager') }}</th>
								<th scope="col">{{ 'Index'|t('search-manager') }}</th>
							</tr>
						</thead>
						<tbody>
							{% for item in nativeSearchCoverageReport %}
								<tr>
									<td>{{ item.label }}</td>
									<td>
										{% include 'lindemannrock-base/_components/badge' with {
											label: item.covered ? 'Search Manager'|t('search-manager') : 'Craft native'|t('search-manager'),
											value: item.covered ? 'searchManager' : 'craftNative',
											colorSet: 'nativeSearchCoverage',
										} only %}
									</td>
									<td>
										{% if item.covered and item.indexHandle %}
											<code>{{ item.indexHandle }}</code>
										{% else %}
											<span class="light">{{ 'Fallback'|t('search-manager') }}</span>
										{% endif %}
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				{% else %}
					{% include 'lindemannrock-base/_components/info-box' with {
						type: 'info',
						message: 'Replace Native Search requires a local backend (MySQL, PostgreSQL, Redis, or File). Configure one to enable coverage.'|t('search-manager'),
					} %}
				{% endif %}
			</div>

			{% js %}
				(() => {
					const $section = $('#native-search-coverage-settings');
					const $lightswitch = $('#replaceNativeSearch').closest('.lightswitch');

					if (!$section.length || !$lightswitch.length) {
						return;
					}

					const updateNativeSearchCoverageVisibility = () => {
						$section.toggleClass('hidden', !$lightswitch.hasClass('on'));
					};

					$lightswitch.on('change', updateNativeSearchCoverageVisibility);
					updateNativeSearchCoverageVisibility();
				})();
			{% endjs %}
		{% else %}
			<div class="field">
				<div class="heading">
					<label>{{ 'Replace Native Search'|t('search-manager') }}</label>
				</div>
				<div class="instructions">
					<p>{{ 'Enhance Craft\'s Control Panel and template search with Search Manager for element types that have a full-coverage index. Types without one keep using Craft\'s native search.'|t('search-manager') }}</p>
				</div>
			</div>
			{% include 'lindemannrock-base/_components/info-box' with {
				type: 'info',
				message: 'Replace Native Search requires a local backend (MySQL, PostgreSQL, Redis, or File). Configure one to enable coverage.'|t('search-manager')
			} %}
		{% endif %}

		{{ forms.textField({
            label: 'Batch Size'|t('search-manager'),
            instructions: 'Number of elements to index in each batch'|t('search-manager'),
            id: 'batchSize',
            name: 'settings[batchSize]',
            value: settings.batchSize,
            type: 'number',
            min: 10,
            max: 1000,
            required: true,
            disabled: settings.isOverriddenByConfig('batchSize'),
            warning: settings.isOverriddenByConfig('batchSize') ?
                "This is being overridden by the <code>batchSize</code> setting in <code>config/search-manager.php</code>."|t('search-manager')|raw : null,
            errors: settings.getErrors('batchSize')
        }) }}

		{{ forms.textField({
            label: 'Last Indexed Debounce'|t('search-manager'),
            instructions: 'Minimum seconds between automatic Last Indexed timestamp updates during save and delete syncs. Set to 0 to update after every successful auto-sync.'|t('search-manager'),
            id: 'lastIndexedDebounceSeconds',
            name: 'settings[lastIndexedDebounceSeconds]',
            value: settings.lastIndexedDebounceSeconds,
            type: 'number',
            min: 0,
            max: 3600,
            required: true,
            disabled: settings.isOverriddenByConfig('lastIndexedDebounceSeconds'),
            warning: settings.isOverriddenByConfig('lastIndexedDebounceSeconds') ?
                "This is being overridden by the <code>lastIndexedDebounceSeconds</code> setting in <code>config/search-manager.php</code>."|t('search-manager')|raw : null,
            errors: settings.getErrors('lastIndexedDebounceSeconds')
        }) }}

		<hr>

		<h3>{{ 'Batch Sync'|t('search-manager') }}</h3>

		{{ forms.textField({
            label: 'Sync Batch Size'|t('search-manager'),
            instructions: 'Maximum number of pending sync rows processed by each batch sync job.'|t('search-manager'),
            id: 'syncBatchSize',
            name: 'settings[syncBatchSize]',
            value: settings.syncBatchSize,
            type: 'number',
            min: 1,
            max: 1000,
            required: true,
            disabled: settings.isOverriddenByConfig('syncBatchSize'),
            warning: settings.isOverriddenByConfig('syncBatchSize') ?
                "This is being overridden by the <code>syncBatchSize</code> setting in <code>config/search-manager.php</code>."|t('search-manager')|raw : null,
            errors: settings.getErrors('syncBatchSize')
        }) }}

		{{ forms.textField({
            label: 'Batch Flush Interval'|t('search-manager'),
            instructions: 'Seconds to wait before draining pending save and delete syncs. Shorter intervals reduce delay; longer intervals coalesce bulk imports more aggressively.'|t('search-manager'),
            id: 'batchFlushInterval',
            name: 'settings[batchFlushInterval]',
            value: settings.batchFlushInterval,
            type: 'number',
            min: 0,
            max: 300,
            required: true,
            disabled: settings.isOverriddenByConfig('batchFlushInterval'),
            warning: settings.isOverriddenByConfig('batchFlushInterval') ?
                "This is being overridden by the <code>batchFlushInterval</code> setting in <code>config/search-manager.php</code>."|t('search-manager')|raw : null,
            errors: settings.getErrors('batchFlushInterval')
        }) }}

		{{ forms.textField({
            label: 'Pending Max Age'|t('search-manager'),
            instructions: 'Seconds to keep abandoned pending sync rows before cleanup.'|t('search-manager'),
            id: 'pendingMaxAge',
            name: 'settings[pendingMaxAge]',
            value: settings.pendingMaxAge,
            type: 'number',
            min: 60,
            max: 604800,
            required: true,
            disabled: settings.isOverriddenByConfig('pendingMaxAge'),
            warning: settings.isOverriddenByConfig('pendingMaxAge') ?
                "This is being overridden by the <code>pendingMaxAge</code> setting in <code>config/search-manager.php</code>."|t('search-manager')|raw : null,
            errors: settings.getErrors('pendingMaxAge')
        }) }}

		{{ forms.textField({
            label: 'Batch Max Attempts'|t('search-manager'),
            instructions: 'Number of failed processing attempts before a pending sync row is abandoned.'|t('search-manager'),
            id: 'batchMaxAttempts',
            name: 'settings[batchMaxAttempts]',
            value: settings.batchMaxAttempts,
            type: 'number',
            min: 1,
            max: 20,
            required: true,
            disabled: settings.isOverriddenByConfig('batchMaxAttempts'),
            warning: settings.isOverriddenByConfig('batchMaxAttempts') ?
                "This is being overridden by the <code>batchMaxAttempts</code> setting in <code>config/search-manager.php</code>."|t('search-manager')|raw : null,
            errors: settings.getErrors('batchMaxAttempts')
        }) }}

		{{ forms.textField({
            label: 'Index Prefix'|t('search-manager'),
            instructions: 'Prefix for index names (useful for multi-environment setups)'|t('search-manager'),
            id: 'indexPrefix',
            name: 'settings[indexPrefix]',
            value: settings.indexPrefix,
            errors: settings.getErrors('indexPrefix'),
            placeholder: 'e.g., dev_, staging_, prod_'|t('search-manager'),
            disabled: settings.isOverriddenByConfig('indexPrefix'),
            warning: settings.isOverriddenByConfig('indexPrefix') ?
                "This is being overridden by the <code>indexPrefix</code> setting in <code>config/search-manager.php</code>."|t('search-manager')|raw : null,
        }) }}

	{% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}
