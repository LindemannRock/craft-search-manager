{# Search Testing Tab #}
{% import "_includes/forms" as forms %}
{% do view.registerAssetBundle('lindemannrock\\searchmanager\\web\\assets\\testtool\\TestToolAsset') %}

{# Get available indices and build siteId mapping #}
{% set allIndices = craft.searchManager.getIndices() %}
{% set enabledIndices = [] %}
{% set indexSiteIds = {} %}
{% for index in allIndices %}
    {% if index.enabled %}
        {% if index.siteId is iterable %}
            {% set siteNames = [] %}
            {% for siteId in index.siteId %}
                {% set site = craft.app.sites.getSiteById(siteId) %}
                {% set siteNames = siteNames|merge([site ? site.name : 'Site #{id}'|t('search-manager', {id: siteId})]) %}
            {% endfor %}
            {% set siteLabel = siteNames|join(', ') %}
        {% elseif index.siteId %}
            {% set site = craft.app.sites.getSiteById(index.siteId) %}
            {% set siteLabel = site ? site.name : 'Site #{id}'|t('search-manager', {id: index.siteId}) %}
        {% else %}
            {% set siteLabel = 'All Sites'|t('search-manager') %}
        {% endif %}
        {% set enabledIndices = enabledIndices|merge([{value: index.handle, label: index.name ~ ' — ' ~ siteLabel}]) %}
        {% if index.siteId is iterable %}
            {% set normalizedSiteId = index.siteId|length == 1 ? index.siteId|first : null %}
        {% else %}
            {% set normalizedSiteId = index.siteId %}
        {% endif %}
        {% set indexSiteIds = indexSiteIds|merge({(index.handle): normalizedSiteId}) %}
    {% endif %}
{% endfor %}

{% include 'lindemannrock-base/_components/info-box' with {
    type: 'info',
    variant: 'colored',
    margin: 'bottom',
    message: '<strong>' ~ 'Developer resources'|t('search-manager') ~ '</strong><br>' ~ 'Download the Postman collection and environment to test the Search Manager API outside Craft.'|t('search-manager') ~ '<br><br><a href="' ~ actionUrl('search-manager/settings/download-postman-collection') ~ '" class="btn" data-icon="download">' ~ 'Download Postman collection'|t('search-manager') ~ '</a>',
} only %}

{# Search Configuration #}
<div class="pane sm-test-pane-spaced">
    <h3 class="first">{{ "Search Configuration"|t('search-manager') }}</h3>

    {{ forms.selectField({
        label: 'Search Index'|t('search-manager'),
        instructions: 'Select which index to search'|t('search-manager'),
        id: 'testIndex',
        name: 'testIndex',
        options: enabledIndices,
        value: enabledIndices[0].value ?? '',
    }) }}

    <div class="field">
        <div class="heading">
            <label for="testQuery">{{ "Search Query"|t('search-manager') }}</label>
        </div>
        <div class="instructions">
            <p>{{ "Enter a search query to test. Supports all operators."|t('search-manager') }}</p>
        </div>
        <div class="sm-test-query-wrap">
            <input type="text" id="testQuery" name="testQuery" class="text fullwidth" value="" placeholder="{{ "Try: 'exact phrase', test NOT spam, title:blog, test*"|t('search-manager') }}" maxlength="256" autocomplete="off">
            {# Autocomplete dropdown #}
            <div id="autocomplete-dropdown" class="sm-test-autocomplete-dropdown" hidden></div>
        </div>
    </div>

    {# Test Feature Toggles #}
    <div class="field sm-test-feature-field">
        <div class="heading">
            <label>{{ "Test Features"|t('search-manager') }}</label>
        </div>
        <div class="sm-test-feature-grid">
            <label class="sm-test-toggle-card">
                <input type="checkbox" id="enableWildcard" name="enableWildcard">
                <span>{{ "Auto Wildcards"|t('search-manager') }}</span>
            </label>
            <label class="sm-test-toggle-card">
                <input type="checkbox" id="showAutocomplete" name="showAutocomplete" {{ settings.enableAutocomplete ? 'checked' : '' }}>
                <span>{{ "Test Autocomplete"|t('search-manager') }}</span>
            </label>
            <label class="sm-test-toggle-card">
                <input type="checkbox" id="showPromotions" name="showPromotions">
                <span>{{ "Test Promotions"|t('search-manager') }}</span>
            </label>
            <label class="sm-test-toggle-card">
                <input type="checkbox" id="showQueryRules" name="showQueryRules">
                <span>{{ "Test Query Rules"|t('search-manager') }}</span>
            </label>
            <label class="sm-test-toggle-card">
                <input type="checkbox" id="showHighlighting" name="showHighlighting" checked>
                <span>{{ "Show Highlighting"|t('search-manager') }}</span>
            </label>
            <label class="sm-test-toggle-card">
                <input type="checkbox" id="enableLiveComparison" name="enableLiveComparison">
                <span>{{ "Live Comparison"|t('search-manager') }}</span>
            </label>
            <label class="sm-test-toggle-card">
                <input type="checkbox" id="resultsRequireUrl">
                <span>{{ "Hide Without URL"|t('search-manager') }}</span>
            </label>
            <label class="sm-test-toggle-card">
                <input type="checkbox" id="includeDebugMeta" name="includeDebugMeta">
                <span>{{ "Debug Metadata"|t('search-manager') }}</span>
            </label>
        </div>
    </div>

    {# Snippet options are part of the public indexed pipeline. #}
    <div id="snippetOptions" class="field sm-test-enrich-panel">
        <div class="sm-test-enrich-card">
            <h4 class="sm-test-enrich-title">{{ "Snippet Options"|t('search-manager') }}</h4>
            <div class="sm-test-enrich-grid">
                <div>
                    {{ forms.selectField({
                        label: 'Snippet Mode'|t('search-manager'),
                        id: 'snippetMode',
                        name: 'snippetMode',
                        options: [
                            {value: 'early', label: 'Early — first occurrence'|t('search-manager')},
                            {value: 'balanced', label: 'Balanced — best match'|t('search-manager')},
                            {value: 'deep', label: 'Deep — exhaustive search'|t('search-manager')},
                        ],
                        value: 'balanced',
                    }) }}
                </div>
                <div>
                    <label for="snippetMaxLength" class="sm-test-number-label">{{ "Snippet Length (50–1000 chars)"|t('search-manager') }}</label>
                    <input type="number" id="snippetMaxLength" class="text fullwidth sm-test-number-input" value="{{ snippetOptions.snippetMaxLength }}" min="{{ snippetOptions.minSnippetLength }}" max="{{ snippetOptions.maxSnippetLength }}" step="50">
                </div>
            </div>
            <div class="sm-test-enrich-options">
                <label class="sm-test-enrich-option">
                    <input type="checkbox" id="snippetIncludeCodeBlocks">
                    {{ "Show Code Snippets"|t('search-manager') }}
                </label>
                <label class="sm-test-enrich-option">
                    <input type="checkbox" id="snippetCleanMarkdown">
                    {{ "Parse Markdown"|t('search-manager') }}
                </label>
            </div>
        </div>
    </div>

    <div class="sm-test-actions">
        <button type="button" id="testButton" class="btn submit">{{ "Search"|t('search-manager') }}</button>
        {% if cacheEnabled %}
            <button type="button" id="clearCacheButton" class="btn">{{ "Clear Search Cache"|t('search-manager') }}</button>
        {% endif %}
        {% if settings.enableAutocompleteCache %}
            <button type="button" id="clearAutocompleteCacheButton" class="btn">{{ "Clear Autocomplete Cache"|t('search-manager') }}</button>
        {% endif %}
        <span id="cacheStatus" class="sm-test-cache-status"></span>
    </div>
</div>

{# Quick Operator Tests #}
<div class="pane sm-test-pane-spaced">
    <h3 class="first">{{ "Quick Operator Tests"|t('search-manager') }}</h3>
    <p class="light">{{ "Click to test different search operators"|t('search-manager') }}</p>
    <div class="sm-test-quick-tests">
        <button type="button" class="btn small quick-test" data-query="test">{{ "Basic"|t('search-manager') }}</button>
        <button type="button" class="btn small quick-test" data-query='"test entry"'>{{ "Phrase"|t('search-manager') }}</button>
        <button type="button" class="btn small quick-test" data-query="test NOT spam">NOT</button>
        <button type="button" class="btn small quick-test" data-query="title:test">{{ "Field"|t('search-manager') }}</button>
        <button type="button" class="btn small quick-test" data-query="test*">{{ "Wildcard"|t('search-manager') }}</button>
        <button type="button" class="btn small quick-test" data-query="test^2 entry">{{ "Boost"|t('search-manager') }}</button>
        <button type="button" class="btn small quick-test" data-query="test OR entry">OR</button>
        <button type="button" class="btn small quick-test" data-query='test* OR entry title:blog NOT spam'>{{ "Combined"|t('search-manager') }}</button>
    </div>
</div>

{# Autocomplete Preview Section #}
<div id="autocomplete-section" class="pane sm-test-pane-spaced" hidden>
    <h3 class="first">{{ "Autocomplete Suggestions"|t('search-manager') }}</h3>
    <div id="autocomplete-results">
        <p class="light">{{ "Type at least {minLength} characters above to see suggestions"|t('search-manager', {minLength: settings.autocompleteMinLength ?? 2}) }}</p>
    </div>
</div>

{# Promotions Preview Section #}
<div id="promotions-section" class="pane sm-test-pane-spaced" hidden>
    <h3 class="first">{{ "Matched Promotions"|t('search-manager') }}</h3>
    <div id="promotions-results">
        <p class="light">{{ "Run a search to see which promotions match"|t('search-manager') }}</p>
    </div>
</div>

{# Query Rules Preview Section #}
<div id="queryrules-section" class="pane sm-test-pane-spaced" hidden>
    <h3 class="first">{{ "Matched Query Rules"|t('search-manager') }}</h3>
    <div id="queryrules-results">
        <p class="light">{{ "Run a search to see which query rules apply"|t('search-manager') }}</p>
        <p class="sm-test-query-rules-cache-note"><strong>{{ "Note:"|t('search-manager') }}</strong> {{ "Query rule testing bypasses the search cache so debug output reflects a live search."|t('search-manager') }}</p>
    </div>
</div>

{# Main Results Section #}
<div id="testResults" hidden>
    <div class="pane">
        <h3 id="resultsTitle" class="first"></h3>
        <div id="resultsContent"></div>
    </div>
</div>

{% js %}
