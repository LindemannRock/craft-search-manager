{% if topSearch %}
    {% set topItem = {
        label: "Top Search"|t('search-manager'),
        title: topSearch.query,
        url: cpUrl('search-manager/analytics'),
        meta: topSearch.count|number ~ ' ' ~ "searches"|t('search-manager'),
    } %}
{% else %}
    {% set topItem = null %}
{% endif %}

{% include 'lindemannrock-base/_components/dashboard-widget-stats' with {
    stats: [
        {value: analyticsData.totalSearches, label: "Total Searches"|t('search-manager')},
        {value: analyticsData.uniqueVisitors, label: "Unique Visitors"|t('search-manager')},
        {value: analyticsData.zeroResults, label: "Zero Results"|t('search-manager')},
        {value: analyticsData.zeroResultsRate, suffix: '%', label: "Zero Results Rate"|t('search-manager')},
    ],
    topItem: topItem,
    footer: {
        url: cpUrl('search-manager/analytics'),
        label: "View full analytics"|t('search-manager'),
    },
} only %}
