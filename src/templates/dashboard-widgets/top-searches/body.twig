{% set rows = [] %}

{% for search in searches %}
    {% set rows = rows|merge([{
        primary: search.query,
        primaryUrl: cpUrl('search-manager/analytics'),
        meta: search.totalResults|number ~ ' ' ~ "results"|t('search-manager'),
        value: search.count|number,
    }]) %}
{% endfor %}

{% include 'lindemannrock-base/_components/dashboard-widget-list' with {
    primaryHeader: "Query"|t('search-manager'),
    valueHeader: "Searches"|t('search-manager'),
    rows: rows,
    empty: {
        title: "No searches yet"|t('search-manager'),
        message: "Search analytics will appear here once users start searching."|t('search-manager'),
    },
    footer: {
        url: cpUrl('search-manager/analytics'),
        label: "View all searches"|t('search-manager'),
    },
} only %}
