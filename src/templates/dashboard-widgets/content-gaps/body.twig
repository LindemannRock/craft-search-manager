{% set rows = [] %}

{% for gap in contentGaps %}
    {% set rows = rows|merge([{
        primary: gap.representative,
        primaryUrl: cpUrl('search-manager/analytics'),
        primaryTitle: gap.queries|join(', '),
        meta: gap.queries|length > 1 ? '+' ~ (gap.queries|length - 1) ~ ' ' ~ "similar"|t('search-manager') : null,
        value: gap.count|number,
    }]) %}
{% endfor %}

{% include 'lindemannrock-base/_components/dashboard-widget-list' with {
    primaryHeader: "Query"|t('search-manager'),
    valueHeader: "Hits"|t('search-manager'),
    rows: rows,
    empty: {
        title: "No content gaps"|t('search-manager'),
        message: "All searches are returning results."|t('search-manager'),
        type: 'success',
    },
    footer: {
        url: cpUrl('search-manager/analytics'),
        label: "View all content gaps"|t('search-manager'),
    },
} only %}
