{% set rows = [] %}

{% for item in trending %}
    {% if item.trend == 'up' %}
        {% set trendLabel = '▲ ' ~ item.changePercent ~ '%' %}
        {% set trendTitle = item.changePercent ~ '% ' ~ 'increase'|t('search-manager') %}
    {% elseif item.trend == 'down' %}
        {% set trendLabel = '▼ ' ~ item.changePercent ~ '%' %}
        {% set trendTitle = item.changePercent ~ '% ' ~ 'decrease'|t('search-manager') %}
    {% elseif item.trend == 'new' %}
        {% set trendLabel = "New"|t('search-manager') %}
        {% set trendTitle = "New query"|t('search-manager') %}
    {% else %}
        {% set trendLabel = '-' %}
        {% set trendTitle = "No change"|t('search-manager') %}
    {% endif %}

    {% set rows = rows|merge([{
        primary: item.query,
        primaryUrl: cpUrl('search-manager/analytics'),
        meta: item.count|number ~ ' ' ~ "searches"|t('search-manager'),
        value: trendLabel,
        valueTitle: trendTitle,
    }]) %}
{% endfor %}

{% include 'lindemannrock-base/_components/dashboard-widget-list' with {
    primaryHeader: "Query"|t('search-manager'),
    valueHeader: "Trend"|t('search-manager'),
    rows: rows,
    empty: {
        title: "No trending data yet"|t('search-manager'),
        message: "Trending data requires search history to compare."|t('search-manager'),
    },
    footer: {
        url: cpUrl('search-manager/analytics'),
        label: "View all analytics"|t('search-manager'),
    },
} only %}
